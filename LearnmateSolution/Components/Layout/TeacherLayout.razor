@inherits LayoutComponentBase

<div class="flex min-h-screen bg-white font-display text-slate-900">
    <!-- Sidebar -->
    <aside class="sticky top-0 h-screen hidden lg:block">
        <TeacherNavMenu />
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col">
        <!-- Top Header -->
        <header class="sticky top-0 z-40 flex items-center justify-between border-b border-slate-200 bg-white/80 backdrop-blur-md px-6 py-3">
            <div class="flex items-center gap-4">
                <!-- Mobile Menu Button (Hamburger) -->
                <button class="lg:hidden p-2 text-slate-600">
                    <span class="material-symbols-outlined">menu</span>
                </button>

                <!-- Search Bar -->
                <div class="hidden md:flex items-center w-64 lg:w-80 h-9 bg-slate-100 rounded-lg px-3 gap-2 focus-within:ring-2 focus-within:ring-primary/20 transition-all">
                    <span class="material-symbols-outlined text-slate-400 text-[20px]">search</span>
                    <input class="bg-transparent border-none outline-none w-full text-sm text-slate-700 placeholder:text-slate-400"
                           placeholder="Search classes, students..." />
                </div>
            </div>

            <div class="flex items-center gap-4">
                <button class="flex items-center justify-center size-9 rounded-lg hover:bg-slate-100 text-slate-600 transition-colors relative">
                    <span class="material-symbols-outlined text-[22px]">notifications</span>
                    <span class="absolute top-2 right-2 size-2 bg-red-500 rounded-full border border-white"></span>
                </button>
                <div class="w-px h-6 bg-slate-200 mx-1"></div>
                
                <!-- Profile Dropdown (Simplified) -->
                <div class="flex items-center gap-3 cursor-pointer group">
                    <div class="size-8 rounded-full bg-slate-200 border border-slate-200 dark:border-slate-700 overflow-hidden">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Sarah" alt="Avatar" />
                    </div>
                    <div class="hidden sm:block text-left">
                        <p class="text-xs font-bold text-slate-900 dark:text-white leading-none mb-0.5">Sarah Wilson</p>
                        <p class="text-[10px] text-slate-500 dark:text-slate-400 leading-none">Mathematics Teacher</p>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 text-[18px] group-hover:translate-y-0.5 transition-transform">expand_more</span>
                </div>
            </div>
        </header>

        <!-- Dynamic Body Content -->
        <main class="flex-1 p-6 lg:p-8 max-w-[1600px] mx-auto w-full">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" class="fixed bottom-0 w-full z-[100] hidden">
    <div class="bg-red-600 text-white p-4 flex items-center justify-between shadow-xl">
        <span class="flex items-center gap-2">
            <span class="material-symbols-outlined">error</span>
            An unhandled error has occurred.
        </span>
        <div class="flex gap-4">
            <a href="" class="underline font-bold">Reload</a>
            <button class="dismiss">✕</button>
        </div>
    </div>
</div>

<style>
    /* Prevent Tailwind Preflight from stripping out base styles for Blazor content if needed */
    main :deep(h1) { font-size: 1.875rem; font-weight: 700; }
    main :deep(h2) { font-size: 1.5rem; font-weight: 700; }
    main :deep(p) { margin-bottom: 1rem; }
    
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    .dark ::-webkit-scrollbar-thumb { background: #1e293b; }
</style>
