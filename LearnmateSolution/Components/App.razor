<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="LearnmateSolution.styles.css" />
    <link rel="stylesheet" href="/css/admin/admin-layout.css" />
    <link rel="stylesheet" href="/css/admin/admin-reports.css" />
    <link rel="icon" type="image/svg+xml" href="images/logo.svg" />
    <!-- Admin layout styles (loaded globally to ensure HeadContent injection works) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&family=Noto+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link rel="stylesheet" href="css/admin/admin-layout.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {

            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "primary-hover": "#0d6efd",
                        "primary-light": "#EEF6FF",
                        "background-light": "#F6F7F9",
                        "background-dark": "#101922",
                    },
                    fontFamily: { "display": ["Inter"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <HeadOutlet />
</head>

<body id="app">
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="js/voice.js"></script>
    <script>
        Blazor.addEventListener('enhancedload', function () {
            window.scrollTo(0, 0);
        });
    </script>
    <script>
        window.initChatInput = function (el, dotnetHelper) {
            if (!el) return;
            el.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    dotnetHelper.invokeMethodAsync('SendFromJs');
                }
            });
            el.addEventListener('input', function () {
                el.style.height = 'auto';
                el.style.height = el.scrollHeight + 'px';
            });
        };
        window.resetTextareaHeight = function (el) {
            if (!el) return;
            el.style.height = 'auto';
        };
    </script>
    <script>
        window.scrollToBottom = function (el) {
            if (el) el.scrollTop = el.scrollHeight;
        };
        window.getScrollHeight = function (el) {
            return el ? el.scrollHeight : 0;
        };
        window.adjustScrollAfterPrepend = function (el, prevScrollHeight) {
            if (el) el.scrollTop += (el.scrollHeight - prevScrollHeight);
        };
        window.downloadFile = function (filename, content, mimeType) {
            const blob = new Blob([content], { type: mimeType });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        };
    </script>
</body>

</html>
