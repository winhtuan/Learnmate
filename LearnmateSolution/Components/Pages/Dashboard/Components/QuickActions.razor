@using LearnmateSolution.Components.Pages.Dashboard.Models

<div class="bg-white rounded-2xl border border-slate-200 p-5">
    <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-slate-400">bolt</span>
        Quick Actions
    </h3>
    <div class="grid grid-cols-2 gap-3">
        @{
            var seasonStyles = new[]
            {
                ("hover:bg-emerald-100", "Spring"),
                ("hover:bg-sky-100",     "Summer"),
                ("hover:bg-amber-100",   "Autumn"),
                ("hover:bg-blue-100",    "Winter"),
            };
        }
        @for (int i = 0; i < Actions.Count; i++)
        {
            var action = Actions[i];
            var hoverBg = seasonStyles[i % seasonStyles.Length].Item1;
            <button class="group flex flex-col items-center justify-center p-4 rounded-2xl bg-slate-50 @hoverBg text-slate-600 transition-all border border-slate-100 outline-none focus:outline-none">
                <span class="material-symbols-outlined mb-2 group-hover:scale-110 transition-transform">@action.Icon</span>
                <span class="text-xs font-semibold">@action.Label</span>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public List<QuickAction> Actions { get; set; } = [];
}
