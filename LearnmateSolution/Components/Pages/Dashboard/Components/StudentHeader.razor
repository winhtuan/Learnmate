@rendermode InteractiveServer
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Student
@using LearnmateSolution.Services

@* Backdrop ngoài header — z-[49] để bắt click ở body page *@
@if (_menuOpen)
{
    <div class="fixed inset-0 z-[49]" @onclick="CloseMenu"></div>
}

<header @onclick="CloseMenu" class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-3 flex items-center justify-between gap-4">

        @* Logo *@
        <a href="/student-dashboard" class="flex items-center gap-2 shrink-0 no-underline">
            <img src="images/logo.svg" class="size-8" alt="LearnMate" />
            <span class="text-xl font-bold leading-tight tracking-tight text-slate-900 hidden sm:block">LearnMate</span>
        </a>

        @* Nav links (lg+) *@
        <nav class="hidden lg:flex items-center gap-6">
            @foreach (var link in _navLinks)
            {
                var isActive = Nav.Uri.Contains(link.Href);
                <a href="@link.Href"
                       class="no-underline text-sm font-medium transition-colors @(isActive ? "text-primary" : "text-slate-600 hover:text-primary")">
                    @link.Label
                </a>
            }
        </nav>

        @* Right side *@
        <div class="flex items-center gap-3 shrink-0">

            @* Avatar trigger + Dropdown: stopPropagation ngăn header CloseMenu khi click vào đây *@
            <div class="relative" @onclick:stopPropagation>

                @* Trigger: name + avatar *@
                <button @onclick="ToggleMenu"
                        class="flex items-center gap-2.5 rounded-full pl-3 pr-1 py-1 hover:bg-slate-100 transition-colors outline-none focus:outline-none border-0">
                    <span class="hidden sm:block text-sm font-semibold text-slate-700 leading-none">@_fullName</span>
                    <img src="@AvatarSrc" alt="Profile"
                         class="size-8 rounded-full object-cover ring-2 transition-all @(_menuOpen ? "ring-slate-400" : "ring-slate-200")" />
                </button>

                @* Panel *@
                @if (_menuOpen)
                {
                    <div class="absolute right-0 mt-2 w-64 bg-white rounded-2xl border border-slate-200 shadow-xl overflow-hidden z-[51]"
                         style="top: 100%;">

                        @* Profile header *@
                        <div class="px-4 py-4 flex items-center gap-3 bg-slate-50 border-b border-slate-100">
                            <img src="@AvatarSrc" alt="Avatar"
                                 class="size-11 rounded-full object-cover shrink-0 ring-2 ring-white shadow-sm" />
                            <div class="min-w-0">
                                <p class="text-[15px] font-bold text-slate-900 truncate">@_fullName</p>
                                <p class="text-[12px] text-slate-400 truncate">@_email</p>
                                @if (_gradeLevel is not null)
                                {
                                    <span
                                        class="inline-flex items-center gap-1 mt-1.5 text-[11px] font-bold tracking-wide text-indigo-700 bg-indigo-100 border border-indigo-200 rounded-full px-2.5 py-0.5 leading-tight">
                                        Grade @_gradeLevel
                                    </span>
                                }
                            </div>
                        </div>

                        @* Menu items *@
                        <div class="py-1.5">
                            @foreach (var item in _menuItems)
                            {
                                <button @onclick="() => Navigate(item.Href)"
                                        class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 transition-colors outline-none focus:outline-none border-0 text-left">
                                    <span
                                    class="material-symbols-outlined text-[20px] text-slate-400 shrink-0">@item.Icon</span>
                                    <span class="font-medium">@item.Label</span>
                                </button>
                            }
                        </div>

                        @* Sign out *@
                        <div class="border-t border-slate-100 py-1.5">
                            <button @onclick="SignOut"
                                    class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-rose-600 hover:bg-rose-50 transition-colors outline-none focus:outline-none border-0 text-left">
                                <span class="material-symbols-outlined text-[20px] shrink-0">logout</span>
                                <span class="font-medium">Sign Out</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</header>

@code {
    private record NavLink(string Label, string Href);
    private record MenuItem(string Label, string Icon, string Href);

    private string _fullName = "Student";
    private string _email = "";
    private string? _avatarUrl;
    private string? _gradeLevel;
    private bool _menuOpen;

    private const string DefaultAvatar = "https://placehold.co/400?text=avatar";

    private string AvatarSrc => _avatarUrl is not null and not "" ? _avatarUrl : DefaultAvatar;

    private static readonly NavLink[] _navLinks =
    [
        new("Dashboard", "/student-dashboard"),
        new("Class", "/classes"),
        new("Schedule", "/schedule"),
        new("Assignment","/assignments"),
    ];

    private static readonly MenuItem[] _menuItems =
    [
        new("My Profile", "account_circle", "/profile"),
        new("Settings", "settings", "/settings"),
        new("Help", "help", "/help"),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // ── Restore session ───────────────────────────────────────────────────
        if (!Session.IsAuthenticated)
        {
            var email = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
            var role = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
            if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
                Session.SetSession(email, role, token);
        }

        if (!Session.IsAuthenticated) return; // page guard handles redirect

        _email = Session.Email ?? "";

        // ── Load profile from API ─────────────────────────────────────────────
        try
        {
            var client = HttpClientFactory.CreateClient("learnmate");
            client.BaseAddress = new Uri(Nav.BaseUri);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);

            var resp = await client.GetFromJsonAsync<ApiResponse<StudentProfileHeaderDto>>("api/student/me");
            if (resp?.Data is { } data)
            {
                _fullName = data.FullName;
                _avatarUrl = data.AvatarUrl;
                _gradeLevel = data.GradeLevel;
            }
        }
        catch
        {
            // Keep defaults — header still renders with email from session
        }

        StateHasChanged();
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;

    private void Navigate(string href)
    {
        _menuOpen = false;
        Nav.NavigateTo(href);
    }

    private async Task SignOut()
    {
        _menuOpen = false;
        Session.Clear();
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_email");
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_role");
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_token");
        Nav.NavigateTo("/login", replace: true);
    }
}
