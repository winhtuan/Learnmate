@inject NavigationManager Nav

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-3 flex items-center justify-between gap-4">

        @* Logo *@
        <a href="/student-dashboard" class="flex items-center gap-2 shrink-0 no-underline">
            <img src="images/logo.svg" class="size-8" alt="LearnMate" />
            <span class="text-xl font-bold leading-tight tracking-tight text-slate-900 hidden sm:block">LearnMate</span>
        </a>

        @* Search bar (md+) *@
        <div class="hidden md:flex items-center bg-slate-100 rounded-full h-10 w-64 lg:w-80 focus-within:ring-2 focus-within:ring-primary/30 transition-all px-4 gap-2">
            <span class="material-symbols-outlined text-[20px] text-slate-400 shrink-0">search</span>
            <input type="text"
                   placeholder="Search..."
                   class="flex-1 bg-transparent text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none border-0 !shadow-none p-0" />
        </div>

        @* Nav links (lg+) *@
        <nav class="hidden lg:flex items-center gap-6">
            @foreach (var link in navLinks)
            {
                var isActive = Nav.Uri.Contains(link.Href);
                <a href="@link.Href"
                   class="no-underline text-sm font-medium transition-colors @(isActive ? "text-primary" : "text-slate-600 hover:text-primary")">
                    @link.Label
                </a>
            }
        </nav>

        @* Right side *@
        <div class="flex items-center gap-3 shrink-0">
            @* Bell *@
            <button class="relative size-9 flex items-center justify-center rounded-full hover:bg-slate-100 transition-colors outline-none focus:outline-none border-0">
                <span class="material-symbols-outlined text-[22px] text-slate-500">notifications</span>
                <span class="absolute top-1 right-1 size-2 bg-red-500 rounded-full border-2 border-white"></span>
            </button>

            @* Avatar *@
            <button class="size-9 rounded-full bg-slate-200 ring-2 ring-slate-100 hover:ring-primary transition-all overflow-hidden">
                <img src="https://api.dicebear.com/7.x/notionists/svg?seed=student" alt="Profile" class="w-full h-full object-cover" />
            </button>
        </div>
    </div>
</header>

@code {
    private record NavLink(string Label, string Href);
    private readonly NavLink[] navLinks =
    [
        new("Dashboard", "/student-dashboard"),
        new("Class", "/classes"),
        new("Schedule", "/schedule"),
        new("Assignment", "/assignments"),
    ];
}
