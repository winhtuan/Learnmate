@using LearnmateSolution.Components.Pages.Dashboard.Models
@inject NavigationManager Nav

<div>
    <div class="flex justify-between items-center mb-4 px-1">
        <h2 class="text-xl font-bold text-slate-900">My Classes</h2>
        <a href="/classes" class="text-base font-bold text-slate-500 hover:text-primary transition-colors outline-none border-0 bg-transparent cursor-pointer p-0 no-underline mr-2">View All</a>
    </div>

    <div class="space-y-3">
        @foreach (var course in Courses)
        {
            <div class="group bg-white p-5 rounded-2xl border border-slate-200 hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                    @* Icon *@
                    <div class="size-12 flex items-center justify-center shrink-0 rounded-xl @course.IconBg">
                        <span class="material-symbols-outlined text-[24px] @course.IconColor">@course.Icon</span>
                    </div>

                    @* Content *@
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2 mb-1.5">
                            <p class="font-semibold text-slate-900 text-[15px] truncate">@course.Title</p>
                            <span class="text-sm font-bold text-slate-400 shrink-0">@course.Progress%</span>
                        </div>
                        <div class="bg-slate-100 rounded-full h-1.5 mb-2">
                            <div class="@course.ProgressColor h-1.5 rounded-full transition-all"
                                 style="width: @(course.Progress)%"></div>
                        </div>
                        <p class="text-[13px] text-slate-400">
                            @course.NextTask
                            @if (course.DueDate is not null)
                            {
                                <span> • <span class="text-orange-500">@course.DueDate</span></span>
                            }
                        </p>
                    </div>

                    @* Arrow *@
                    <button class="shrink-0 size-8 flex items-center justify-center rounded-full hover:bg-slate-100 text-slate-400 hover:text-primary transition-colors outline-none focus:outline-none border-0 ml-2">
                        <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<CourseItem> Courses { get; set; } = [];
}
