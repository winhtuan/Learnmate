@page "/teacher/assignments/{AssignmentId:long}/edit"
@rendermode InteractiveServer
@layout Layout.TeacherLayout

@using BusinessLogicLayer.DTOs.Teacher.Assignments
@using BusinessLogicLayer.DTOs.Teacher.Classes
@using BusinessLogicLayer.Services.Interfaces
@using BusinessObject.Enum
@using LearnmateSolution.AppState
@inject ITeacherAssignmentService AssignmentService
@inject ITeacherCourseService ClassService
@inject UserSessionService Session
@inject NavigationManager NavigationManager

<PageTitle>Edit Assignment | LearnMate</PageTitle>

@if (IsLoading)
{
    <div class="flex items-center justify-center py-20">
        <span class="material-symbols-outlined animate-spin text-primary text-4xl">progress_activity</span>
    </div>
}
else if (Model == null)
{
    <div class="bg-white border border-slate-200 rounded-lg p-12 text-center shadow-sm">
        <span class="material-symbols-outlined text-slate-300 text-6xl mb-4">error</span>
        <h2 class="text-xl font-bold text-slate-900 mb-2">Assignment Not Found</h2>
        <p class="text-slate-500 mb-6">The assignment you're looking for doesn't exist or has been deleted.</p>
        <button type="button" @onclick='() => NavigationManager.NavigateTo("/teacher/assignments/create")' class="bg-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-600 transition-colors">
            Back to Assignments
        </button>
    </div>
}
else
{
    <!-- Page Heading -->
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-1">Edit Assignment</h1>
            <p class="text-slate-500 font-normal">Update your assignment details, questions, and settings.</p>
        </div>
        <button type="button" @onclick='() => NavigationManager.NavigateTo("/teacher/classes")' class="flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors">
            <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            Back to Classes
        </button>
    </div>

    <EditForm Model="Model" OnValidSubmit="HandleUpdate" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <DataAnnotationsValidator />

        <!-- Left Column -->
        <div class="lg:col-span-8 flex flex-col gap-6">
            <div class="bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden p-6">
                <h3 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-3">Basic Information</h3>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="mb-4 p-4 rounded-lg bg-red-50 text-red-600 border border-red-200 flex items-center gap-2 text-sm">
                        <span class="material-symbols-outlined text-[20px]">error</span>
                        @ErrorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(SuccessMessage))
                {
                    <div class="mb-4 p-4 rounded-lg bg-green-50 text-green-700 border border-green-200 flex items-center gap-2 text-sm">
                        <span class="material-symbols-outlined text-[20px]">check_circle</span>
                        @SuccessMessage
                    </div>
                }

                <div class="flex flex-col gap-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Assignment Title <span class="text-red-500">*</span></label>
                        <InputText @bind-Value="Model.Title" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400" placeholder="e.g., Midterm Physics Test" />
                        <ValidationMessage For="@(() => Model.Title)" class="text-red-500 text-xs mt-1" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Criteria &amp; Instructions</label>
                        <InputTextArea @bind-Value="Model.Description" rows="5" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400 resize-y" placeholder="Enter instructions, scoring criteria..." />
                    </div>
                </div>
            </div>

            <!-- File Upload Section (replaces Questions) -->
            <div class="bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden p-6">
                <h3 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-3">Assignment File</h3>
                <p class="text-sm text-slate-500 mb-4">Upload a new assignment document (PDF, DOCX, PPT, ZIP, images, etc.). Max 50 MB.</p>
                
                <label class="border-2 border-dashed rounded-lg p-8 flex flex-col items-center text-center cursor-pointer transition-all
                    @(UploadedFile != null ? "border-primary/50 bg-primary/5" : "border-slate-300 hover:border-primary hover:bg-slate-50")">
                    @if (IsUploading)
                    {
                        <span class="material-symbols-outlined animate-spin text-primary text-4xl mb-2">progress_activity</span>
                        <p class="text-sm font-medium text-primary">Uploading...</p>
                    }
                    else if (UploadedFile != null)
                    {
                        <span class="material-symbols-outlined text-primary text-4xl mb-2">task</span>
                        <p class="text-sm font-bold text-primary">@UploadedFile.Name</p>
                        <p class="text-xs text-slate-400 mt-1">@FormatFileSize(UploadedFile.Size) — Click to change</p>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-slate-400 text-4xl mb-2">cloud_upload</span>
                        <p class="text-sm font-medium text-slate-700">Click to select a file</p>
                        <p class="text-xs text-slate-400 mt-1">Leave empty to keep current file</p>
                    }
                    <InputFile OnChange="OnFileSelected" class="hidden" />
                </label>

                @if (!string.IsNullOrEmpty(FileUploadError))
                {
                    <p class="text-xs text-red-500 mt-2">@FileUploadError</p>
                }
                @if (!string.IsNullOrEmpty(Model.FileUrl))
                {
                    <div class="mt-3 flex items-center justify-between text-sm p-3 rounded-lg bg-slate-50 border border-slate-200">
                        <div class="flex items-center gap-2 text-primary">
                            <span class="material-symbols-outlined text-[18px]">attachment</span>
                            <span class="font-medium truncate max-w-[200px]" title="@Model.FileUrl">Current File</span>
                        </div>
                        <a href="@Model.FileUrl" target="_blank" class="text-primary hover:underline" @onclick:stopPropagation>View Document &rarr;</a>
                    </div>
                }
            </div>
        </div>

        <!-- Right Column -->
        <div class="lg:col-span-4 flex flex-col gap-6">
            <div class="bg-white rounded-lg border border-slate-200 shadow-sm p-6 flex flex-col gap-5">
                <h3 class="text-lg font-bold text-slate-900 border-b border-slate-100 pb-3">Settings</h3>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Target Class <span class="text-red-500">*</span></label>
                    <InputSelect @bind-Value="Model.ClassId" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary outline-none transition-all appearance-none bg-white">
                        <option value="0" disabled>Select a class...</option>
                        @foreach (var cls in TeacherClasses)
                        {
                            <option value="@cls.Id">@cls.Name (@cls.Subject)</option>
                        }
                    </InputSelect>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Due Date / Deadline</label>
                    <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="Model.DueDate" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary outline-none transition-all text-slate-700" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
                    <InputSelect @bind-Value="Model.Status" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary outline-none transition-all appearance-none bg-white">
                        <option value="@AssignmentStatus.DRAFT">Draft</option>
                        <option value="@AssignmentStatus.PUBLISHED">Published</option>
                        <option value="@AssignmentStatus.CLOSED">Closed</option>
                    </InputSelect>
                </div>
            </div>

            <!-- Info card -->
            <div class="bg-white rounded-lg border border-slate-200 shadow-sm p-5">
                <h4 class="text-sm font-bold text-slate-700 mb-3">Assignment Info</h4>
                <div class="space-y-2 text-xs text-slate-500">
                    <div class="flex justify-between"><span>ID</span><span class="font-mono text-slate-700">#@AssignmentId</span></div>
                    <div class="flex justify-between"><span>Created</span><span class="text-slate-700">@OriginalCreatedAt.ToString("MMM dd, yyyy HH:mm")</span></div>
                    <div class="flex justify-between"><span>File Attached</span><span class="text-slate-700">@(string.IsNullOrEmpty(Model.FileUrl) ? "No" : "Yes")</span></div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col gap-3">
                <button type="submit" disabled="@IsSubmitting" class="w-full flex items-center justify-center gap-2 bg-primary hover:bg-blue-600 text-white font-medium py-3 rounded-lg transition-all shadow-sm disabled:opacity-70 disabled:cursor-not-allowed">
                    @if (IsSubmitting)
                    {
                        <span class="material-symbols-outlined animate-spin">progress_activity</span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-[20px]">save</span>
                        <span>Save Changes</span>
                    }
                </button>
                <button type="button" @onclick='() => NavigationManager.NavigateTo("/teacher/assignments/create")' class="w-full flex items-center justify-center gap-2 bg-white border border-slate-200 text-slate-700 font-medium py-3 rounded-lg hover:bg-slate-50 transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public long AssignmentId { get; set; }

    private UpdateAssignmentDto? Model;
    private bool IsLoading = true;
    private bool IsSubmitting;
    private bool IsUploading;
    private string? ErrorMessage;
    private string? SuccessMessage;
    private string? FileUploadError;
    private IBrowserFile? UploadedFile;
    private DateTime OriginalCreatedAt;

    private List<TeacherClassListItemDto> TeacherClasses = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTeacherClasses();
        await LoadAssignment();
    }

    private async Task LoadTeacherClasses()
    {
        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 1;
            TeacherClasses = await ClassService.GetTeacherClassesAsync(teacherId);
        }
        catch { }
    }

    private async Task LoadAssignment()
    {
        IsLoading = true;
        try
        {
            var detail = await AssignmentService.GetAssignmentByIdAsync(AssignmentId);
            if (detail != null)
            {
                OriginalCreatedAt = detail.CreatedAt;
                Model = new UpdateAssignmentDto
                {
                    ClassId = detail.ClassId,
                    Title = detail.Title,
                    Description = detail.Description,
                    DueDate = detail.DueDate,
                    Status = detail.Status,
                    FileUrl = detail.FileUrl
                };
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to load assignment: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleUpdate()
    {
        if (Model == null) return;

        ErrorMessage = null;
        SuccessMessage = null;

        if (Model.ClassId == 0)
        {
            ErrorMessage = "Please select a target class.";
            return;
        }

        IsSubmitting = true;

        try
        {
            var response = await AssignmentService.UpdateAssignmentAsync(AssignmentId, Model);

            if (response.Success)
            {
                SuccessMessage = "Assignment updated successfully!";
            }
            else
            {
                ErrorMessage = response.Message ?? "Failed to update assignment.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        FileUploadError = null;
        UploadedFile = e.File;

        if (UploadedFile.Size > 50 * 1024 * 1024)
        {
            FileUploadError = "File too large. Maximum 50 MB.";
            UploadedFile = null;
            return;
        }

        IsUploading = true;
        StateHasChanged();

        try
        {
            using var stream = UploadedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var url = await AssignmentService.UploadAssignmentFileAsync(
                stream, UploadedFile.Name, UploadedFile.ContentType);
            if (Model != null)
            {
                Model.FileUrl = url;
            }
        }
        catch (Exception ex)
        {
            FileUploadError = "Upload failed: " + ex.Message;
            UploadedFile = null;
        }
        finally
        {
            IsUploading = false;
            StateHasChanged();
        }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}
