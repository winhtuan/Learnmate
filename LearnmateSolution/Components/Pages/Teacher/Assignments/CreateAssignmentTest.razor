@page "/teacher/assignments/create"
@rendermode InteractiveServer
@layout Layout.TeacherLayout

@using BusinessLogicLayer.DTOs.Teacher.Assignments
@using BusinessLogicLayer.DTOs.Teacher.Classes
@using BusinessLogicLayer.Services.Interfaces
@using BusinessObject.Enum
@using LearnmateSolution.AppState
@inject ITeacherAssignmentService AssignmentService
@inject ITeacherCourseService ClassService
@inject UserSessionService Session
@inject NavigationManager NavigationManager

<PageTitle>Create Assignment | LearnMate</PageTitle>

<!-- Page Heading -->
<div class="mb-8 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-1">Create Assignment</h1>
        <p class="text-slate-500 font-normal">Set up a new assignment for your students.</p>
    </div>
    <button type="button" @onclick='() => NavigationManager.NavigateTo("/teacher/classes")' class="flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors">
        <span class="material-symbols-outlined text-[20px]">arrow_back</span>
        Back to Classes
    </button>
</div>

<!-- Main Form -->
<EditForm Model="Model" OnValidSubmit="HandleSubmit" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    <DataAnnotationsValidator />

    <!-- Left Column: Primary Details (8/12) -->
    <div class="lg:col-span-8 flex flex-col gap-6">
        <div class="bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-3">Basic Information</h3>
            
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="mb-4 p-4 rounded-lg bg-red-50 text-red-600 border border-red-200 flex items-center gap-2 text-sm">
                    <span class="material-symbols-outlined text-[20px]">error</span>
                    @ErrorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="mb-4 p-4 rounded-lg bg-green-50 text-green-700 border border-green-200 flex items-center gap-2 text-sm">
                    <span class="material-symbols-outlined text-[20px]">check_circle</span>
                    @SuccessMessage
                </div>
            }

            <div class="flex flex-col gap-5">
                <!-- Title Field -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Assignment Title <span class="text-red-500">*</span></label>
                    <InputText @bind-Value="Model.Title" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400" placeholder="e.g., Midterm Physics Test" />
                    <ValidationMessage For="@(() => Model.Title)" class="text-red-500 text-xs mt-1" />
                </div>

                <!-- Description/Criteria Field -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Criteria &amp; Instructions</label>
                    <InputTextArea @bind-Value="Model.Description" rows="5" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400 resize-y" placeholder="Enter instructions, scoring criteria, and any other relevant details..." />
                    <ValidationMessage For="@(() => Model.Description)" class="text-red-500 text-xs mt-1" />
                </div>
            </div>
        </div>
        
        <!-- File Upload Section (replaces Questions) -->
        <div class="bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-3">Assignment File</h3>
            <p class="text-sm text-slate-500 mb-4">Upload the assignment document (PDF, DOCX, PPT, ZIP, images, etc.). Max 50 MB.</p>
            
            <label class="border-2 border-dashed rounded-lg p-8 flex flex-col items-center text-center cursor-pointer transition-all
                @(UploadedFile != null ? "border-primary/50 bg-primary/5" : "border-slate-300 hover:border-primary hover:bg-slate-50")">
                @if (IsUploading)
                {
                    <span class="material-symbols-outlined animate-spin text-primary text-4xl mb-2">progress_activity</span>
                    <p class="text-sm font-medium text-primary">Uploading...</p>
                }
                else if (UploadedFile != null)
                {
                    <span class="material-symbols-outlined text-primary text-4xl mb-2">task</span>
                    <p class="text-sm font-bold text-primary">@UploadedFile.Name</p>
                    <p class="text-xs text-slate-400 mt-1">@FormatFileSize(UploadedFile.Size) — Click to change</p>
                }
                else
                {
                    <span class="material-symbols-outlined text-slate-400 text-4xl mb-2">cloud_upload</span>
                    <p class="text-sm font-medium text-slate-700">Click to select a file</p>
                    <p class="text-xs text-slate-400 mt-1">PDF, DOCX, PPT, ZIP, images up to 50 MB</p>
                }
                <InputFile OnChange="OnFileSelected" class="hidden" />
            </label>

            @if (!string.IsNullOrEmpty(FileUploadError))
            {
                <p class="text-xs text-red-500 mt-2">@FileUploadError</p>
            }
            @if (!string.IsNullOrEmpty(Model.FileUrl))
            {
                <div class="mt-3 flex items-center gap-2 text-sm text-green-600">
                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                    File uploaded successfully!
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Settings (4/12) -->
    <div class="lg:col-span-4 flex flex-col gap-6">
        <div class="bg-white rounded-lg border border-slate-200 shadow-sm p-6 flex flex-col gap-5">
            <h3 class="text-lg font-bold text-slate-900 border-b border-slate-100 pb-3">Settings</h3>
            
            <!-- Class Selection -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Target Class <span class="text-red-500">*</span></label>
                <InputSelect @bind-Value="Model.ClassId" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all appearance-none bg-white">
                    <option value="0" disabled>Select a class...</option>
                    @foreach (var cls in TeacherClasses)
                    {
                        <option value="@cls.Id">@cls.Name (@cls.Subject)</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Model.ClassId)" class="text-red-500 text-xs mt-1" />
            </div>

            <!-- Set Deadline -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Due Date / Deadline</label>
                <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="Model.DueDate" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all text-slate-700" />
                <ValidationMessage For="@(() => Model.DueDate)" class="text-red-500 text-xs mt-1" />
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col gap-3">
            <button type="submit" disabled="@(IsSubmitting || IsUploading)" class="w-full flex items-center justify-center gap-2 bg-primary hover:bg-blue-600 text-white font-medium py-3 rounded-lg transition-all shadow-sm disabled:opacity-70 disabled:cursor-not-allowed">
                @if (IsSubmitting)
                {
                    <span class="material-symbols-outlined animate-spin">progress_activity</span>
                    <span>Creating...</span>
                }
                else
                {
                    <span class="material-symbols-outlined text-[20px]">publish</span>
                    <span>Create Assignment</span>
                }
            </button>
        </div>
    </div>
</EditForm>

<!-- Existing Assignments -->
<div class="mt-10">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">Your Assignments</h2>
        <span class="text-sm text-slate-500">@ExistingAssignments.Count assignment(s)</span>
    </div>

    @if (IsLoadingList)
    {
        <div class="flex items-center justify-center py-12">
            <span class="material-symbols-outlined animate-spin text-primary text-3xl">progress_activity</span>
        </div>
    }
    else if (ExistingAssignments.Count == 0)
    {
        <div class="bg-white border border-slate-200 rounded-lg p-8 text-center shadow-sm">
            <span class="material-symbols-outlined text-slate-300 text-5xl mb-3">assignment</span>
            <p class="text-slate-500">No assignments created yet. Use the form above to create your first one!</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var a in ExistingAssignments)
            {
                <a href="/teacher/assignments/@a.Id/edit" class="bg-white border border-slate-200 rounded-lg shadow-sm hover:shadow-md hover:border-primary/40 transition-all overflow-hidden cursor-pointer block">
                    <div class="p-5">
                        <div class="flex items-start justify-between mb-3">
                            <h4 class="font-bold text-slate-900 text-base leading-tight line-clamp-2">@a.Title</h4>
                            @{
                                var (statusBg, statusLabel) = a.Status switch
                                {
                                    AssignmentStatus.DRAFT => ("bg-slate-100 text-slate-600", "Draft"),
                                    AssignmentStatus.PUBLISHED => ("bg-green-100 text-green-700", "Published"),
                                    AssignmentStatus.CLOSED => ("bg-red-100 text-red-600", "Closed"),
                                    _ => ("bg-slate-100 text-slate-500", a.Status.ToString())
                                };
                            }
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider @statusBg shrink-0 ml-2">
                                @statusLabel
                            </span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(a.Description))
                        {
                            <p class="text-xs text-slate-500 mb-3 line-clamp-2">@a.Description</p>
                        }

                        <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">class</span>
                                @a.ClassName
                            </span>
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">upload_file</span>
                                @a.SubmissionCount submissions
                            </span>
                        </div>
                    </div>
                    <div class="border-t border-slate-100 px-5 py-3 bg-slate-50 flex items-center justify-between">
                        <div class="text-[11px] text-slate-400">
                            @if (a.DueDate.HasValue)
                            {
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">schedule</span>
                                    Due: @a.DueDate.Value.ToString("MMM dd, yyyy HH:mm")
                                </span>
                            }
                            else
                            {
                                <span>No deadline</span>
                            }
                        </div>
                        <span class="text-[11px] text-slate-400">@a.CreatedAt.ToString("MMM dd")</span>
                    </div>
                </a>
            }
        </div>
    }
</div>

@code {
    private CreateAssignmentDto Model { get; set; } = new()
    {
        DueDate = DateTime.Now.AddDays(7)
    };

    private bool IsSubmitting;
    private bool IsLoadingList = true;
    private bool IsUploading;
    private string? ErrorMessage;
    private string? SuccessMessage;
    private string? FileUploadError;
    private IBrowserFile? UploadedFile;
    private List<AssignmentListItemDto> ExistingAssignments = new();
    private List<TeacherClassListItemDto> TeacherClasses = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTeacherClasses();
        await LoadAssignments();
    }

    private async Task LoadTeacherClasses()
    {
        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 1;
            TeacherClasses = await ClassService.GetTeacherClassesAsync(teacherId);

            // Handle pre-selected class from URL
            var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
            if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("classId", out var cId))
            {
                if (long.TryParse(cId, out long id)) Model.ClassId = id;
            }
        }
        catch { }
    }

    private async Task LoadAssignments()
    {
        IsLoadingList = true;
        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 1;
            ExistingAssignments = await AssignmentService.GetAssignmentsByTeacherAsync(teacherId);
        }
        catch { }
        finally
        {
            IsLoadingList = false;
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        FileUploadError = null;
        Model.FileUrl = null;
        UploadedFile = e.File;

        if (UploadedFile.Size > 50 * 1024 * 1024)
        {
            FileUploadError = "File too large. Maximum 50 MB.";
            UploadedFile = null;
            return;
        }

        IsUploading = true;
        StateHasChanged();

        try
        {
            using var stream = UploadedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var url = await AssignmentService.UploadAssignmentFileAsync(
                stream, UploadedFile.Name, UploadedFile.ContentType);
            Model.FileUrl = url;
        }
        catch (Exception ex)
        {
            FileUploadError = "Upload failed: " + ex.Message;
            UploadedFile = null;
        }
        finally
        {
            IsUploading = false;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        if (Model.ClassId == 0)
        {
            ErrorMessage = "Please select a target class.";
            return;
        }

        IsSubmitting = true;

        try
        {
            long currentTeacherId = Session.UserId > 0 ? Session.UserId : 1;
            var response = await AssignmentService.CreateAssignmentAsync(currentTeacherId, Model);

            if (response.Success)
            {
                SuccessMessage = "Assignment created successfully!";
                Model = new CreateAssignmentDto { DueDate = DateTime.Now.AddDays(7) };
                UploadedFile = null;
                await LoadAssignments();
            }
            else
            {
                ErrorMessage = response.Message ?? "Failed to create assignment.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}
