@page "/teacher/dashboard"
@layout Layout.TeacherLayout
@using BusinessLogicLayer.Services.Interfaces.Dashboard
@using BusinessLogicLayer.DTOs.Teacher.Dashboard
@using LearnmateSolution.AppState
@inject ITeacherDashboardService DashboardService
@inject UserSessionService Session
@inject IJSRuntime JS
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Teacher Dashboard | LearnMate</PageTitle>

<!-- Page Heading -->
<div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-1">Chào buổi sáng, @(Session.Email?.Split('@')[0] ?? "Teacher")</h1>
    <p class="text-slate-500 font-normal">Đây là tổng quan hàng ngày và lịch dạy của bạn.</p>
</div>

<!-- Metrics Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <!-- Total Classes -->
    <div class="bg-white border border-slate-200 rounded-lg p-5 flex flex-col justify-between shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-slate-500">Lớp đang dạy</span>
            <span class="material-symbols-outlined text-slate-400 text-[20px]">class</span>
        </div>
        <p class="text-3xl font-bold text-slate-900 tracking-tight">@DashboardData?.ActiveClassesCount</p>
        <div class="mt-2 text-xs text-slate-400 flex items-center gap-1">
            <span class="text-green-500 font-medium">Hoạt động</span>
        </div>
    </div>
    <!-- Active Students -->
    <div class="bg-white border border-slate-200 rounded-lg p-5 flex flex-col justify-between shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-slate-500">Tổng học sinh</span>
            <span class="material-symbols-outlined text-slate-400 text-[20px]">groups</span>
        </div>
        <p class="text-3xl font-bold text-slate-900 tracking-tight">@DashboardData?.TotalStudentsCount</p>
        <div class="mt-2 text-xs text-slate-400 flex items-center gap-1">
            <span class="text-green-500 font-medium">Học sinh</span> đang tham gia
        </div>
    </div>
    <!-- Pending Assignments -->
    <div class="bg-white border border-slate-200 rounded-lg p-5 flex flex-col justify-between shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-slate-500">Bài tập chờ chấm</span>
            <span class="material-symbols-outlined text-slate-400 text-[20px]">assignment_turned_in</span>
        </div>
        <p class="text-3xl font-bold text-slate-900 tracking-tight">@DashboardData?.PendingAssignmentsCount</p>
        <div class="mt-2 text-xs text-slate-400">
             Cần đánh giá
        </div>
    </div>
    <!-- Monthly Earnings -->
    <div class="bg-white border border-slate-200 rounded-lg p-5 flex flex-col justify-between shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-slate-500">Thu nhập tạm tính</span>
            <span class="material-symbols-outlined text-slate-400 text-[20px]">payments</span>
        </div>
        <div class="flex items-baseline gap-2">
            <p class="text-3xl font-bold text-slate-900 tracking-tight">@DashboardData?.MonthlyEarnings.ToString("N0") <span class="text-sm font-medium">đ</span></p>
        </div>
        <div class="mt-2 text-xs text-slate-400">
            Tháng này
        </div>
    </div>
</div>

<!-- Main Split Layout -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    <!-- Left Column: Schedule (7/12) -->
    <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-6">
        <div class="flex items-center justify-between">
            <h3 class="text-xl font-bold text-slate-900">Today's Schedule</h3>
            <button class="text-sm font-medium text-primary hover:text-blue-600 transition-colors">View Calendar</button>
        </div>

        @if (CurrentSession != null)
        {
            <!-- Active Class Card -->
            <div class="bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden">
                <div class="p-6">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-md bg-green-100 text-green-700 text-[10px] font-bold uppercase tracking-wider mb-3">
                                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                                Đang diễn ra
                            </div>
                            <h4 class="text-2xl font-bold text-slate-900 mb-1">@CurrentSession.ClassName</h4>
                            <p class="text-slate-500 text-sm mb-4">@CurrentSession.StartTime.ToString("HH:mm") - @CurrentSession.EndTime.ToString("HH:mm") • @CurrentSession.Subject</p>
                            <div class="flex items-center gap-2 mb-6">
                                <div class="flex -space-x-2">
                                    @for(int i=1; i<=3; i++) {
                                        <div class="size-8 rounded-full border-2 border-white bg-slate-100 overflow-hidden">
                                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@(CurrentSession.ClassId + i)" alt="Student" />
                                        </div>
                                    }
                                </div>
                                <span class="text-xs text-slate-500 font-medium">Lớp học trực tuyến</span>
                            </div>
                        </div>
                        <div class="hidden sm:block w-32 h-32 rounded-lg bg-slate-100 bg-cover bg-center"
                             style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCZJ4w-amJ0LH885zpI4kfHJ0NHxpnMXtnDLUqFZKKA7p0kBKUcbRkES_T-850yW9SKI_inXYjuGifDLUkL0eu7lK5bFAc-ZUZxmcMle4EpnsSH0LhsXvjyr_y_tuGmXt4vCWp7h7UXy1sh4-ZJQB0Yw2TxcrwUbNdCYQe_jFckFS-Hi5McQ9H6Sb4BoDBL7ZUgCGRw226Y_zdgiIiWz-rsBPoi8tlzcrPNg1MLljDxmql-C0eofBwZYPhmBtOplk9zNG7P9dN1pns');">
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-3 mt-2">
                        @if (!string.IsNullOrEmpty(CurrentSession.MeetingLink))
                        {
                            <a href="@CurrentSession.MeetingLink" target="_blank" class="flex items-center justify-center gap-2 bg-primary hover:bg-blue-600 text-white font-medium px-5 py-2.5 rounded-lg transition-all shadow-sm no-underline">
                                <span class="material-symbols-outlined text-[20px]">videocam</span>
                                Tham gia dạy (Google Meet)
                            </a>
                        }
                        else
                        {
                            <button disabled title="Chưa cài đặt link" class="flex items-center justify-center gap-2 bg-slate-100 text-slate-400 font-medium px-5 py-2.5 rounded-lg transition-all cursor-not-allowed">
                                <span class="material-symbols-outlined text-[20px]">videocam_off</span>
                                Chưa cài đặt Meet Link
                            </button>
                        }
                        
                        <button class="flex items-center justify-center gap-2 bg-white border border-slate-200 text-slate-700 font-medium px-4 py-2.5 rounded-lg hover:bg-slate-50 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">content_copy</span>
                            Sao chép link
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Upcoming Classes -->
        <div class="flex flex-col gap-3">
            <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">Tiết dạy tiếp theo</p>
            @if (DashboardData?.UpcomingSessions.Any() == true)
            {
                @foreach (var item in DashboardData.UpcomingSessions)
                {
                    <div class="group flex items-center justify-between bg-white border border-slate-200 rounded-lg p-4 hover:border-primary/50 transition-colors cursor-pointer shadow-sm">
                        <div class="flex items-center gap-4">
                            <div class="flex flex-col items-center justify-center w-16 h-14 rounded-lg bg-slate-50 border border-slate-100 text-slate-600">
                                <span class="text-xs font-bold uppercase">@item.StartTime.ToString("HH:mm")</span>
                                <span class="text-[10px] opacity-60">@item.StartTime.ToString("dd/MM")</span>
                            </div>
                            <div>
                                <h5 class="font-bold text-slate-900 group-hover:text-primary transition-colors">@item.ClassName</h5>
                                <p class="text-xs text-slate-500">@item.Subject • @item.Type</p>
                                @if (!string.IsNullOrEmpty(item.MeetingLink))
                                {
                                    <a href="@item.MeetingLink" target="_blank" class="inline-flex items-center gap-1 text-[11px] font-bold text-primary mt-2 hover:underline no-underline">
                                        <span class="material-symbols-outlined text-[14px]">videocam</span>
                                        JOIN GOOGLE MEET
                                    </a>
                                }
                            </div>
                        </div>
                        <button class="text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="py-12 bg-slate-50 border border-dashed border-slate-200 rounded-lg flex flex-col items-center justify-center text-slate-400">
                    <span class="material-symbols-outlined text-4xl mb-2">calendar_today</span>
                    <p class="text-sm">Không có tiết dạy sắp tới</p>
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Quick Actions & Feeds (5/12) -->
    <div class="lg:col-span-5 xl:col-span-4 flex flex-col gap-8">
        <!-- Quick Actions -->
        <div>
            <h3 class="text-lg font-bold text-slate-900 mb-4">Quick Actions</h3>
            <div class="grid grid-cols-2 gap-3">
                <button class="flex flex-col items-center justify-center gap-2 p-4 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition-colors group">
                    <div class="p-2 rounded-full bg-blue-50 text-blue-600 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">add_circle</span>
                    </div>
                    <span class="text-sm font-medium text-slate-700">Create Class</span>
                </button>
                <a href="/teacher/assignments/create" class="flex flex-col items-center justify-center gap-2 p-4 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition-colors group">
                    <div class="p-2 rounded-full bg-purple-50 text-purple-600 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">assignment</span>
                    </div>
                    <span class="text-sm font-medium text-slate-700">Post Assignment</span>
                </a>
                <button class="flex flex-col items-center justify-center gap-2 p-4 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition-colors group">
                    <div class="p-2 rounded-full bg-orange-50 text-orange-600 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">person_add</span>
                    </div>
                    <span class="text-sm font-medium text-slate-700">Add Student</span>
                </button>
                <button class="flex flex-col items-center justify-center gap-2 p-4 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition-colors group">
                    <div class="p-2 rounded-full bg-teal-50 text-teal-600 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">bar_chart</span>
                    </div>
                    <span class="text-sm font-medium text-slate-700">View Reports</span>
                </button>
            </div>
        </div>

        <!-- Recent Activity Feed -->
        <div class="bg-white border border-slate-200 rounded-lg p-5 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-slate-900">Recent Activity</h3>
                <button class="text-xs font-semibold text-slate-500 hover:text-primary">View All</button>
            </div>
            <div class="flex flex-col gap-4">
                @foreach (var act in Activities)
                {
                    <div class="flex gap-3">
                        <div class="shrink-0 size-8 rounded-full border border-slate-200 overflow-hidden">
                            <img src="@act.Avatar" class="size-full object-cover" />
                        </div>
                        <div class="flex-1">
                            <p class="text-[13px] text-slate-800 leading-tight">
                                <span class="font-bold">@act.User</span> @act.Action <span class="text-primary font-medium">@act.Target</span>
                            </p>
                            <span class="text-xs text-slate-400 mt-1 block">@act.Time</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Calendar Component Placeholder -->
        <div class="bg-white border border-slate-200 rounded-lg p-5 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-[15px] font-bold text-slate-900">October 2023</h3>
                <div class="flex gap-1 text-slate-400">
                    <span class="material-symbols-outlined text-[18px] cursor-pointer">chevron_left</span>
                    <span class="material-symbols-outlined text-[18px] cursor-pointer">chevron_right</span>
                </div>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center text-[10px] text-slate-400 font-bold mb-2">
                <span>S</span><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center text-xs">
                @for(int i=29; i<=31; i++) { <span class="p-1.5 text-slate-200">@i</span> }
                @for(int i=1; i<=12; i++) {
                    if(i == 4) {
                        <span class="p-1.5 bg-primary text-white rounded-full font-bold">@i</span>
                    } else {
                        <span class="p-1.5 hover:bg-slate-50 rounded cursor-pointer relative">
                            @i
                            @if(i==6 || i==9) { <span class="absolute bottom-1 left-1/2 -translate-x-1/2 size-1 @(i==6?"bg-blue-400":"bg-purple-400") rounded-full"></span> }
                        </span>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private TeacherDashboardDataDto? DashboardData;
    private bool IsLoading = true;
    private UpcomingSessionDto? CurrentSession => DashboardData?.UpcomingSessions.FirstOrDefault(s => s.StartTime <= DateTime.Now.AddMinutes(5) && s.EndTime >= DateTime.Now);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load session if not already loaded (for SSR hydration)
            if (!Session.IsAuthenticated)
            {
                var email = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
                var role  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
                var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
                var avatar = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_avatar");
                var userIdStr = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_userid");
                
                if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(token) && long.TryParse(userIdStr, out var userId))
                {
                    Session.SetSession(email, role ?? "Teacher", token, avatar, userId);
                }
            }

            if (Session.UserId > 0)
            {
                DashboardData = await DashboardService.GetDashboardDataAsync(Session.UserId);
            }
            
            IsLoading = false;
            StateHasChanged();
        }
    }

    private List<ActivityItem> Activities = new()
    {
        new("Hệ thống", "thông báo", "Dashboard đã sẵn sàng", "Vừa xong", "https://api.dicebear.com/7.x/avataaars/svg?seed=LearnMate")
    };

    public record ActivityItem(string User, string Action, string Target, string Time, string Avatar);
}
