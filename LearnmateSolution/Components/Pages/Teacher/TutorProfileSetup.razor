@page "/tutor/profile-setup"
@layout Layout.LandingLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout
@using BusinessLogicLayer.DTOs.Auth
@using BusinessLogicLayer.Services.Interfaces
@using BusinessLogicLayer.DTOs.Teacher.Profile
@using BusinessLogicLayer.DTOs
@using BusinessObject.Enum
@inject ITeacherProfileService ProfileService
@inject ITeacherComplianceService ComplianceService
@inject IFileStorageService StorageService
@inject IAuthService AuthService
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject UserSessionService Session
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Tutor Onboarding | LearnMate</PageTitle>

<div class="min-h-screen bg-[#F8FAFC] text-slate-900 font-display">
    <!-- Premium Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
                <img src="images/logo.svg" alt="LearnMate" class="h-10 w-10" />
                <span class="text-xl font-extrabold tracking-tight text-slate-900">LearnMate</span>
            </div>
            
            <div class="flex items-center gap-6">
                <div class="hidden md:flex items-center gap-2 text-sm font-medium text-slate-500">
                    <span class="material-symbols-outlined text-green-500">lock</span>
                    Secure Portal
                </div>
                <button class="text-sm font-bold text-slate-600 hover:text-primary transition-all bg-transparent border-0" @onclick='() => Nav.NavigateTo("/teacher/dashboard")'>
                    Save Draft
                </button>
                <div class="h-10 w-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-400">
                    <span class="material-symbols-outlined">person</span>
                </div>
            </div>
        </div>
    </header>

    <div class="max-w-7xl mx-auto px-6 py-12">
        <!-- Wizard Header -->
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div>
                <h1 class="text-4xl font-black tracking-tight text-slate-900 mb-2">Tutor Onboarding</h1>
                <p class="text-lg text-slate-500">Tell us about yourself and your teaching expertise.</p>
            </div>
            
            <div class="flex flex-col gap-2 min-w-[300px]">
                <div class="flex justify-between text-xs font-bold uppercase tracking-widest text-primary">
                    <span>Step @(currentStep + 1) of 4: @StepName</span>
                    <span>@Progress% Complete</span>
                </div>
                <div class="h-2 w-full bg-slate-200 rounded-full overflow-hidden">
                    <div class="h-full bg-primary transition-all duration-500" style="width: @Progress%"></div>
                </div>
            </div>
        </div>

        <!-- Stepper Indicator -->
        <div class="flex items-center gap-4 mb-20 overflow-x-visible pb-12">
            <div class="flex items-center justify-between w-full relative">
                        <!-- Step 0: Account -->
                        <div class="flex flex-col items-center z-10">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 @(currentStep == 0 ? "bg-primary text-white scale-110 shadow-lg" : currentStep > 0 ? "bg-green-500 text-white" : "bg-slate-200 text-slate-500")">
                                @if (currentStep > 0) { <span class="material-symbols-outlined text-sm">check</span> }
                                else { <span class="text-xs font-bold">1</span> }
                            </div>
                            <span class="absolute -bottom-6 text-[10px] font-bold uppercase tracking-wider @(currentStep == 0 ? "text-primary" : "text-slate-400")">Account</span>
                        </div>

                        <!-- Step 1: Info -->
                        <div class="flex flex-col items-center z-10">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 @(currentStep == 1 ? "bg-primary text-white scale-110 shadow-lg" : currentStep > 1 ? "bg-green-500 text-white" : "bg-slate-200 text-slate-500")">
                                @if (currentStep > 1) { <span class="material-symbols-outlined text-sm">check</span> }
                                else { <span class="text-xs font-bold">2</span> }
                            </div>
                            <span class="absolute -bottom-6 text-[10px] font-bold uppercase tracking-wider @(currentStep == 1 ? "text-primary" : "text-slate-400")">Basics</span>
                        </div>

                        <!-- Step 2: Verification -->
                        <div class="flex flex-col items-center z-10">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 @(currentStep == 2 ? "bg-primary text-white scale-110 shadow-lg" : currentStep > 2 ? "bg-green-500 text-white" : "bg-slate-200 text-slate-500")">
                                @if (currentStep > 2) { <span class="material-symbols-outlined text-sm">check</span> }
                                else { <span class="text-xs font-bold">3</span> }
                            </div>
                            <span class="absolute -bottom-6 text-[10px] font-bold uppercase tracking-wider @(currentStep == 2 ? "text-primary" : "text-slate-400")">Verify</span>
                        </div>

                        <!-- Step 3: Review -->
                        <div class="flex flex-col items-center z-10">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 @(currentStep == 3 ? "bg-primary text-white scale-110 shadow-lg" : "bg-slate-200 text-slate-500")">
                                <span class="text-xs font-bold">4</span>
                            </div>
                            <span class="absolute -bottom-6 text-[10px] font-bold uppercase tracking-wider @(currentStep == 3 ? "text-primary" : "text-slate-400")">Final</span>
                        </div>

                        <!-- Progress Line -->
                        <div class="absolute top-5 left-0 h-0.5 bg-slate-100 w-full -z-0"></div>
                        <div class="absolute top-5 left-0 h-0.5 bg-primary transition-all duration-500 -z-0" style="width: @(currentStep * 33.33)%"></div>
                    </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
            <!-- Form Area -->
            <div class="lg:col-span-8 space-y-8">
                @if (isLoading && currentStep > 0)
                {
                    <div class="bg-white rounded-3xl p-24 border border-slate-200 shadow-sm flex flex-col items-center justify-center">
                        <div class="size-16 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
                        <p class="mt-6 text-slate-500 font-medium">Preparing your application...</p>
                    </div>
                }
                else
                {
                    <EditForm Model="profile" class="space-y-8">
                        <DataAnnotationsValidator />
                        
                        @if (currentStep == 0)
                {
                    <div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                        <div>
                            <h3 class="text-2xl font-black text-slate-900 mb-2">Create your account</h3>
                            <p class="text-slate-500 text-sm">Start your teaching journey today with LearnMate.</p>
                        </div>

                        <div class="space-y-4">
                            <div>
                                <label class="text-xs font-bold uppercase text-slate-500 tracking-wider mb-2 block">Full Name</label>
                                <input @bind="fullName" type="text" placeholder="John Doe" class="w-full rounded-xl border border-slate-200 bg-slate-50/50 p-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none" />
                            </div>

                            <div>
                                <label class="text-xs font-bold uppercase text-slate-500 tracking-wider mb-2 block">Email Address</label>
                                <input @bind="email" type="email" placeholder="john@example.com" class="w-full rounded-xl border border-slate-200 bg-slate-50/50 p-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none" />
                            </div>

                            <div>
                                <label class="text-xs font-bold uppercase text-slate-500 tracking-wider mb-2 block">Password</label>
                                <input @bind="password" type="password" placeholder="••••••••" class="w-full rounded-xl border border-slate-200 bg-slate-50/50 p-4 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none" />
                            </div>
                        </div>

                        @if (!showOtpSection)
                        {
                            <button @onclick="RegisterAccount" disabled="@(isLoading || string.IsNullOrEmpty(email) || string.IsNullOrEmpty(password) || string.IsNullOrEmpty(fullName))" class="w-full bg-primary text-white rounded-xl py-4 font-bold text-sm shadow-xl shadow-primary/20 hover:scale-[1.02] transition-all disabled:opacity-50 disabled:hover:scale-100 flex items-center justify-center gap-2">
                                @if (isLoading)
                                {
                                    <div class="size-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                                    <span>Creating Account...</span>
                                }
                                else
                                {
                                    <span>Create Account & Continue</span>
                                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                }
                            </button>
                        }
                        else
                        {
                            <!-- OTP Section -->
                            <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100 space-y-4">
                                <div class="flex items-center gap-3 text-primary">
                                    <span class="material-symbols-outlined">mark_email_unread</span>
                                    <p class="text-sm font-bold">Please verify your email</p>
                                </div>
                                <p class="text-xs text-blue-600/80">We've sent a 6-digit code to <b>@email</b></p>
                                
                                <div class="flex gap-2 justify-between">
                                    @for (int i = 0; i < 6; i++)
                                    {
                                        var idx = i;
                                        <input type="text" maxlength="1" @oninput="(e) => OnOtpInput(e, idx)" class="size-10 rounded-lg border border-blue-200 text-center font-bold text-lg focus:ring-2 focus:ring-primary outline-none" />
                                    }
                                </div>

                                <button @onclick="VerifyOtp" disabled="@(isLoading || otpCode.Length < 6)" class="w-full bg-primary text-white rounded-xl py-3 font-bold text-sm shadow-lg shadow-primary/20 hover:scale-[1.02] transition-all flex items-center justify-center gap-2">
                                     @if (isLoading)
                                    {
                                        <div class="size-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                                        <span>Verifying...</span>
                                    }
                                    else
                                    {
                                        <span>Verify OTP</span>
                                    }
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (currentStep == 1)
                        {
                            <!-- Step 1: Basic Info -->
                            <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm space-y-10 animate-fade-in">
                                <section class="space-y-6">
                                    <h3 class="text-2xl font-bold text-slate-900 flex items-center gap-3">
                                        Personal Details
                                    </h3>
                                    
                                    <div class="flex flex-col sm:flex-row gap-8 items-start">
                                        <div class="relative group">
                                            <div class="size-32 rounded-3xl bg-slate-50 border-2 border-dashed border-slate-200 flex flex-col items-center justify-center cursor-pointer hover:border-primary hover:bg-primary/5 transition-all overflow-hidden" @onclick='() => TriggerFileUpload("Avatar")'>
                                                @if (!string.IsNullOrEmpty(profile.AvatarUrl))
                                                {
                                                    <img src="@profile.AvatarUrl" class="size-full object-cover" />
                                                }
                                                else
                                                {
                                                    <span class="material-symbols-outlined text-4xl text-slate-300">add_a_photo</span>
                                                    <span class="text-[10px] font-bold uppercase text-slate-400 mt-2">Upload</span>
                                                }
                                            </div>
                                            <button type="button" @onclick='() => TriggerFileUpload("Avatar")' class="absolute -bottom-2 -right-2 size-8 bg-primary text-white rounded-full flex items-center justify-center shadow-lg border-2 border-white hover:scale-110 transition-all">
                                                <span class="material-symbols-outlined text-sm">edit</span>
                                            </button>
                                        </div>
                                        
                                        <div class="flex-1 space-y-6 w-full">
                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                                <div class="space-y-2">
                                                    <label class="text-sm font-bold text-slate-700">Full Name</label>
                                                    <input @bind="profile.FullName" @bind:event="oninput" type="text" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all" placeholder="e.g. Alexander Pierce" />
                                                </div>
                                                <div class="space-y-2">
                                                    <label class="text-sm font-bold text-slate-700">Languages Spoken</label>
                                                    <input @bind="profile.LanguagesSpoken" @bind:event="oninput" type="text" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all" placeholder="English, Spanish, French..." />
                                                </div>
                                            </div>
                                            
                                            <div class="space-y-2">
                                                <label class="text-sm font-bold text-slate-700">Professional Bio</label>
                                                <textarea @bind="profile.Bio" @bind:event="oninput" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all h-32" placeholder="Briefly introduce yourself to potential students..."></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </section>

                                <section class="space-y-6 pt-10 border-t border-slate-100">
                                    <h3 class="text-2xl font-bold text-slate-900">Teaching Expertise</h3>
                                    
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                        <div class="space-y-2">
                                            <label class="text-sm font-bold text-slate-700">Subjects of Expertise</label>
                                            <div class="flex flex-wrap gap-2 mb-2">
                                                @foreach(var subject in (profile.Subjects ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                                {
                                                    <span class="px-3 py-1 bg-primary/10 text-primary rounded-lg text-xs font-bold flex items-center gap-1">
                                                        @subject.Trim()
                                                        <span class="material-symbols-outlined text-sm cursor-pointer">close</span>
                                                    </span>
                                                }
                                            </div>
                                            <InputText @bind-Value="profile.Subjects" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all" placeholder="Add subject..." />
                                        </div>
                                        
                                        <div class="grid grid-cols-2 gap-4">
                                            <div class="space-y-2">
                                                <label class="text-sm font-bold text-slate-700">Years of Experience</label>
                                                <input @bind="profile.YearsOfExperience" @bind:event="oninput" type="number" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all" />
                                            </div>
                                            <div class="space-y-2">
                                                <label class="text-sm font-bold text-slate-700">Hourly Rate ($)</label>
                                                <input @bind="profile.HourlyRate" @bind:event="oninput" type="number" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all" />
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="space-y-2">
                                        <label class="text-sm font-bold text-slate-700">Teaching Philosophy</label>
                                        <textarea @bind="profile.TeachingPhilosophy" @bind:event="oninput" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all h-32" placeholder="Describe your approach to teaching..."></textarea>
                                    </div>
                                </section>
                            </div>
                        }
                        else if (currentStep == 2)
                        {
                            <!-- Step 2: Verification -->
                            <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm space-y-10 animate-fade-in">
                                <div class="text-center space-y-2 mb-8">
                                    <h3 class="text-2xl font-bold text-slate-900">Complete Your Profile</h3>
                                    <p class="text-slate-500">Provide your professional credentials to unlock your teaching badge.</p>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <!-- CV/Degree -->
                                    <div class="p-6 rounded-2xl border border-slate-200 bg-slate-50 space-y-4">
                                        <div class="flex items-center gap-3">
                                            <div class="size-10 bg-primary/10 text-primary rounded-xl flex items-center justify-center">
                                                <span class="material-symbols-outlined">school</span>
                                            </div>
                                            <h4 class="font-bold text-slate-900">Degree & CV</h4>
                                        </div>
                                        <div class="border-2 border-dashed border-slate-300 rounded-xl p-8 flex flex-col items-center justify-center text-center cursor-pointer hover:border-primary hover:bg-white transition-all group" @onclick='() => TriggerFileUpload("CV")'>
                                            <span class="material-symbols-outlined text-slate-300 group-hover:text-primary mb-2">cloud_upload</span>
                                            <span class="text-sm font-bold text-slate-600">Click to upload CV</span>
                                            <span class="text-[10px] text-slate-400 mt-1 uppercase">PDF, DOCX (Max 5MB)</span>
                                            @if (uploadedFiles.Any(f => f.Category == "CV"))
                                            {
                                                <div class="mt-4 flex items-center gap-2 px-3 py-1 bg-green-100 text-green-700 rounded-lg text-[10px] font-bold">
                                                    <span class="material-symbols-outlined text-xs">check_circle</span> 
                                                    @uploadedFiles.Count(f => f.Category == "CV") File(s)
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Certificates -->
                                    <div class="p-6 rounded-2xl border border-slate-200 bg-slate-50 space-y-4">
                                        <div class="flex items-center gap-3">
                                            <div class="size-10 bg-primary/10 text-primary rounded-xl flex items-center justify-center">
                                                <span class="material-symbols-outlined">verified</span>
                                            </div>
                                            <h4 class="font-bold text-slate-900">Certificates</h4>
                                        </div>
                                        <div class="border-2 border-dashed border-slate-300 rounded-xl p-8 flex flex-col items-center justify-center text-center cursor-pointer hover:border-primary hover:bg-white transition-all group" @onclick='() => TriggerFileUpload("Certificate")'>
                                            <span class="material-symbols-outlined text-slate-300 group-hover:text-primary mb-2">add_circle</span>
                                            <span class="text-sm font-bold text-slate-600">Add Certificate</span>
                                            <span class="text-[10px] text-slate-400 mt-1 uppercase">JPG, PNG, PDF</span>
                                            @if (uploadedFiles.Any(f => f.Category == "Certificate"))
                                            {
                                                <div class="mt-4 flex items-center gap-2 px-3 py-1 bg-green-100 text-green-700 rounded-lg text-[10px] font-bold">
                                                    <span class="material-symbols-outlined text-xs">check_circle</span> 
                                                    @uploadedFiles.Count(f => f.Category == "Certificate") File(s)
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Identity -->
                                    <div class="md:col-span-2 p-6 rounded-2xl border border-slate-200 bg-slate-50 flex flex-col md:flex-row items-center justify-between gap-6">
                                        <div class="flex items-center gap-4">
                                            <div class="size-12 bg-green-100 text-green-600 rounded-2xl flex items-center justify-center">
                                                <span class="material-symbols-outlined">badge</span>
                                            </div>
                                            <div>
                                                <h4 class="font-bold text-slate-900">Identity Verification</h4>
                                                <p class="text-xs text-slate-500">Government ID (Passport / ID Card)</p>
                                            </div>
                                        </div>
                                        <button type="button" class="px-6 py-2.5 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 hover:bg-slate-50 transition-all flex items-center gap-2" @onclick='() => TriggerFileUpload("Identity")'>
                                            <span class="material-symbols-outlined text-lg">upload_file</span>
                                            @(uploadedFiles.Any(f => f.Category == "Identity") ? "Update ID" : "Upload Passport/ID")
                                        </button>
                                    </div>
                                </div>



                                <div class="p-6 bg-blue-50 border border-blue-100 rounded-2xl flex items-start gap-4">
                                    <span class="material-symbols-outlined text-primary">info</span>
                                    <p class="text-sm text-blue-700 font-medium">LearnMate prioritizes security. All documents are encrypted. Reviews are completed within 24-48 hours.</p>
                                </div>
                            </div>
                        }
                        else if (currentStep == 3)
                        {
                            <!-- Step 3: Review -->
                            <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm space-y-8 animate-fade-in text-center py-16">
                                <div class="size-20 bg-primary/10 text-primary rounded-full flex items-center justify-center mx-auto mb-6">
                                    <span class="material-symbols-outlined text-4xl">task_alt</span>
                                </div>
                                <h3 class="text-3xl font-black text-slate-900">Ready to Join?</h3>
                                <p class="text-lg text-slate-500 max-w-md mx-auto">Please review your information on the right. Once submitted, your profile will be reviewed by our compliance team.</p>
                                
                                <div class="max-w-md mx-auto p-4 bg-slate-50 rounded-2xl border border-slate-200 text-left space-y-3">
                                    <div class="flex justify-between text-sm">
                                        <span class="text-slate-500 font-medium">Full Name</span>
                                        <span class="text-slate-900 font-bold">@profile.FullName</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-slate-500 font-medium">Hourly Rate</span>
                                        <span class="text-slate-900 font-bold">$@profile.HourlyRate/hr</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-slate-500 font-medium">Documents Uploaded</span>
                                        <span class="text-slate-900 font-bold">@uploadedFiles.Count</span>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Actions -->
                        <div class="flex justify-between mt-auto pt-8">
                    @if (currentStep > 0)
                    {
                        <button type="button" @onclick="PrevStep" class="flex items-center gap-2 px-6 py-3 rounded-xl border-2 border-slate-100 text-slate-500 font-bold text-sm hover:bg-slate-50 transition-all">
                            <span class="material-symbols-outlined text-sm">arrow_back</span> Back
                        </button>
                    }
                    <div></div>

                    @if (currentStep < 3 && currentStep > 0)
                    {
                        <button type="button" @onclick="NextStep" class="flex items-center gap-2 px-8 py-3 rounded-xl bg-primary text-white font-bold text-sm shadow-xl shadow-primary/20 hover:scale-[1.05] transition-all">
                            Next Step <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </button>
                    }
                    @if (currentStep == 3)
                    {
                        <button @onclick="SubmitApplication" disabled="@isSubmitting" class="flex items-center gap-2 px-8 py-3 rounded-xl bg-green-500 text-white font-bold text-sm shadow-xl shadow-green-500/20 hover:scale-[1.05] transition-all disabled:opacity-50 disabled:hover:scale-100">
                             @if (isSubmitting)
                            {
                                <div class="size-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                                <span>Submitting...</span>
                            }
                            else
                            {
                                <span>Submit Application</span>
                                <span class="material-symbols-outlined text-sm">send</span>
                            }
                        </button>
                    }
                </div>
                    </EditForm>
                    <InputFile OnChange="OnInputFileChange" multiple id="fileUpload" class="hidden" />
                }
            </div>

            <!-- Preview Sidebar -->
            <div class="lg:col-span-4 space-y-6 lg:sticky lg:top-32">
                <div class="bg-white rounded-3xl overflow-hidden border border-slate-200 shadow-xl">
                    <div class="h-32 bg-gradient-to-br from-primary to-blue-600 relative">
                        <div class="absolute -right-4 -top-4 size-32 bg-white/10 rounded-full blur-2xl"></div>
                        <div class="absolute left-6 -bottom-8">
                            <div class="size-24 rounded-3xl bg-white p-1 shadow-lg ring-4 ring-white/50">
                                <img src="@(string.IsNullOrEmpty(profile.AvatarUrl) ? "https://api.dicebear.com/7.x/avataaars/svg?seed="+profile.FullName : profile.AvatarUrl)" class="size-full object-cover rounded-2xl" />
                            </div>
                        </div>
                        <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-black uppercase text-white tracking-widest">
                            Preview Card
                        </div>
                    </div>
                    
                    <div class="pt-12 p-8 space-y-6">
                        <div>
                            <h4 class="text-2xl font-black text-slate-900 mb-1">@(string.IsNullOrEmpty(profile.FullName) ? "Your Name" : profile.FullName)</h4>
                            <div class="flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-wider">
                                <span class="material-symbols-outlined text-sm">star</span>
                                NEW TUTOR
                            </div>
                        </div>
                        
                        <div class="flex flex-wrap gap-2">
                            @foreach(var subject in (profile.Subjects ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="px-2 py-1 bg-slate-100 rounded-lg text-[10px] font-bold text-slate-600 uppercase tracking-tighter">@subject.Trim()</span>
                            }
                            @if(string.IsNullOrEmpty(profile.Subjects)) { <span class="text-slate-300 text-xs italic">No subjects added</span> }
                        </div>
                        
                        <p class="text-sm text-slate-500 leading-relaxed italic">
                            @(string.IsNullOrEmpty(profile.Bio) ? "\"Your professional bio will appear here. Introduce yourself to students and highlight your teaching style...\"" : $"\"{profile.Bio}\"")
                        </p>
                        
                        <div class="grid grid-cols-2 gap-4 border-t border-slate-100 pt-6">
                            <div>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Hourly Rate</p>
                                <p class="text-lg font-black text-slate-900">@(profile.HourlyRate > 0 ? $"${profile.HourlyRate}" : "$ --")</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Experience</p>
                                <p class="text-lg font-black text-slate-900">@(profile.YearsOfExperience.HasValue ? $"{profile.YearsOfExperience} Years" : "-- Years")</p>
                            </div>
                        </div>
                        
                        <button disabled class="w-full py-3 bg-primary/10 text-primary rounded-xl text-sm font-bold opacity-50">View Full Profile</button>
                    </div>
                </div>
                
                <div class="bg-blue-50/50 rounded-3xl p-6 border border-blue-100 space-y-4">
                    <div class="flex items-center gap-3 text-primary">
                        <span class="material-symbols-outlined">help</span>
                        <h4 class="font-bold">Why complete this?</h4>
                    </div>
                    <p class="text-sm text-blue-900/70 font-medium">Detailed profiles receive **4x more booking requests**. Your teaching philosophy helps students find the right match.</p>
                </div>
                
                @if (currentStep >= 2)
                {
                    <div class="bg-green-50/50 rounded-3xl p-6 border border-green-100 space-y-3 animate-fade-in">
                        <div class="flex items-center gap-2 text-green-600">
                             <span class="material-symbols-outlined">verified</span>
                             <h4 class="font-bold">Verified Badge</h4>
                        </div>
                        <p class="text-xs text-green-800/60 font-medium">Building trust is **70% faster** with a verified profile badge.</p>
                        <div class="bg-white/50 rounded-xl p-3 space-y-2">
                             @foreach(var cat in new[] {"CV", "Certificate", "Identity"})
                             {
                                 <div class="flex justify-between items-center text-[10px] font-bold">
                                     <span class="text-slate-500 uppercase">@cat</span>
                                     @if(uploadedFiles.Any(f => f.Category == cat)) { <span class="text-green-600 flex items-center gap-1">DONE <span class="material-symbols-outlined text-[10px]">check_circle</span></span> }
                                     else { <span class="text-slate-300">PENDING</span> }
                                 </div>
                             }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <footer class="bg-white border-t border-slate-200 py-12">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-8">
                <div class="flex items-center gap-2">
                    <img src="images/logo.svg" alt="LearnMate" class="h-6 w-6 grayscale opacity-50" />
                    <span class="text-xs font-bold text-slate-400">© 2024 LearnMate Inc. All rights reserved.</span>
                </div>
                <div class="flex gap-8">
                    <a href="#" class="text-xs font-bold text-slate-400 hover:text-slate-600" style="text-decoration:none;">Help Center</a>
                    <a href="#" class="text-xs font-bold text-slate-400 hover:text-slate-600" style="text-decoration:none;">Privacy Policy</a>
                    <a href="#" class="text-xs font-bold text-slate-400 hover:text-slate-600" style="text-decoration:none;">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    
    :root {
        --primary: #137fec;
    }
    
    .font-display {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    
    .bg-primary { background-color: var(--primary); }
    .text-primary { color: var(--primary); }
    .border-primary { border-color: var(--primary); }
    .ring-primary { --tw-ring-color: var(--primary); }
</style>

@code {
    private int currentStep = 0;
    private bool isLoading;
    private UpdateTeacherProfileDto profile = new();
    private bool isSubmitting = false;
    private List<TeacherDocumentRequestDto> uploadedFiles = new();
    private string currentUploadCategory = "";
    
    // Auth related fields for Step 0
    private string email = "";
    private string password = "";
    private string fullName = "";
    private bool showOtpSection = false;
    private string otpCode = "";
    private string[] otpDigits = new string[6];

    private string StepName => currentStep switch { 0 => "Account Setup", 1 => "Basic Info", 2 => "Verification", 3 => "Review", _ => "" };
    private int Progress => currentStep switch { 0 => 0, 1 => 25, 2 => 50, 3 => 75, _ => 0 };

    private void OnOtpInput(ChangeEventArgs e, int index)
    {
        var val = e.Value?.ToString() ?? "";
        if (!string.IsNullOrEmpty(val))
        {
            otpDigits[index] = val.Substring(val.Length - 1);
            otpCode = string.Concat(otpDigits);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        
        try 
        {
            if (!Session.IsAuthenticated)
            {
                var sEmail = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
                var sRole  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
                var sToken = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
                var sId = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_userid");
                var sName = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_fullname");
                
                if (!string.IsNullOrEmpty(sEmail) && !string.IsNullOrEmpty(sRole) && !string.IsNullOrEmpty(sToken))
                {
                    long.TryParse(sId, out var uid);
                    Session.SetSession(sEmail, sRole, sToken, null, uid, sName);
                }
            }

            if (Session.IsAuthenticated)
            {
                currentStep = 1;
                await LoadProfile();
            }
            else
            {
                currentStep = 0;
                isLoading = false;
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in OnAfterRenderAsync: {ex.Message}");
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RegisterAccount()
    {
        if (isLoading) return;
        isLoading = true;
        try
        {
            var result = await AuthService.RegisterAsync(new RegisterRequest(email, password, "TEACHER", fullName, null));
            if (result.Success)
            {
                showOtpSection = true;
                ToastService.ShowSuccess("Account created! Please check your email for the verification code.");
            }
            else
            {
                ToastService.ShowError(result.Message);
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Registration failed: " + ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task VerifyOtp()
    {
        if (isLoading) return;
        isLoading = true;
        try
        {
            var result = await AuthService.VerifyOtpAsync(new VerifyOtpRequest(email, otpCode));
            if (result.Success)
            {
                // Auto login
                var loginResult = await AuthService.LoginAsync(new LoginRequest(email, password));
                if (loginResult.Success)
                {
                    var data = loginResult.Data!;
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "lm_email", data.Email);
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "lm_role",  data.Role);
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "lm_token", data.AccessToken);
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "lm_userid", data.UserId.ToString());
                    await JS.InvokeVoidAsync("sessionStorage.setItem", "lm_fullname", data.FullName ?? "");
                    
                    Session.SetSession(data.Email, data.Role, data.AccessToken, data.AvatarUrl, data.UserId, data.FullName);
                    
                    currentStep = 1;
                    await LoadProfile();
                }
            }
            else
            {
                ToastService.ShowError(result.Message);
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Verification failed: " + ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadProfile()
    {
        try
        {
            isLoading = true;
            StateHasChanged();
            var userProfile = await ProfileService.GetProfileAsync(Session.UserId);
            if (userProfile != null)
            {
                profile = new UpdateTeacherProfileDto
                {
                    FullName = userProfile.FullName,
                    Bio = userProfile.Bio,
                    Subjects = userProfile.Subjects,
                    HourlyRate = userProfile.HourlyRate,
                    LanguagesSpoken = userProfile.LanguagesSpoken,
                    YearsOfExperience = userProfile.YearsOfExperience,
                    TeachingPhilosophy = userProfile.TeachingPhilosophy,
                    BankAccount = userProfile.BankAccount,
                    AvatarUrl = userProfile.AvatarUrl
                };
            }
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void NextStep() { if (currentStep < 3) currentStep++; }
    private void PrevStep() { if (currentStep > 0) currentStep--; }

    private async Task TriggerFileUpload(string category)
    {
        currentUploadCategory = category;
        await JS.InvokeVoidAsync("eval", "document.getElementById('fileUpload').click()");
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            foreach (var file in e.GetMultipleFiles(5))
            {
                var fileName = $"{Guid.NewGuid()}_{file.Name}";
                var objectPath = $"compliance/{fileName}";
                
                using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                
                if (currentUploadCategory == "Avatar")
                {
                    var avatarUrl = await StorageService.UploadImageAsync("avatars", Guid.NewGuid().ToString(), stream, file.ContentType);
                    profile.AvatarUrl = avatarUrl;
                    StateHasChanged();
                    continue;
                }

                await StorageService.UploadAsync(objectPath, stream, file.ContentType);
                var url = await StorageService.GetUrlAsync(objectPath);
                
                uploadedFiles.Add(new TeacherDocumentRequestDto
                {
                    Name = file.Name,
                    FileUrl = url,
                    FileType = file.ContentType,
                    Category = currentUploadCategory,
                    FileSize = file.Size
                });
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Upload failed: {ex.Message}");
        }
    }

    private async Task SubmitApplication()
    {
        if (isSubmitting) return;
        if (uploadedFiles.Count == 0)
        {
            ToastService.ShowWarning("Please upload at least one document for verification.");
            return;
        }

        isSubmitting = true;
        try
        {
            var profileResult = await ProfileService.UpdateProfileAsync(Session.UserId, profile);
            if (!profileResult.Success)
            {
                ToastService.ShowError($"Profile update failed: {profileResult.Message}");
                return;
            }

            var result = await ComplianceService.SubmitApplicationAsync(Session.UserId, uploadedFiles);
            
            if (result.Success)
            {
                ToastService.ShowSuccess("Application submitted successfully! Our team will review it within 24-48 hours.");
                Nav.NavigateTo("/teacher/dashboard");
            }
            else
            {
                ToastService.ShowError($"Submission failed: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Submission failed: {ex.Message}");
        }
        finally { isSubmitting = false; }
    }
}
