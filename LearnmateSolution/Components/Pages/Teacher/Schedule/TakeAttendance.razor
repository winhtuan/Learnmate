@page "/teacher/schedule/{ScheduleId:long}/attendance"
@rendermode InteractiveServer
@layout Layout.TeacherLayout

@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Teacher.Schedules
@using BusinessLogicLayer.Services.Interfaces.Teacher.Schedules
@inject ITeacherScheduleService ScheduleService
@inject NavigationManager NavigationManager

<PageTitle>Take Attendance | LearnMate</PageTitle>

@if (IsLoading)
{
    <div class="flex items-center justify-center py-20">
        <span class="material-symbols-outlined animate-spin text-primary text-4xl">progress_activity</span>
    </div>
}
else if (Schedule == null)
{
    <div class="bg-white border border-slate-200 rounded-lg p-12 text-center shadow-sm">
        <h2 class="text-xl font-bold text-slate-900 mb-2">Schedule Not Found</h2>
        <button type="button" @onclick='() => NavigationManager.NavigateTo("/teacher/schedule")' class="bg-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-600 transition-colors">
            Back to Schedules
        </button>
    </div>
}
else
{
    <div class="mb-8 flex items-center justify-between">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <button type="button" @onclick='() => NavigationManager.NavigateTo($"/teacher/schedule/class/{Schedule.ClassId}")' class="text-slate-400 hover:text-slate-800 transition-colors p-1" title="Back">
                    <span class="material-symbols-outlined">arrow_back</span>
                </button>
                <h1 class="text-3xl font-bold tracking-tight text-slate-900">Attendance: @Schedule.Title</h1>
            </div>
            <p class="text-slate-500 font-normal ml-11">@Schedule.StartTime.ToString("MMM dd, yyyy") | @Schedule.StartTime.ToString("HH:mm") - @Schedule.EndTime.ToString("HH:mm")</p>
        </div>
        <button type="button" @onclick="Save" disabled="@IsSaving" class="flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-6 py-2.5 rounded-lg font-medium transition-all shadow-sm disabled:opacity-70 group">
            @if (IsSaving)
            {
                <span class="material-symbols-outlined animate-spin text-[20px]">progress_activity</span>
                <span>Saving...</span>
            }
            else
            {
                <span class="material-symbols-outlined text-[20px] group-hover:scale-110 transition-transform">save</span>
                <span>Save Attendance</span>
            }
        </button>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="mb-6 p-4 rounded-lg bg-red-50 text-red-600 border border-red-200 flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined">error</span>
            @ErrorMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="mb-6 p-4 rounded-lg bg-green-50 text-green-700 border border-green-200 flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined text-[20px]">check_circle</span>
            @SuccessMessage
        </div>
    }

    <div class="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden mb-6">
        <div class="px-6 py-4 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
            <div class="flex items-center gap-6 text-sm font-medium">
                <span class="text-slate-600">Total Students: <strong class="text-slate-900">@Attendances.Count</strong></span>
                <span class="text-green-600">Present: <strong class="text-green-700">@Attendances.Count(a => a.IsPresent)</strong></span>
                <span class="text-red-500">Absent: <strong class="text-red-600">@Attendances.Count(a => !a.IsPresent)</strong></span>
            </div>
            <div class="flex items-center gap-3">
                <button type="button" @onclick="MarkAllPresent" class="text-xs font-semibold text-primary hover:text-blue-700 underline underline-offset-2">Mark All Present</button>
                <div class="w-px h-4 bg-slate-300"></div>
                <button type="button" @onclick="MarkAllAbsent" class="text-xs font-semibold text-red-500 hover:text-red-700 underline underline-offset-2">Mark All Absent</button>
            </div>
        </div>

        <table class="w-full text-left">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500 font-semibold">
                    <th class="p-4 px-6 w-1/3">Student</th>
                    <th class="p-4 text-center w-48">Status</th>
                    <th class="p-4 px-6">Notes (Optional)</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-sm">
                @foreach (var a in Attendances)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 px-6">
                            <p class="font-bold text-slate-900 mb-0.5">@a.StudentName</p>
                            <p class="text-xs text-slate-500">@a.StudentEmail</p>
                        </td>
                        <td class="p-4">
                            <div class="flex items-center justify-center p-1 bg-white border border-slate-200 rounded-lg shadow-sm w-40 mx-auto">
                                <button type="button" 
                                        @onclick="() => a.IsPresent = true" 
                                        class="flex-1 py-1.5 rounded-md text-xs font-bold transition-all @(a.IsPresent ? "bg-green-100 text-green-700 shadow-sm" : "text-slate-400 hover:bg-slate-50")">
                                    Present
                                </button>
                                <button type="button" 
                                        @onclick="() => a.IsPresent = false" 
                                        class="flex-1 py-1.5 rounded-md text-xs font-bold transition-all @(!a.IsPresent ? "bg-red-100 text-red-700 shadow-sm" : "text-slate-400 hover:bg-slate-50")">
                                    Absent
                                </button>
                            </div>
                        </td>
                        <td class="p-4 px-6">
                            <input type="text" @bind="a.Notes" class="w-full px-3 py-2 bg-transparent border border-slate-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all text-sm placeholder:text-slate-300" placeholder="Reason for absence, behavior notes..." />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public long ScheduleId { get; set; }

    private long TeacherId = 2;

    private bool IsLoading = true;
    private bool IsSaving = false;
    private TeacherScheduleDto? Schedule;
    private List<StudentAttendanceDto> Attendances = new();
    private string? ErrorMessage;
    private string? SuccessMessage;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            Schedule = await ScheduleService.GetScheduleByIdAsync(ScheduleId);
            if (Schedule != null)
            {
                Attendances = await ScheduleService.GetAttendanceForScheduleAsync(ScheduleId);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void MarkAllPresent()
    {
        foreach (var a in Attendances)
            a.IsPresent = true;
    }

    private void MarkAllAbsent()
    {
        foreach (var a in Attendances)
            a.IsPresent = false;
    }

    private async Task Save()
    {
        IsSaving = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var res = await ScheduleService.SaveAttendanceAsync(TeacherId, ScheduleId, Attendances);
            if (res.Success)
            {
                SuccessMessage = "Attendance saved successfully!";
            }
            else
            {
                ErrorMessage = res.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to save: " + ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }
}
