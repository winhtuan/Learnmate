@page "/teacher/schedule"
@rendermode InteractiveServer
@layout Layout.TeacherLayout

@using BusinessLogicLayer.DTOs.Teacher.Schedules
@using BusinessLogicLayer.Services.Interfaces.Teacher.Schedules
@using BusinessObject.Enum
@inject ITeacherScheduleService ScheduleService
@inject NavigationManager NavigationManager

<PageTitle>Class Selection | Schedule Management</PageTitle>

<div class="mb-8 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 mb-1">Schedule &amp; Attendance</h1>
        <p class="text-slate-500 font-normal">Select a class to manage its schedule and take attendance.</p>
    </div>
</div>

@if (IsLoading)
{
    <div class="flex items-center justify-center py-20">
        <span class="material-symbols-outlined animate-spin text-primary text-4xl">progress_activity</span>
    </div>
}
else if (Classes == null || Classes.Count == 0)
{
    <div class="bg-white border border-slate-200 rounded-lg p-12 text-center shadow-sm">
        <span class="material-symbols-outlined text-slate-300 text-6xl mb-4">class</span>
        <h2 class="text-xl font-bold text-slate-900 mb-2">No Classes Found</h2>
        <p class="text-slate-500 mb-6">You are not assigned to any classes yet.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var c in Classes)
        {
            <a href="/teacher/schedule/class/@c.Id" class="bg-white border border-slate-200 rounded-lg shadow-sm hover:shadow-md hover:border-primary/40 transition-all overflow-hidden cursor-pointer block group">
                <div class="p-6">
                    <div class="flex items-start justify-between mb-4">
                        <div class="size-10 rounded-lg bg-blue-50 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                            <span class="material-symbols-outlined">book</span>
                        </div>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            @c.Status
                        </span>
                    </div>
                    
                    <h3 class="text-lg font-bold text-slate-900 mb-1 group-hover:text-primary transition-colors">@c.Name</h3>
                    <p class="text-sm text-slate-500 mb-4 line-clamp-1">Subject: @c.Subject</p>
                    
                    <div class="pt-4 border-t border-slate-100 flex items-center justify-between text-sm">
                        <span class="flex items-center gap-1.5 text-slate-600">
                            <span class="material-symbols-outlined text-[18px]">group</span>
                            @c.EnrolledStudents Students
                        </span>
                        <span class="text-primary font-medium flex items-center gap-1">
                            Manage <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                        </span>
                    </div>
                </div>
            </a>
        }
    </div>
}

@code {
    private List<TeacherScheduleClassDto>? Classes;
    private bool IsLoading = true;
    private long TeacherId = 2; // Temporary context - typically comes from AuthState

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            Classes = await ScheduleService.GetTeacherClassesAsync(TeacherId);
        }
        catch (Exception)
        {
            // Error handling
        }
        finally
        {
            IsLoading = false;
        }
    }
}
