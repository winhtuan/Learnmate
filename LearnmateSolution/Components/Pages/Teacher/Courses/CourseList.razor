@page "/teacher/courses"
@* @inject ITeacherCourseService CourseService *@

<PageTitle>My Courses</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>My Courses</h3>
    <button class="btn btn-success">+ Create New Course</button>
</div>

<p>This is where Dev B will work on viewing and managing the teacher's courses.</p>

<table class="table table-striped table-hover mt-3">
    <thead>
        <tr>
            <th>Course ID</th>
            <th>Title</th>
            <th>Price</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Introduction to .NET</td>
            <td>$99</td>
            <td><span class="badge bg-primary">Published</span></td>
            <td>
                <button class="btn btn-sm btn-outline-secondary">Edit</button>
                <button class="btn btn-sm btn-outline-danger">Delete</button>
            </td>
        </tr>
    </tbody>
</table>

@code {
    // Component lifecycle, logic, list of courses, pagination, etc.
    protected override async Task OnInitializedAsync()
    {
        // Fetch courses for the teacher
    }
}
