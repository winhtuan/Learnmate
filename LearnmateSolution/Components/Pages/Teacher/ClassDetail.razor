<!-- Shared empty state component -->
@code {
    [Parameter] public long ClassId { get; set; }


    private TeacherClassDetailDto? Detail;
    private bool IsLoading = true;
    private string ActiveTab = "students";

    // ── Add Student Modal state ───────────────────────────────────────────────
    private bool                  ShowAddStudentModal;
    private string                SearchEmail       = "";
    private bool                  IsSearching;
    private bool                  SearchDone;
    private StudentSearchResultDto? SearchResult;
    private string?               AddStudentError;
    private bool                  IsAdding;
    private bool                  AddStudentSuccess;

    // ── Remove Student state ─────────────────────────────────────────────────
    private bool                  ShowRemoveStudentConfirm;
    private bool                  IsRemovingStudent;
    private TeacherStudentItemDto? StudentToRemove;

    // ── Upload Modal state ───────────────────────────────────────────────────
    private bool ShowUploadModal;
    private bool IsUploading;
    private IBrowserFile? SelectedFile;
    private string UploadTitle = "";
    private string? UploadDescription;
    private string? UploadError;

    // ── Delete state ─────────────────────────────────────────────────────────
    private bool ShowDeleteConfirm;
    private bool IsDeleting;
    private TeacherMaterialItemDto? MaterialToDelete;

    // ── Tab definitions ─────────────────────────────────────────────────────
    private IEnumerable<(string Key, string Label, string Icon, int Count)> Tabs =>
        Detail is null ? [] :
        [
            ("students",    "Học sinh",  "group",          Detail.TotalStudents),
            ("assignments", "Bài tập",   "assignment",     Detail.TotalAssignments),
            ("materials",   "Tài liệu",  "folder_open",    Detail.TotalMaterials),
            ("schedule",    "Lịch học",  "calendar_month", Detail.TotalSchedules)
        ];

    // ── Lifecycle ───────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        long teacherId = Session.UserId > 0 ? Session.UserId : 2;
        try { Detail = await ClassService.GetTeacherClassDetailAsync(ClassId, teacherId); }
        catch { }
        finally { IsLoading = false; }
    }

    // ── Meeting Link Methods ────────────────────────────────────────────────
    private bool isEditingMeetLink;
    private string? tempMeetLink;
    private bool isSavingMeetLink;

    private void StartEditingMeetLink()
    {
        tempMeetLink = Detail?.MeetingLink;
        isEditingMeetLink = true;
    }

    private async Task SaveMeetLink()
    {
        if (Detail == null) return;
        isSavingMeetLink = true;
        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 2;
            var success = await ClassService.UpdateMeetingLinkAsync(ClassId, teacherId, tempMeetLink);
            if (success)
            {
                Detail.MeetingLink = tempMeetLink;
                isEditingMeetLink = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving meet link: {ex.Message}");
        }
        finally
        {
            isSavingMeetLink = false;
        }
    }

    // ── Add Student Modal Methods ──────────────────────────────────────────
    private void OpenAddStudentModal()
    {
        SearchEmail        = "";
        SearchResult       = null;
        AddStudentError    = null;
        AddStudentSuccess  = false;
        SearchDone         = false;
        IsSearching        = false;
        IsAdding           = false;
        ShowAddStudentModal = true;
    }

    private void CloseAddStudentModal() => ShowAddStudentModal = false;

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleSearchStudent();
    }

    private async Task HandleSearchStudent()
    {
        if (string.IsNullOrWhiteSpace(SearchEmail)) return;
        IsSearching     = true;
        SearchResult    = null;
        AddStudentError = null;
        SearchDone      = false;
        StateHasChanged();
        try
        {
            SearchResult = await ClassService.SearchStudentByEmailAsync(SearchEmail.Trim(), ClassId);
            SearchDone   = true;
        }
        catch (Exception ex) { AddStudentError = ex.Message; }
        finally { IsSearching = false; StateHasChanged(); }
    }

    private async Task HandleAddStudent()
    {
        if (SearchResult is null || SearchResult.AlreadyInClass) return;
        IsAdding        = true;
        AddStudentError = null;
        StateHasChanged();
        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 2;
            var error = await ClassService.AddStudentToClassAsync(ClassId, teacherId, SearchResult.Email);
            if (error is not null)
            {
                AddStudentError = error;
            }
            else
            {
                // Add to local list
                Detail!.Students.Add(new TeacherStudentItemDto
                {
                    StudentId  = SearchResult.UserId,
                    FullName   = SearchResult.FullName,
                    Email      = SearchResult.Email,
                    AvatarUrl  = SearchResult.AvatarUrl,
                    GradeLevel = SearchResult.GradeLevel,
                    Status     = "ACTIVE",
                    JoinedAt   = DateTime.Now
                });
                Detail.TotalStudents = Detail.Students.Count;
                AddStudentSuccess    = true;
                SearchResult.AlreadyInClass = true;
                SearchEmail         = "";
                SearchResult        = null;
                SearchDone          = false;
            }
        }
        catch (Exception ex) { AddStudentError = ex.Message; }
        finally { IsAdding = false; StateHasChanged(); }
    }

    // ── Remove Student Methods ─────────────────────────────────────────────────
    private void ConfirmRemoveStudent(TeacherStudentItemDto s)
    {
        StudentToRemove          = s;
        ShowRemoveStudentConfirm = true;
    }

    private async Task HandleRemoveStudent()
    {
        if (StudentToRemove is null) return;
        IsRemovingStudent = true;
        StateHasChanged();
        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 2;
            var ok = await ClassService.RemoveStudentFromClassAsync(ClassId, teacherId, StudentToRemove.StudentId);
            if (ok)
            {
                Detail!.Students.RemoveAll(s => s.StudentId == StudentToRemove.StudentId);
                Detail.TotalStudents = Detail.Students.Count;
            }
            ShowRemoveStudentConfirm = false;
            StudentToRemove = null;
        }
        catch { }
        finally { IsRemovingStudent = false; StateHasChanged(); }
    }

    // ── Upload Modal Methods ─────────────────────────────────────────────────
    private void OpenUploadModal()
    {
        ShowUploadModal = true;
        SelectedFile = null;
        UploadTitle = "";
        UploadDescription = null;
        UploadError = null;
        IsUploading = false;
    }

    private void CloseUploadModal()
    {
        if (IsUploading) return;
        ShowUploadModal = false;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        UploadError = null;
        var file = e.File;

        // Check file size (50 MB max)
        if (file.Size > 50 * 1024 * 1024)
        {
            UploadError = $"File quá lớn ({file.Size / 1024 / 1024} MB). Tối đa 50 MB.";
            return;
        }

        SelectedFile = file;

        // Auto-fill title from filename if empty
        if (string.IsNullOrWhiteSpace(UploadTitle))
        {
            UploadTitle = Path.GetFileNameWithoutExtension(file.Name);
        }
    }

    private void ClearSelectedFile()
    {
        SelectedFile = null;
    }

    private async Task HandleUpload()
    {
        if (SelectedFile is null || string.IsNullOrWhiteSpace(UploadTitle)) return;

        IsUploading = true;
        UploadError = null;
        StateHasChanged();

        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 2;

            await using var stream = SelectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);

            var newMaterial = await ClassService.UploadMaterialAsync(
                ClassId, teacherId,
                SelectedFile.Name, UploadTitle, UploadDescription,
                stream, SelectedFile.ContentType, SelectedFile.Size);

            // Add to the list and update count
            Detail!.Materials.Insert(0, newMaterial);
            Detail.TotalMaterials = Detail.Materials.Count;

            ShowUploadModal = false;
        }
        catch (Exception ex)
        {
            UploadError = ex.Message;
        }
        finally
        {
            IsUploading = false;
            StateHasChanged();
        }
    }

    // ── Download Material ────────────────────────────────────────────────────
    private async Task DownloadMaterial(TeacherMaterialItemDto m)
    {
        try
        {
            var url = await FileStorage.GetUrlAsync(m.FileUrl, expirySeconds: 3600);
            Nav.NavigateTo(url, forceLoad: true);
        }
        catch
        {
            // If presigned URL fails, try direct URL
            if (!string.IsNullOrEmpty(m.FileUrl))
                Nav.NavigateTo(m.FileUrl, forceLoad: true);
        }
    }

    // ── Delete Material ──────────────────────────────────────────────────────
    private void ConfirmDeleteMaterial(TeacherMaterialItemDto m)
    {
        MaterialToDelete = m;
        ShowDeleteConfirm = true;
    }

    private async Task HandleDeleteMaterial()
    {
        if (MaterialToDelete is null) return;

        IsDeleting = true;
        StateHasChanged();

        try
        {
            long teacherId = Session.UserId > 0 ? Session.UserId : 2;
            await ClassService.DeleteMaterialAsync(ClassId, teacherId, MaterialToDelete.Id);

            Detail!.Materials.RemoveAll(m => m.Id == MaterialToDelete.Id);
            Detail.TotalMaterials = Detail.Materials.Count;
            ShowDeleteConfirm = false;
            MaterialToDelete = null;
        }
        catch { }
        finally
        {
            IsDeleting = false;
            StateHasChanged();
        }
    }

    // ── Stats ───────────────────────────────────────────────────────────────
    private IEnumerable<(string Label, string Value, string Icon, string IconColor, string Sub)> GetStats() =>
        Detail is null ? [] :
        [
            ("Học sinh",    Detail.TotalStudents.ToString(),
             "group",       "text-blue-400",
             $"/ {Detail.MaxStudents} tối đa"),
            ("Bài tập",     Detail.TotalAssignments.ToString(),
             "assignment",  "text-purple-400",
             Detail.Assignments.Count(a => a.Status == "PUBLISHED") + " đang mở"),
            ("Lịch học",    Detail.TotalSchedules.ToString(),
             "calendar_month","text-green-400",
             Detail.Schedules.Count(s => s.StartTime >= DateTime.Now) + " sắp tới"),
            ("Tài liệu",    Detail.TotalMaterials.ToString(),
             "folder_open", "text-orange-400",
             "tài liệu đang hoạt động")
        ];

    // ── Format file size ─────────────────────────────────────────────────────
    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    // ── Subject theming ─────────────────────────────────────────────────────
    private static string GetSubjectBg(string s) => s.ToLower() switch
    {
        var x when x.Contains("toán") || x.Contains("math")    => "bg-blue-100",
        var x when x.Contains("lý")   || x.Contains("physics") => "bg-purple-100",
        var x when x.Contains("hóa")  || x.Contains("chem")    => "bg-orange-100",
        var x when x.Contains("sinh") || x.Contains("bio")     => "bg-green-100",
        var x when x.Contains("văn")  || x.Contains("liter")   => "bg-pink-100",
        var x when x.Contains("tin")  || x.Contains("comp")    => "bg-cyan-100",
        _                                                        => "bg-indigo-100"
    };

    private static string GetSubjectText(string s) => s.ToLower() switch
    {
        var x when x.Contains("toán") || x.Contains("math")    => "text-blue-600",
        var x when x.Contains("lý")   || x.Contains("physics") => "text-purple-600",
        var x when x.Contains("hóa")  || x.Contains("chem")    => "text-orange-600",
        var x when x.Contains("sinh") || x.Contains("bio")     => "text-green-600",
        var x when x.Contains("văn")  || x.Contains("liter")   => "text-pink-600",
        var x when x.Contains("tin")  || x.Contains("comp")    => "text-cyan-600",
        _                                                        => "text-indigo-600"
    };

    private static string GetSubjectIcon(string s) => s.ToLower() switch
    {
        var x when x.Contains("toán") || x.Contains("math")    => "calculate",
        var x when x.Contains("lý")   || x.Contains("physics") => "science",
        var x when x.Contains("hóa")  || x.Contains("chem")    => "biotech",
        var x when x.Contains("sinh") || x.Contains("bio")     => "eco",
        var x when x.Contains("văn")  || x.Contains("liter")   => "menu_book",
        var x when x.Contains("tin")  || x.Contains("comp")    => "terminal",
        _                                                        => "class"
    };

    private static (string icon, string bg) GetFileStyle(string fileType) =>
        fileType.ToLower() switch
        {
            "pdf"                      => ("picture_as_pdf", "bg-red-500"),
            "doc" or "docx"           => ("description",    "bg-blue-500"),
            "xls" or "xlsx"           => ("table_chart",    "bg-green-500"),
            "ppt" or "pptx"           => ("slideshow",      "bg-orange-500"),
            "mp4" or "mov" or "avi"   => ("play_circle",    "bg-purple-500"),
            "jpg" or "jpeg" or "png"  => ("image",          "bg-pink-500"),
            "zip" or "rar"            => ("folder_zip",     "bg-yellow-500"),
            _                         => ("insert_drive_file","bg-slate-500")
        };
}


