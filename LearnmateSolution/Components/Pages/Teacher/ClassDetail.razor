@* ═══════════════════════════════════════════════════════════════════════════════
   UPLOAD MATERIAL MODAL
   ═══════════════════════════════════════════════════════════════════════════════ *@
@if (ShowUploadModal)

{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
         @onclick="CloseUploadModal">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden animate-scale-in"
             @onclick:stopPropagation="true">

            <!-- Modal Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[24px]">upload_file</span>
                    <h2 class="text-lg font-bold text-slate-900">Tải lên tài liệu</h2>
                </div>
                <button @onclick="CloseUploadModal"
                        class="size-8 flex items-center justify-center rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-700 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="px-6 py-5 space-y-4">
                <!-- Drop zone / File picker -->
                <div class="relative border-2 border-dashed rounded-xl p-8 text-center transition-all
                            @(SelectedFile is not null ? "border-primary bg-blue-50/50" : "border-slate-200 hover:border-primary/50 hover:bg-slate-50")">
                    @if (SelectedFile is null)
                    {
                        <span class="material-symbols-outlined text-slate-300 text-5xl mb-3">cloud_upload</span>
                        <p class="text-sm font-medium text-slate-600 mb-1">Kéo thả file vào đây hoặc nhấn để chọn</p>
                        <p class="text-xs text-slate-400">PDF, Word, Excel, PowerPoint, Hình ảnh, ZIP — Tối đa 50 MB</p>
                    }
                    else
                    {
                        var (fIcon, fColor) = GetFileStyle(Path.GetExtension(SelectedFile.Name).TrimStart('.'));
                        <div class="flex items-center gap-3 justify-center">
                            <div class="size-10 rounded-lg @fColor flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-white text-[22px]">@fIcon</span>
                            </div>
                            <div class="text-left">
                                <p class="font-medium text-slate-900 text-sm truncate max-w-[280px]">@SelectedFile.Name</p>
                                <p class="text-xs text-slate-400">@FormatFileSize(SelectedFile.Size)</p>
                            </div>
                            <button @onclick="ClearSelectedFile"
                                    class="size-7 flex items-center justify-center rounded-full hover:bg-red-50 text-slate-300 hover:text-red-500 transition-colors">
                                <span class="material-symbols-outlined text-[18px]">close</span>
                            </button>
                        </div>
                    }
                    <InputFile OnChange="OnFileSelected"
                               accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png,.gif,.zip,.rar,.txt"
                               class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                </div>

                <!-- Title -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Tiêu đề <span class="text-red-400">*</span></label>
                    <input @bind="UploadTitle"
                           placeholder="Nhập tiêu đề tài liệu..."
                           class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                </div>

                <!-- Description (optional) -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Mô tả <span class="text-slate-300 text-xs">(tuỳ chọn)</span></label>
                    <textarea @bind="UploadDescription" rows="2"
                              placeholder="Ghi chú thêm về tài liệu này..."
                              class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all resize-none"></textarea>
                </div>

                <!-- Error message -->
                @if (!string.IsNullOrEmpty(UploadError))
                {
                    <div class="flex items-center gap-2 p-3 bg-red-50 border border-red-200 rounded-lg">
                        <span class="material-symbols-outlined text-red-500 text-[18px]">error</span>
                        <p class="text-sm text-red-600">@UploadError</p>
                    </div>
                }

                <!-- Upload progress -->
                @if (IsUploading)
                {
                    <div class="space-y-2">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined animate-spin text-primary text-[18px]">progress_activity</span>
                            <p class="text-sm text-slate-600">Đang tải lên...</p>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2">
                            <div class="bg-primary h-2 rounded-full transition-all animate-pulse" style="width: 60%"></div>
                        </div>
                    </div>
                }
            </div>

            <!-- Modal Footer -->
            <div class="flex items-center justify-end gap-2 px-6 py-4 border-t border-slate-100 bg-slate-50/50">
                <button @onclick="CloseUploadModal"
                        disabled="@IsUploading"
                        class="px-4 py-2 rounded-lg border border-slate-200 text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors disabled:opacity-50">
                    Hủy
                </button>
                <button @onclick="HandleUpload"
                        disabled="@(IsUploading || SelectedFile is null || string.IsNullOrWhiteSpace(UploadTitle))"
                        class="flex items-center gap-1.5 px-5 py-2 rounded-lg bg-primary hover:bg-blue-600 text-white text-sm font-medium transition-all shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-[18px]">cloud_upload</span>
                    Tải lên
                </button>
            </div>
        </div>
    </div>
}

@* ═══════════════════════════════════════════════════════════════════════════════
   DELETE CONFIRMATION MODAL
   ═══════════════════════════════════════════════════════════════════════════════ *@
@if (ShowDeleteConfirm && MaterialToDelete is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
         @onclick="() => ShowDeleteConfirm = false">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 p-6 text-center animate-scale-in"
