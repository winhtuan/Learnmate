@page "/classes/{Id:int}/materials"
@layout ClassLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Class.Components
@using LearnmateSolution.Components.Pages.Class.Models

<div class="space-y-6 max-w-screen-xl mx-auto">
    <Breadcrumb Items="@([ new("Dashboard", "/student-dashboard"), new("My Classes", "/classes"), new("Advanced Calculus", $"/classes/{Id}"), new("Materials") ])" />

    <HeroBanner
        ClassCode="MATH101"
        ClassStatus="Active"
        ClassName="Advanced Calculus"
        Description="Multivariable calculus, vector analysis, and differential equations for science and engineering students."
        BackgroundImage="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=1200" />

    <ClassTabNav ClassId="@Id" ActiveTab="materials" />

    <MaterialsToolbar />

    @* Folders *@
    <div>
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Folders</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var folder in folders)
            {
                <MaterialFolderCard Folder="folder" />
            }
        </div>
    </div>

    @* Recent files *@
    <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="text-base font-bold text-slate-900">Recent Files</h3>
            <button class="text-sm font-semibold text-primary hover:text-primary/80 transition-colors">View all</button>
        </div>
        <table class="w-full">
            <thead class="bg-slate-50 border-b border-slate-100">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Name</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider hidden md:table-cell">Folder</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider hidden lg:table-cell">Size</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider hidden lg:table-cell">Modified</th>
                    <th class="px-6 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @foreach (var file in recentFiles)
                {
                    <MaterialFileRow File="file" />
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    // MaterialFolder(int Id, string Name, int FileCount, string Size, string Icon, string IconColor, string IconBg)
    private List<MaterialFolder> folders =
    [
        new MaterialFolder(1, "Lecture Slides", 12, "48 MB", "auto_stories", "text-sky-600", "bg-sky-100"),
        new MaterialFolder(2, "Readings", 8, "22 MB", "menu_book", "text-emerald-600", "bg-emerald-100"),
        new MaterialFolder(3, "Resources", 5, "6 MB", "folder_special", "text-purple-600", "bg-purple-100"),
    ];

    // MaterialFile(int Id, string Name, string Type, string Date, string Size, string Icon, string IconColor, string IconBg)
    private List<MaterialFile> recentFiles =
    [
        new MaterialFile(1, "Lecture 12 - Chain Rule.pdf", "Lecture Slides", "Today", "2.4 MB", "picture_as_pdf", "text-rose-600", "bg-rose-100"),
        new MaterialFile(2, "Chapter 7 Reading.pdf", "Readings", "Yesterday", "1.8 MB", "picture_as_pdf", "text-rose-600", "bg-rose-100"),
        new MaterialFile(3, "Problem Set 7.pdf", "Resources", "Oct 12", "320 KB", "picture_as_pdf", "text-rose-600", "bg-rose-100"),
        new MaterialFile(4, "Formula Sheet.pdf", "Resources", "Oct 10", "180 KB", "picture_as_pdf", "text-rose-600", "bg-rose-100"),
    ];
}
