@page "/classes/{Id:long}/schedule"
@layout ClassLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Class.Components
@using LearnmateSolution.Components.Pages.Class.Models
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Class
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<div class="space-y-6 max-w-screen-xl mx-auto">
    <Breadcrumb Items="@([ new("Dashboard", "/student-dashboard"), new("My Classes", "/classes"), new(_className, $"/classes/{Id}"), new("Schedule") ])" />

    @if (!_ready)
    {
        <div class="flex items-center justify-center h-64 text-slate-400">
            <svg class="animate-spin h-8 w-8 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span class="text-sm font-medium">Loading...</span>
        </div>
    }
    else
    {
        <HeroBanner ClassCode="@_subject" ClassStatus="@_status" ClassName="@_className"
                    Description="@_description" BackgroundImage="" />

        <ClassTabNav ClassId="@Id" ActiveTab="schedule" />

        <ScheduleHeader Month="@_currentMonthName" Year="@_currentYear"
                        OnPrevMonth="@NavPrevMonth" OnNextMonth="@NavNextMonth"
                        OnSync="@ExportIcs" />

        <EventTypeLegend EventTypes="@_eventTypes" />

        <ScheduleCalendar Days="@_calendarDays" />
    }
</div>

@code {
    [Parameter] public long Id { get; set; }

    private bool _ready;
    private string _className   = "Class";
    private string _subject     = "";
    private string _status      = "ACTIVE";
    private string _description = "";
    private string _currentMonthName = "";
    private int    _currentYear;
    private DateTime _displayDate;
    private List<CalendarDay> _calendarDays = [];
    private List<ClassScheduleItemDto> _schedules = [];

    private static readonly List<EventTypeItem> _eventTypes =
    [
        new("REGULAR", "Session", "sky"),
        new("EXTRA",   "Extra",   "emerald"),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Session.IsAuthenticated)
        {
            var email = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
            var role  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
            if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
                Session.SetSession(email, role, token);
        }

        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login", replace: true); return; }
        if (Session.Role != "STUDENT") { Nav.NavigateTo(Session.Role == "ADMIN" ? "/admin/dashboard" : "/", replace: true); return; }

        await LoadAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("learnmate");
            client.BaseAddress = new Uri(Nav.BaseUri);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);

            var classTask = client.GetFromJsonAsync<ApiResponse<ClassDetailDto>>($"api/classes/{Id}");
            var schTask   = client.GetFromJsonAsync<ApiResponse<List<ClassScheduleItemDto>>>($"api/classes/{Id}/schedules");
            await Task.WhenAll(classTask, schTask);

            var cls = classTask.Result?.Data;
            if (cls is not null)
            {
                _className   = cls.Name;
                _subject     = cls.Subject;
                _status      = cls.Status;
                _description = cls.Description ?? "";
            }

            _schedules = schTask.Result?.Data ?? [];

            var today = DateTime.Today;
            _displayDate = _schedules.Where(s => s.StartTimeLocal >= today)
                                     .Select(s => s.StartTimeLocal)
                                     .FirstOrDefault();
            if (_displayDate == default) _displayDate = today;

            RefreshCalendar();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Session.Clear();
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_email");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_role");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_token");
            Nav.NavigateTo("/login", replace: true);
        }
        catch
        {
            var today = DateTime.Today;
            _displayDate = today;
            RefreshCalendar();
        }
    }

    private void RefreshCalendar()
    {
        _currentMonthName = _displayDate.ToString("MMMM");
        _currentYear      = _displayDate.Year;
        _calendarDays     = BuildCalendar(_displayDate.Year, _displayDate.Month, _schedules, DateTime.Today);
    }

    private void NavPrevMonth()
    {
        _displayDate = _displayDate.AddMonths(-1);
        RefreshCalendar();
    }

    private void NavNextMonth()
    {
        _displayDate = _displayDate.AddMonths(1);
        RefreshCalendar();
    }

    private async Task ExportIcs()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("BEGIN:VCALENDAR");
        sb.AppendLine("VERSION:2.0");
        sb.AppendLine("PRODID:-//LearnMate//EN");

        foreach (var s in _schedules)
        {
            sb.AppendLine("BEGIN:VEVENT");
            sb.AppendLine($"UID:{s.Id}@learnmate");
            sb.AppendLine($"DTSTART:{s.StartTimeLocal.ToUniversalTime():yyyyMMdd'T'HHmmss'Z'}");
            sb.AppendLine($"DTEND:{s.EndTimeLocal.ToUniversalTime():yyyyMMdd'T'HHmmss'Z'}");
            sb.AppendLine($"SUMMARY:{s.Title}");
            sb.AppendLine("END:VEVENT");
        }

        sb.AppendLine("END:VCALENDAR");

        await JS.InvokeVoidAsync("downloadFile",
            $"{_className}-schedule.ics",
            sb.ToString(),
            "text/calendar");
    }

    private static List<CalendarDay> BuildCalendar(
        int year, int month, List<ClassScheduleItemDto> schedules, DateTime today)
    {
        var days = new List<CalendarDay>();

        var byDay = schedules
            .Where(s => s.StartTimeLocal.Year == year && s.StartTimeLocal.Month == month)
            .GroupBy(s => s.StartTimeLocal.Day)
            .ToDictionary(g => g.Key, g => g.ToList());

        var firstDay  = new DateTime(year, month, 1);
        var leadingDays = ((int)firstDay.DayOfWeek + 6) % 7;
        var prevMonth = firstDay.AddDays(-1);
        for (int i = leadingDays - 1; i >= 0; i--)
            days.Add(new CalendarDay(prevMonth.AddDays(-i).Day, IsPrevMonth: true));

        var daysInMonth = DateTime.DaysInMonth(year, month);
        for (int d = 1; d <= daysInMonth; d++)
        {
            var isToday = today.Year == year && today.Month == month && today.Day == d;
            var events  = byDay.TryGetValue(d, out var list)
                ? list.Select(s => new CalendarEvent(
                    Type:  s.Type.ToUpper(),
                    Time:  s.StartTimeLocal.ToString("h:mm tt"),
                    Title: s.Title
                )).ToList()
                : null;
            days.Add(new CalendarDay(d, IsToday: isToday, Events: events));
        }

        int nextDay = 1;
        while (days.Count % 7 != 0)
            days.Add(new CalendarDay(nextDay++, IsNextMonth: true));

        return days;
    }
}
