@page "/classes/{Id:int}/schedule"
@layout ClassLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Class.Components
@using LearnmateSolution.Components.Pages.Class.Models

<div class="space-y-6 max-w-screen-xl mx-auto">
    <Breadcrumb Items="@([ new("Dashboard", "/student-dashboard"), new("My Classes", "/classes"), new("Advanced Calculus", $"/classes/{Id}"), new("Schedule") ])" />

    <HeroBanner
        ClassCode="MATH101"
        ClassStatus="Active"
        ClassName="Advanced Calculus"
        Description="Multivariable calculus, vector analysis, and differential equations for science and engineering students."
        BackgroundImage="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=1200" />

    <ClassTabNav ClassId="@Id" ActiveTab="schedule" />

    <ScheduleHeader Month="October" Year="2023" />

    <EventTypeLegend EventTypes="eventTypes" />

    <ScheduleCalendar Days="calendarDays" />
</div>

@code {
    [Parameter] public int Id { get; set; }

    // EventTypeItem(string Type, string Label, string Color)
    private List<EventTypeItem> eventTypes =
    [
        new EventTypeItem("lecture",  "Lecture",      "sky"),
        new EventTypeItem("office",   "Office Hours", "emerald"),
        new EventTypeItem("deadline", "Deadline",     "rose"),
        new EventTypeItem("exam",     "Exam",         "purple"),
    ];

    private List<CalendarDay> calendarDays = BuildCalendar();

    // CalendarEvent(string Type, string? Time, string Title)
    private static List<CalendarDay> BuildCalendar()
    {
        var days = new List<CalendarDay>();

        for (int d = 1; d <= 31; d++)
        {
            List<CalendarEvent>? events = d switch
            {
                2  => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 1")],
                4  => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 2")],
                6  => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 3")],
                9  => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 4")],
                11 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 5"), new CalendarEvent("office", "3:00 PM", "Office Hours")],
                13 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 6")],
                15 => [new CalendarEvent("deadline", null,      "Problem Set 5 Due")],
                16 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 7")],
                18 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 8"), new CalendarEvent("deadline", null, "Problem Set 6 Due")],
                20 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 9")],
                23 => [new CalendarEvent("exam",     "9:00 AM", "Midterm Exam")],
                25 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 10"), new CalendarEvent("office", "3:00 PM", "Office Hours")],
                27 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 11")],
                30 => [new CalendarEvent("lecture",  "9:00 AM", "Lecture 12")],
                _  => null
            };
            days.Add(new CalendarDay(d, IsToday: d == 16, Events: events));
        }

        int nextDay = 1;
        while (days.Count < 35)
            days.Add(new CalendarDay(nextDay++, IsNextMonth: true));

        return days;
    }
}
