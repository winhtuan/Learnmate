@using LearnmateSolution.Components.Pages.Class.Models

<div class="flex flex-wrap gap-8 px-4 justify-center md:justify-start">
    @foreach (var item in EventTypes)
    {
        <div class="flex items-center gap-3">
            <span class="w-4 h-4 rounded-md @ColorClass(item.Color) border"></span>
            <span class="text-sm font-medium text-slate-600">@item.Label</span>
        </div>
    }
</div>

@code {
    [Parameter] public List<EventTypeItem> EventTypes { get; set; } = [];

    private static string ColorClass(string color) => color switch
    {
        "sky"     => "bg-sky-100 border-sky-200",
        "emerald" => "bg-emerald-100 border-emerald-200",
        "rose"    => "bg-rose-100 border-rose-200",
        "purple"  => "bg-purple-100 border-purple-200",
        _         => "bg-slate-100 border-slate-200",
    };
}
