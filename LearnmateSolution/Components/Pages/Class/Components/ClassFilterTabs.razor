<div class="flex items-center justify-between gap-4">
    <div class="relative shrink-0 w-96">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-[20px]">search</span>
        <input type="text"
               placeholder="Search classes..."
               value="@SearchQuery"
               @oninput="e => OnSearchChange.InvokeAsync(e.Value?.ToString() ?? string.Empty)"
               class="w-full pl-11 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all shadow-sm" />
    </div>
    
    <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-hide">
        @foreach (var tab in Tabs)
        {
            var isActive = ActiveTab == tab.Id;
            <button @onclick="() => HandleClick(tab.Id)"
                    class="px-5 py-2.5 rounded-full text-sm whitespace-nowrap transition-colors border @(isActive ? "bg-slate-900 text-white font-semibold border-slate-900" : "bg-white text-slate-700 border-slate-200 font-semibold hover:bg-slate-50")">
                @tab.Label
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public string ActiveTab { get; set; } = "all";
    [Parameter] public EventCallback<string> OnTabChange { get; set; }
    [Parameter] public string SearchQuery { get; set; } = "";
    [Parameter] public EventCallback<string> OnSearchChange { get; set; }

    private record TabEntry(string Id, string Label);

    private static readonly TabEntry[] Tabs =
    [
        new("all",       "All Classes"),
        new("active",    "Active"),
        new("completed", "Completed"),
    ];

    private async Task HandleClick(string id)
    {
        ActiveTab = id;
        await OnTabChange.InvokeAsync(id);
    }
}
