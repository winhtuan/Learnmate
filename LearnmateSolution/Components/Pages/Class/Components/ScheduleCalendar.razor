@using LearnmateSolution.Components.Pages.Class.Models

<div class="bg-white rounded-[2.5rem] p-6 lg:p-8 border border-slate-100 shadow-sm">
    @* Week day headers *@
    <div class="grid grid-cols-7 mb-4 border-b border-slate-100 pb-4">
        @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
        {
            <div class="text-center text-sm font-bold text-slate-400 uppercase tracking-wider">@day</div>
        }
    </div>

    @* Calendar grid *@
    <div class="grid grid-cols-7 gap-2 lg:gap-3">
        @foreach (var (dayData, index) in Days.Select((d, i) => (d, i)))
        {
            var isOtherMonth = dayData.IsPrevMonth || dayData.IsNextMonth;
            <div class="p-2 min-h-[120px] rounded-2xl flex flex-col gap-1 relative @(isOtherMonth ? "border border-transparent text-slate-300 bg-slate-50/50" : "border border-slate-100 hover:border-primary/30 hover:shadow-md transition-all bg-white") @(dayData.IsToday ? "ring-2 ring-primary ring-offset-2" : "")">

                @if (dayData.IsToday)
                {
                    <span class="absolute -top-1 -right-1 flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-primary"></span>
                    </span>
                }

                <span class="text-sm font-bold p-1 block @(dayData.IsToday ? "text-primary" : isOtherMonth ? "font-medium" : "text-slate-700")">
                    @dayData.Day
                </span>

                @if (dayData.Events is not null)
                {
                    @foreach (var ev in dayData.Events)
                    {
                        var colors = EventColors[ev.Type];
                        <div class="px-2 py-1.5 rounded-lg @colors.Bg border @colors.Border">
                            <p class="text-[10px] font-bold @colors.TextLabel uppercase tracking-wide mb-0.5">
                                @EventLabels[ev.Type]
                            </p>
                            <p class="text-xs font-semibold text-slate-900 truncate">
                                @(ev.Time is not null ? $"{ev.Time} - " : "")@ev.Title
                            </p>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<CalendarDay> Days { get; set; } = [];

    private record EventColorSet(string Bg, string Border, string TextLabel);

    private static readonly Dictionary<string, EventColorSet> EventColors = new()
    {
        ["lecture"]  = new("bg-sky-100",     "border-sky-200",     "text-sky-700"),
        ["office"]   = new("bg-emerald-100", "border-emerald-200", "text-emerald-700"),
        ["deadline"] = new("bg-rose-100",    "border-rose-200",    "text-rose-700"),
        ["exam"]     = new("bg-purple-100",  "border-purple-200",  "text-purple-700"),
    };

    private static readonly Dictionary<string, string> EventLabels = new()
    {
        ["lecture"]  = "Lecture",
        ["office"]   = "Office Hrs",
        ["deadline"] = "Deadline",
        ["exam"]     = "Mid-Term",
    };
}
