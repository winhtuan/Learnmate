@using LearnmateSolution.Components.Pages.Class.Models

<section class="bg-white rounded-[2.5rem] p-1 border border-slate-100 shadow-xl shadow-slate-200/50">
    <div class="rounded-[2.2rem] bg-slate-900 overflow-hidden relative">
        @* Glow *@
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/30 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2"></div>

        <div class="relative z-10 flex flex-col md:flex-row p-8 md:p-10 gap-8 items-start md:items-center">
            <div class="flex-1 space-y-6">
                @* Status + Date *@
                <div class="flex flex-wrap items-center gap-4">
                    <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-rose-500/20 text-rose-300 border border-rose-500/30 text-xs font-bold uppercase tracking-wider">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
                        </span>
                        @Session.Status
                    </span>
                    <span class="text-slate-300 font-medium flex items-center gap-2 text-sm">
                        <span class="material-symbols-outlined text-[18px]">calendar_today</span>
                        @Session.Date
                    </span>
                </div>

                @* Title + Description *@
                <div>
                    <h2 class="text-3xl md:text-4xl font-bold text-white mb-2 leading-tight">@Session.Title</h2>
                    <p class="text-slate-400 text-lg max-w-xl">@Session.Description</p>
                </div>

                @* Actions *@
                <div class="flex flex-wrap items-center gap-6">
                    <a href="@Session.MeetingUrl" target="_blank" rel="noopener noreferrer" class="relative flex items-center gap-3 px-8 py-4 bg-primary text-white rounded-2xl font-bold text-base shadow-lg shadow-primary/40 hover:bg-primary/90 transition-all hover:scale-[1.02] active:scale-[0.98]">
                        <span class="material-symbols-outlined">videocam</span>
                        Join Room
                        <span class="absolute -top-1 -right-1 flex h-4 w-4">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-40"></span>
                        </span>
                    </a>

                    <div class="flex items-center gap-3 text-sm font-medium text-slate-300">
                        <div class="flex -space-x-3">
                            <div class="size-8 rounded-full border-2 border-slate-900 bg-slate-700"></div>
                            <div class="size-8 rounded-full border-2 border-slate-900 bg-slate-600"></div>
                            <div class="size-8 rounded-full border-2 border-slate-900 bg-slate-500 flex items-center justify-center text-[10px] text-white">
                                @Session.StudentsWaiting+
                            </div>
                        </div>
                        <span>Students waiting</span>
                    </div>
                </div>
            </div>

            @* Host card *@
            <div class="bg-white/10 backdrop-blur-md border border-white/10 p-5 rounded-2xl flex items-center gap-4 w-full md:w-auto min-w-[240px]">
                <div class="size-12 rounded-full bg-slate-800 overflow-hidden">
                    <img class="w-full h-full object-cover" src="@Session.Host.Avatar" alt="@Session.Host.Name" />
                </div>
                <div>
                    <p class="text-xs text-slate-400 uppercase tracking-wide font-bold">Hosted By</p>
                    <p class="text-white font-bold">@Session.Host.Name</p>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter] public LiveSession Session { get; set; } = null!;
}
