@page "/login"
@layout AuthLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout

<PageTitle>Sign in – LearnMate</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="css/auth/login.css" />
</HeadContent>

<div class="lm-auth-container">

    <!-- ══════════════ LEFT PANEL ══════════════ -->
    <div class="lm-left-panel">
        <div>
            <div class="lm-logo-row">
                <AuthLogo />
            </div>
            <div class="lm-left-hero">
                <h1 class="lm-welcome-heading">Welcome back</h1>
                <p class="lm-welcome-sub">
                    Access your account securely and continue your learning journey from where you left off.
                </p>
            </div>
        </div>

        <div class="lm-recent-accounts">
            <p class="lm-recent-label">Recent accounts</p>
            <div class="lm-avatar-row">
                @foreach (var account in recentAccounts)
                {
                    <button class="lm-avatar-btn" @onclick="() => OpenModal(account)" title="@account.Name">
                        <img src="@account.AvatarUrl" alt="@account.Name" class="lm-avatar-img" />
                        <span class="lm-avatar-tooltip">@account.Name</span>
                    </button>
                }
                <button class="lm-avatar-btn lm-avatar-add" title="Add account">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- ══════════════ RIGHT PANEL ══════════════ -->
    <div class="lm-right-panel">
        <div class="lm-form-container">

            <div class="lm-mobile-logo">
                <AuthLogo Dark="false" />
            </div>

            <h2 class="lm-signin-heading">Sign in</h2>
            <p class="lm-signin-sub">Enter your credentials to access your account</p>

            @if (!string.IsNullOrEmpty(globalError))
            {
                <div class="lm-global-error" role="alert">@globalError</div>
            }

            <div class="lm-form">

                <!-- Email -->
                <div class="lm-field">
                    <label class="lm-label" for="email">
                        Email address <span class="lm-required">*</span>
                    </label>
                    <div class="lm-input-wrapper">
                        <svg class="lm-input-icon-left" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="16" x="2" y="4" rx="2" />
                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                        </svg>
                        <input id="email" type="email"
                               class="lm-input lm-input--icon-left @(emailError != null ? "lm-input--error" : "")"
                               placeholder="you@example.com"
                               @bind="email" @bind:event="oninput"
                               disabled="@isLoading" autocomplete="email" />
                    </div>
                    @if (emailError != null)
                    {
                        <span class="lm-error-text" role="alert">@emailError</span>
                    }
                </div>

                <!-- Password -->
                <div class="lm-field">
                    <div class="lm-label-row">
                        <label class="lm-label" for="password">
                            Password <span class="lm-required">*</span>
                        </label>
                        <a href="/forgot-password" class="lm-forgot-link">Forgot your password?</a>
                    </div>
                    <div class="lm-input-wrapper">
                        <input id="password"
                               type="@(showPassword ? "text" : "password")"
                               class="lm-input lm-input--icon-right @(passwordError != null ? "lm-input--error" : "")"
                               placeholder="••••••••"
                               @bind="password" @bind:event="oninput"
                               disabled="@isLoading" autocomplete="current-password" />
                        <button type="button" class="lm-eye-btn" @onclick="TogglePassword" tabindex="-1" aria-label="Toggle password visibility">
                            @if (showPassword)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24" />
                                    <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68" />
                                    <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61" />
                                    <line x1="2" x2="22" y1="2" y2="22" />
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            }
                        </button>
                    </div>
                    @if (passwordError != null)
                    {
                        <span class="lm-error-text" role="alert">@passwordError</span>
                    }
                </div>

                <!-- Sign in button -->
                <button class="lm-btn-primary" @onclick="HandleLogin" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="lm-spinner" aria-label="Signing in..."></span>
                    }
                    else
                    {
                        <span>Sign in</span>
                    }
                </button>

                <!-- Divider -->
                <div class="lm-divider">
                    <div class="lm-divider-line"></div>
                    <span class="lm-divider-label">Or continue with</span>
                    <div class="lm-divider-line"></div>
                </div>

                <!-- Google -->
                <button class="lm-btn-google" type="button">
                    <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                    </svg>
                    <span>Google</span>
                </button>

                <p class="lm-signup-text">
                    Don't have an account? <a href="/register" class="lm-signup-link">Sign up</a>
                </p>

            </div>
        </div>
    </div>

</div>

<AccountModal Account="selectedAccount" OnClose="CloseModal" />

@code {
    private string email = "";
    private string password = "";
    private bool showPassword;
    private bool isLoading;
    private string? emailError;
    private string? passwordError;
    private string? globalError;

    private RecentAccount? selectedAccount;

    private readonly List<RecentAccount> recentAccounts =
    [
        new("Alex Johnson", "alex.johnson@email.com", "https://i.pravatar.cc/48?img=1"),
        new("Maria Chen",   "maria.chen@email.com",   "https://i.pravatar.cc/48?img=5"),
    ];

    private void OpenModal(RecentAccount account) => selectedAccount = account;
    private void CloseModal() => selectedAccount = null;
    private void TogglePassword() => showPassword = !showPassword;

    private async Task HandleLogin()
    {
        emailError = null;
        passwordError = null;
        globalError = null;

        if (string.IsNullOrWhiteSpace(email))
            emailError = "Email is required.";
        else if (!email.Contains('@'))
            emailError = "Please enter a valid email address.";

        if (string.IsNullOrWhiteSpace(password))
            passwordError = "Password is required.";

        if (emailError != null || passwordError != null)
            return;

        isLoading = true;
        StateHasChanged();

        await Task.Delay(1200); // TODO: replace with real auth service call

        isLoading = false;
        globalError = "Invalid email or password. Please try again.";
    }
}
