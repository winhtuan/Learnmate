@if (!string.IsNullOrEmpty(Password))
{
    <div class="lm-strength">
        <div class="lm-strength-header">
            <span class="lm-strength-label @ColorClass">@Label</span>
        </div>
        <div class="lm-strength-bars">
            @for (int i = 1; i <= 5; i++)
            {
                <div class="lm-strength-seg @(i <= Score ? SegColorClass : "")"></div>
            }
        </div>
        <div class="lm-requirements">
            @foreach (var (text, pass) in Checks)
            {
                <div class="lm-req @(pass ? "lm-req--pass" : "")">
                    @if (pass)
                    {
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                    }
                    else
                    {
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                        </svg>
                    }
                    <span>@text</span>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string Password { get; set; } = "";

    private bool HasLen     => Password.Length >= 8;
    private bool HasUpper   => Password.Any(char.IsUpper);
    private bool HasLower   => Password.Any(char.IsLower);
    private bool HasDigit   => Password.Any(char.IsDigit);
    private bool HasSpecial => Password.Any(c => !char.IsLetterOrDigit(c));

    private int Score =>
        (HasLen ? 1 : 0) + (HasUpper ? 1 : 0) + (HasLower ? 1 : 0) +
        (HasDigit ? 1 : 0) + (HasSpecial ? 1 : 0);

    private (string Text, bool Pass)[] Checks =>
    [
        ("8+ characters",     HasLen),
        ("Contains number",   HasDigit),
        ("Uppercase letter",  HasUpper),
        ("Special character", HasSpecial),
        ("Lowercase letter",  HasLower),
    ];

    private string Label => Score switch
    {
        0 or 1 => "Too weak",
        2      => "Weak",
        3      => "Fair",
        4      => "Strong",
        _      => "Very strong"
    };

    private string ColorClass => Score switch
    {
        0 or 1 => "lm-strength--tooweak",
        2      => "lm-strength--weak",
        3      => "lm-strength--fair",
        4      => "lm-strength--strong",
        _      => "lm-strength--verystrong"
    };

    private string SegColorClass => Score switch
    {
        0 or 1 => "lm-strength-seg--tooweak",
        2      => "lm-strength-seg--weak",
        3      => "lm-strength-seg--fair",
        4      => "lm-strength-seg--strong",
        _      => "lm-strength-seg--verystrong"
    };
}
