<article class="group relative flex flex-col items-center text-center bg-white rounded-2xl p-6 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-100">

    @* Avatar *@
    <div class="relative mb-4">
        <div class="w-20 h-20 rounded-full overflow-hidden ring-4 ring-white shadow-lg">
            <img alt="@Name"
                 class="w-full h-full object-cover object-top"
                 src="@ImageUrl" />
        </div>
    </div>

    @* Name + Rating *@
    <div class="mb-3">
        <h3 class="text-base font-bold text-slate-900 leading-tight">@Name</h3>
        <div class="flex items-center justify-center gap-1 mt-1">
            <span class="material-symbols-outlined text-yellow-400 text-sm" style="font-variation-settings:'FILL' 1; font-size:16px;">star</span>
            <span class="text-xs font-bold text-slate-700">@Rating</span>
            <span class="text-xs text-slate-400 font-normal">/ 5.0</span>
        </div>
    </div>

    @* Subject badge *@
    <span class="inline-block bg-primary/8 text-primary text-xs font-semibold px-3 py-1 rounded-full mb-4">
        @Subject
    </span>

    @* Price *@
    <div class="mb-5">
        <p class="text-xs text-slate-400 mb-0.5">Starting at</p>
        <p class="text-2xl font-black text-slate-900 leading-tight">
            $@Price<span class="text-sm font-normal text-slate-400">/hr</span>
        </p>
    </div>

    @* Book button *@
    <button class="w-full py-2.5 rounded-xl border-2 border-primary text-primary text-sm font-bold bg-transparent hover:bg-primary hover:text-white active:scale-[0.98] transition-all duration-200" style="">
        Book Lesson
    </button>

</article>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "";
    [Parameter, EditorRequired] public string Subject { get; set; } = "";
    [Parameter, EditorRequired] public string Rating { get; set; } = "";
    [Parameter, EditorRequired] public string Price { get; set; } = "";
    [Parameter, EditorRequired] public string ImageUrl { get; set; } = "";
}
