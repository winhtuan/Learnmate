@page "/admin/compliance"
@using LearnmateSolution.Components.Layout.Admin
@using BusinessLogicLayer.Services.Interfaces
@using BusinessLogicLayer.DTOs
@using BusinessObject.Enum
@layout AdminLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject UserSessionService Session
@inject ITeacherComplianceService ComplianceService
@inject ToastService ToastService
@inject IJSRuntime JS

<HeadContent>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
</HeadContent>

<div class="compliance-page">
    <main class="flex flex-col xl:flex-row gap-6">
        <!-- Main Content Area: List -->
        <div class="flex-1 flex flex-col">
            <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-slate-900">Teacher Verification Hub</h1>
                    <p class="text-slate-500 text-sm">Review credentials for high-trust certification status.</p>
                </div>
                <div class="flex gap-2">
                    <button class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-all">
                        <span class="material-symbols-outlined text-lg">filter_list</span> Filters
                    </button>
                    <button class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90 transition-all shadow-sm">
                        <span class="material-symbols-outlined text-lg">download</span> Export List
                    </button>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Pending Review</p>
                    <div class="mt-2 flex items-baseline gap-2">
                        <span class="text-3xl font-bold">@applications.Count(a => a.Status == ComplianceStatus.PENDING)</span>
                    </div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Approved</p>
                    <div class="mt-2 flex items-baseline gap-2">
                        <span class="text-3xl font-bold">@applications.Count(a => a.Status == ComplianceStatus.APPROVED)</span>
                    </div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Rejected</p>
                    <div class="mt-2 flex items-baseline gap-2">
                        <span class="text-3xl font-bold">@applications.Count(a => a.Status == ComplianceStatus.REJECTED)</span>
                    </div>
                </div>
            </div>

            <!-- Applications Table -->
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <table class="w-full text-left border-collapse m-0">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-200">
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Teacher</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Expertise</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Submitted</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var app in applications)
                        {
                            <tr class="group hover:bg-slate-50 transition-colors @(selectedApp?.UserId == app.UserId ? "bg-blue-50/50 ring-1 ring-inset ring-primary/10" : "")">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="h-10 w-10 overflow-hidden rounded-full border border-slate-200 bg-slate-100">
                                            <img alt="@app.FullName" src="@(string.IsNullOrEmpty(app.AvatarUrl) ? "/images/default-avatar.png" : app.AvatarUrl)" class="h-full w-full object-cover" />
                                        </div>
                                        <div>
                                            <div class="text-sm font-semibold text-slate-900">@app.FullName</div>
                                            <div class="text-xs text-slate-500">@app.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-700">@app.Subjects</span>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">@app.SubmittedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4">
                                    @{
                                        var statusClass = app.Status switch {
                                            ComplianceStatus.PENDING => "bg-amber-50 text-amber-700 border-amber-100",
                                            ComplianceStatus.APPROVED => "bg-green-50 text-green-700 border-green-100",
                                            ComplianceStatus.REJECTED => "bg-red-50 text-red-700 border-red-100",
                                            ComplianceStatus.INFO_REQUESTED => "bg-blue-50 text-blue-700 border-blue-100",
                                            _ => "bg-slate-50 text-slate-700 border-slate-100"
                                        };
                                        var dotClass = app.Status switch {
                                            ComplianceStatus.PENDING => "bg-amber-500",
                                            ComplianceStatus.APPROVED => "bg-green-500",
                                            ComplianceStatus.REJECTED => "bg-red-500",
                                            ComplianceStatus.INFO_REQUESTED => "bg-blue-500",
                                            _ => "bg-slate-500"
                                        };
                                    }
                                    <span class="inline-flex items-center gap-1.5 rounded-md @statusClass px-2 py-1 text-xs font-medium border">
                                        <span class="h-1.5 w-1.5 rounded-full @dotClass"></span> @app.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <button class="text-sm font-semibold text-primary hover:underline hover:text-primary/70 bg-transparent border-0 p-0" @onclick="() => SelectApplication(app)">Review Details</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Review Panel (Side Panel Layout) -->
        <div class="w-full xl:w-[420px]">
            <aside class="rounded-xl border border-slate-200 bg-white flex flex-col overflow-hidden shadow-lg xl:sticky xl:top-8 min-h-[600px]">
                @if (selectedApp != null)
                {
                    <div class="border-b border-slate-100 p-6 bg-white">
                        <div class="flex items-center justify-between mb-6">
                            <h3 class="text-lg font-bold text-slate-900">Review Application</h3>
                            <button class="text-slate-400 hover:text-slate-600 bg-transparent border-0 p-0" @onclick="() => selectedApp = null">
                                <span class="material-symbols-outlined">close</span>
                            </button>
                        </div>
                        <div class="flex flex-col items-center text-center">
                            <div class="relative mb-3">
                                <div class="h-24 w-24 overflow-hidden rounded-xl border-4 border-slate-50 shadow-sm bg-slate-100">
                                    <img alt="@selectedApp.FullName" src="@(string.IsNullOrEmpty(selectedApp.AvatarUrl) ? "/images/default-avatar.png" : selectedApp.AvatarUrl)" class="h-full w-full object-cover" />
                                </div>
                                <span class="absolute bottom-0 right-0 flex h-6 w-6 items-center justify-center rounded-full bg-primary text-white text-[10px] ring-2 ring-white">
                                    <span class="material-symbols-outlined text-xs">verified_user</span>
                                </span>
                            </div>
                            <h4 class="text-lg font-bold text-slate-900">@selectedApp.FullName</h4>
                            <div class="flex flex-wrap justify-center gap-2 my-3">
                                <span class="text-xs font-semibold px-2 py-1 bg-slate-100 rounded-lg text-slate-700">@selectedApp.HourlyRate $/hr</span>
                                <span class="text-xs font-semibold px-2 py-1 bg-blue-50 rounded-lg text-primary">@selectedApp.YearsOfExperience Years Exp</span>
                                <span class="text-xs font-semibold px-2 py-1 bg-slate-100 rounded-lg text-slate-700">Verified ID</span>
                            </div>
                            <p class="text-sm text-slate-500 mb-2 px-4 italic line-clamp-2">"@selectedApp.Bio"</p>
                        </div>
                    </div>
                    <div class="p-6 space-y-6 bg-white flex-1 overflow-y-auto">
                        <!-- Expertise Details -->
                        <section class="grid grid-cols-2 gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                            <div>
                                <h5 class="text-[10px] font-bold uppercase text-slate-400 mb-1">Languages</h5>
                                <p class="text-xs font-bold text-slate-700">@selectedApp.LanguagesSpoken</p>
                            </div>
                            <div>
                                <h5 class="text-[10px] font-bold uppercase text-slate-400 mb-1">Subjects</h5>
                                <p class="text-xs font-bold text-slate-700">@selectedApp.Subjects</p>
                            </div>
                            <div class="col-span-2 pt-2 border-t border-slate-200">
                                <h5 class="text-[10px] font-bold uppercase text-slate-400 mb-1">Teaching Philosophy</h5>
                                <p class="text-xs text-slate-600 leading-relaxed">@selectedApp.TeachingPhilosophy</p>
                            </div>
                        </section>
                        <!-- Documents Section -->
                        <section>
                            <h5 class="text-xs font-bold uppercase text-slate-400 tracking-wider mb-3">Verification Documents</h5>
                            <div class="space-y-2">
                                @foreach (var doc in selectedApp.Documents)
                                {
                                    <a href="@doc.FileUrl" target="_blank" class="flex w-full items-center justify-between rounded-lg border border-slate-200 p-3 bg-white hover:bg-slate-50 transition-colors text-left group no-underline">
                                        <div class="flex items-center gap-3">
                                            <div class="size-8 bg-primary/10 text-primary rounded-lg flex items-center justify-center shrink-0">
                                                <span class="material-symbols-outlined text-sm">@(doc.Category == "CV" ? "school" : doc.Category == "Certificate" ? "verified" : "badge")</span>
                                            </div>
                                            <div>
                                                <div class="text-xs font-bold text-slate-800">@doc.Category: @doc.Name</div>
                                                <div class="text-[9px] text-slate-400 uppercase">@doc.FileType • @(doc.FileSize / 1024) KB</div>
                                            </div>
                                        </div>
                                        <span class="material-symbols-outlined text-slate-300 group-hover:text-primary transition-colors text-sm">visibility</span>
                                    </a>
                                }
                            </div>
                        </section>
                        <!-- Notes Section -->
                        <section>
                            <h5 class="text-xs font-bold uppercase text-slate-400 tracking-wider mb-3">Internal Admin Notes</h5>
                            <textarea @bind="adminNotes" class="w-full rounded-lg border-slate-200 bg-slate-50 p-3 text-sm focus:border-primary focus:ring-primary placeholder:italic text-slate-700 h-24" placeholder="Add a private note for other admins..."></textarea>
                        </section>
                    </div>
                    <!-- Footer Actions -->
                    <div class="p-6 border-t border-slate-100 bg-slate-50/50">
                        @if (selectedApp.Status == ComplianceStatus.APPROVED || selectedApp.Status == ComplianceStatus.REJECTED)
                        {
                            <div class="p-4 rounded-xl @(selectedApp.Status == ComplianceStatus.APPROVED ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800") text-center">
                                <p class="text-sm font-bold flex items-center justify-center gap-2">
                                    <span class="material-symbols-outlined">@(selectedApp.Status == ComplianceStatus.APPROVED ? "verified" : "block")</span>
                                    Decision Finalized: @selectedApp.Status
                                </p>
                                <p class="text-[10px] mt-1 opacity-70">No further changes can be made to this application.</p>
                            </div>
                        }
                        else
                        {
                            <div class="flex flex-col gap-2">
                                <button @onclick="() => UpdateStatus(ComplianceStatus.APPROVED)" class="w-full flex items-center justify-center gap-2 rounded-lg bg-primary py-2.5 text-sm font-bold text-white shadow-md border-0 hover:bg-primary/90 transition-all">
                                    <span class="material-symbols-outlined text-lg">check_circle</span> Approve Application
                                </button>
                                <div class="grid grid-cols-2 gap-2">
                                    <button @onclick="() => UpdateStatus(ComplianceStatus.INFO_REQUESTED)" class="flex items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">
                                        <span class="material-symbols-outlined text-sm">info</span> Info Request
                                    </button>
                                    <button @onclick="() => UpdateStatus(ComplianceStatus.REJECTED)" class="flex items-center justify-center gap-2 rounded-lg border border-red-200 bg-red-50 py-2 text-xs font-semibold text-red-600 hover:bg-red-100">
                                        <span class="material-symbols-outlined text-sm">cancel</span> Reject
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="p-12 text-center flex flex-col items-center justify-center min-h-[400px] space-y-4">
                        <div class="h-20 w-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-200 dark:bg-slate-800">
                            <span class="material-symbols-outlined text-5xl">verified_user</span>
                        </div>
                        <div>
                            <h4 class="text-slate-900 font-bold dark:text-slate-100">No Selection</h4>
                            <p class="text-sm text-slate-500">Select an application from the list to review details and documentation.</p>
                        </div>
                    </div>
                }
            </aside>
        </div>
    </main>
</div>

<style>
    /* Prevent Bootstrap table conflicts */
    .compliance-page .table > :not(caption) > * > * {
        background-color: white !important;
        box-shadow: none !important;
        color: inherit !important;
    }
    .compliance-page .table thead tr {
        background-color: #f8fafc !important; /* slate-50 */
    }
    .compliance-page .table {
        border-color: transparent !important;
    }
    .compliance-page aside {
        background-color: white !important;
    }
    .compliance-page aside .p-6:not(.border-t) {
        background-color: white !important;
    }
    .compliance-page aside .p-6.border-t {
        background-color: #f8fafc !important;
    }
    /* Ensure primary buttons keep their color */
    .compliance-page button.bg-primary {
        background-color: #137fec !important;
        color: white !important;
    }
    .compliance-page textarea {
        background-color: #f8fafc !important;
    }
</style>

@code {
    private List<TeacherApplicationDto> applications = new();
    private TeacherApplicationDto? selectedApp;
    private string adminNotes = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!Session.IsAuthenticated)
        {
            var email = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
            var role  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
            if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
                Session.SetSession(email, role, token);
        }
        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login", replace: true); return; }
        if (Session.Role != "ADMIN") { Nav.NavigateTo(Session.Role == "STUDENT" ? "/student-dashboard" : "/", replace: true); return; }
        
        await LoadApplications();
    }

    private async Task LoadApplications()
    {
        applications = (await ComplianceService.GetAllApplicationsAsync()).ToList();
        selectedApp = applications.FirstOrDefault();
        adminNotes = selectedApp?.AdminNotes ?? "";
        StateHasChanged();
    }

    private void SelectApplication(TeacherApplicationDto app)
    {
        selectedApp = app;
        adminNotes = app.AdminNotes ?? "";
    }

    private async Task UpdateStatus(ComplianceStatus status)
    {
        if (selectedApp == null) return;
        
        var result = await ComplianceService.ReviewApplicationAsync(selectedApp.UserId, status, adminNotes);
        if (result.Success)
        {
            await LoadApplications();
            ToastService.ShowSuccess($"Successfully updated to {status}");
        }
        else
        {
            ToastService.ShowError(result.Message);
        }
    }
}
