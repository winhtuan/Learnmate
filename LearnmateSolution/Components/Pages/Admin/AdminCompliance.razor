@page "/admin/compliance"
@using LearnmateSolution.Components.Layout.Admin
@layout AdminLayout
@rendermode InteractiveServer

<HeadContent>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
</HeadContent>

<div class="compliance-page">
    <main class="flex flex-col xl:flex-row gap-6">
        <!-- Main Content Area: List -->
        <div class="flex-1 flex flex-col">
            <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-slate-900">Teacher Verification Hub</h1>
                    <p class="text-slate-500 text-sm">Review credentials for high-trust certification status.</p>
                </div>
                <div class="flex gap-2">
                    <button class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-all">
                        <span class="material-symbols-outlined text-lg">filter_list</span> Filters
                    </button>
                    <button class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90 transition-all shadow-sm">
                        <span class="material-symbols-outlined text-lg">download</span> Export List
                    </button>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Pending Review</p>
                    <div class="mt-2 flex items-baseline gap-2">
                        <span class="text-3xl font-bold">24</span>
                        <span class="text-xs font-semibold text-red-500 flex items-center">
                            <span class="material-symbols-outlined text-xs">arrow_upward</span> 12%
                        </span>
                    </div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">In Progress</p>
                    <div class="mt-2 flex items-baseline gap-2">
                        <span class="text-3xl font-bold">12</span>
                        <span class="text-xs font-semibold text-slate-400">Stable</span>
                    </div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Average TAT</p>
                    <div class="mt-2 flex items-baseline gap-2">
                        <span class="text-3xl font-bold">1.2d</span>
                        <span class="text-xs font-semibold text-green-500 flex items-center">
                            <span class="material-symbols-outlined text-xs">arrow_downward</span> 4%
                        </span>
                    </div>
                </div>
            </div>

            <!-- Applications Table -->
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                <table class="w-full text-left border-collapse m-0">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-200">
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Teacher</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Expertise</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Submitted</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var teacher in teachers)
                        {
                            <tr class="group hover:bg-slate-50 transition-colors @(selectedTeacher?.Id == teacher.Id ? "bg-blue-50/50 ring-1 ring-inset ring-primary/10" : "")">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="h-10 w-10 overflow-hidden rounded-full border border-slate-200 bg-slate-100">
                                            <img alt="@teacher.Name" src="@teacher.Avatar" class="h-full w-full object-cover" />
                                        </div>
                                        <div>
                                            <div class="text-sm font-semibold text-slate-900">@teacher.Name</div>
                                            <div class="text-xs text-slate-500">@teacher.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-700">@teacher.Expertise</span>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">@teacher.SubmittedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4">
                                    @{
                                        var statusClass = teacher.Status switch {
                                            "Pending Review" => "bg-amber-50 text-amber-700 border-amber-100",
                                            "In Progress" => "bg-blue-50 text-blue-700 border-blue-100",
                                            _ => "bg-slate-50 text-slate-700 border-slate-100"
                                        };
                                        var dotClass = teacher.Status switch {
                                            "Pending Review" => "bg-amber-500",
                                            "In Progress" => "bg-blue-500",
                                            _ => "bg-slate-500"
                                        };
                                    }
                                    <span class="inline-flex items-center gap-1.5 rounded-md @statusClass px-2 py-1 text-xs font-medium border">
                                        <span class="h-1.5 w-1.5 rounded-full @dotClass"></span> @teacher.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <button class="text-sm font-semibold text-primary hover:underline hover:text-primary/70 bg-transparent border-0 p-0" @onclick="() => SelectTeacher(teacher)">Review Details</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Review Panel (Side Panel Layout) -->
        <div class="w-full xl:w-[420px]">
            <aside class="rounded-xl border border-slate-200 bg-white flex flex-col overflow-hidden shadow-lg xl:sticky xl:top-8 min-h-[600px]">
                @if (selectedTeacher != null)
                {
                    <div class="border-b border-slate-100 p-6 bg-white">
                        <div class="flex items-center justify-between mb-6">
                            <h3 class="text-lg font-bold text-slate-900">Review Application</h3>
                            <button class="text-slate-400 hover:text-slate-600 bg-transparent border-0 p-0" @onclick="() => selectedTeacher = null">
                                <span class="material-symbols-outlined">close</span>
                            </button>
                        </div>
                        <div class="flex flex-col items-center text-center">
                            <div class="relative mb-3">
                                <div class="h-24 w-24 overflow-hidden rounded-xl border-4 border-slate-50 shadow-sm bg-slate-100">
                                    <img alt="@selectedTeacher.Name" src="@selectedTeacher.Avatar" class="h-full w-full object-cover" />
                                </div>
                                <span class="absolute bottom-0 right-0 flex h-6 w-6 items-center justify-center rounded-full bg-primary text-white text-[10px] ring-2 ring-white">
                                    <span class="material-symbols-outlined text-xs">verified_user</span>
                                </span>
                            </div>
                            <h4 class="text-lg font-bold text-slate-900">@selectedTeacher.Name</h4>
                            <p class="text-sm text-slate-500 mb-2">@selectedTeacher.Description</p>
                            <div class="flex gap-2">
                                <span class="text-xs font-semibold px-2 py-1 bg-slate-100 rounded-lg text-slate-700">@selectedTeacher.Degree</span>
                                <span class="text-xs font-semibold px-2 py-1 bg-slate-100 rounded-lg text-slate-700">Verified ID</span>
                            </div>
                        </div>
                    </div>
                    <div class="p-6 space-y-6 bg-white flex-1">
                        <!-- Documents Section -->
                        <section>
                            <h5 class="text-xs font-bold uppercase text-slate-400 tracking-wider mb-3">Verification Documents</h5>
                            <div class="space-y-2">
                                @foreach (var doc in selectedTeacher.Documents)
                                {
                                    <button class="flex w-full items-center justify-between rounded-lg border border-slate-200 p-3 bg-white hover:bg-slate-50 transition-colors text-left group">
                                        <div class="flex items-center gap-3">
                                            <span class="material-symbols-outlined text-primary">@doc.Icon</span>
                                            <div>
                                                <div class="text-sm font-semibold text-slate-700">@doc.Name</div>
                                                <div class="text-[10px] text-slate-400 uppercase">@doc.Type • @doc.Size</div>
                                            </div>
                                        </div>
                                        <span class="material-symbols-outlined text-slate-300 group-hover:text-primary transition-colors">visibility</span>
                                    </button>
                                }
                            </div>
                        </section>
                        <!-- Notes Section -->
                        <section>
                            <h5 class="text-xs font-bold uppercase text-slate-400 tracking-wider mb-3">Internal Admin Notes</h5>
                            <textarea class="w-full rounded-lg border-slate-200 bg-slate-50 p-3 text-sm focus:border-primary focus:ring-primary placeholder:italic text-slate-700 h-24" placeholder="Add a private note for other admins..."></textarea>
                        </section>
                    </div>
                    <!-- Footer Actions -->
                    <div class="p-6 border-t border-slate-100 bg-slate-50/50">
                        <div class="flex flex-col gap-2">
                            <button class="w-full flex items-center justify-center gap-2 rounded-lg bg-primary py-2.5 text-sm font-bold text-white shadow-md border-0 hover:bg-primary/90 transition-all">
                                <span class="material-symbols-outlined text-lg">check_circle</span> Approve Application
                            </button>
                            <div class="grid grid-cols-2 gap-2">
                                <button class="flex items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">
                                    <span class="material-symbols-outlined text-sm">info</span> Info Request
                                </button>
                                <button class="flex items-center justify-center gap-2 rounded-lg border border-red-200 bg-red-50 py-2 text-xs font-semibold text-red-600 hover:bg-red-100">
                                    <span class="material-symbols-outlined text-sm">cancel</span> Reject
                                </button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="p-12 text-center flex flex-col items-center justify-center min-h-[400px] space-y-4">
                        <div class="h-20 w-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-200 dark:bg-slate-800">
                            <span class="material-symbols-outlined text-5xl">verified_user</span>
                        </div>
                        <div>
                            <h4 class="text-slate-900 font-bold dark:text-slate-100">No Selection</h4>
                            <p class="text-sm text-slate-500">Select an application from the list to review details and documentation.</p>
                        </div>
                    </div>
                }
            </aside>
        </div>
    </main>
</div>

<style>
    /* Prevent Bootstrap table conflicts */
    .compliance-page .table > :not(caption) > * > * {
        background-color: white !important;
        box-shadow: none !important;
        color: inherit !important;
    }
    .compliance-page .table thead tr {
        background-color: #f8fafc !important; /* slate-50 */
    }
    .compliance-page .table {
        border-color: transparent !important;
    }
    .compliance-page aside {
        background-color: white !important;
    }
    .compliance-page aside .p-6:not(.border-t) {
        background-color: white !important;
    }
    .compliance-page aside .p-6.border-t {
        background-color: #f8fafc !important;
    }
    /* Ensure primary buttons keep their color */
    .compliance-page button.bg-primary {
        background-color: #137fec !important;
        color: white !important;
    }
    .compliance-page textarea {
        background-color: #f8fafc !important;
    }
</style>

