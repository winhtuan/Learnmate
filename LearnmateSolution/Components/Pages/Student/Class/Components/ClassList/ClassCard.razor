@using LearnmateSolution.Components.Pages.Student.Class.Models
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject UserSessionService Session

<article class="group relative flex flex-col bg-white rounded-2xl p-4 shadow-sm hover:shadow-md transition-all duration-300 border border-slate-200 @(Class.IsUpcoming ? "opacity-60 hover:opacity-100 grayscale hover:grayscale-0" : "")">

    @* Image *@
    <div class="h-44 w-full rounded-xl bg-cover bg-center relative overflow-hidden mb-4"
         style="background-image: url('@Class.Image')">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>

        @* Code badge *@
        <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider text-slate-800 shadow-sm">
            @Class.Code
        </div>

        @* Professor name *@
        <div class="absolute bottom-4 left-4 right-4 text-white">
            <p class="text-sm font-medium opacity-90">@Class.Professor</p>
        </div>

        @* Warning badge *@
        @if (Class.HasWarning)
        {
            <div class="absolute top-4 right-4 bg-rose-500 text-white px-3 py-1 rounded-full text-xs font-bold shadow-lg shadow-rose-500/30 flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">warning</span>
                <span>Due Tomorrow</span>
            </div>
        }

        @* Upcoming overlay *@
        @if (Class.IsUpcoming)
        {
            <div class="absolute inset-0 flex items-center justify-center bg-black/10 backdrop-blur-[1px]">
                <span class="bg-black/50 text-white px-3 py-1 rounded-full text-xs backdrop-blur-md">Upcoming Term</span>
            </div>
        }
    </div>

    @* Content *@
    <div class="px-2 flex flex-col flex-1">
        <div class="flex justify-between items-start mb-2">
            <a href="/classes/@Class.Id" class="no-underline">
                <h3 class="text-xl font-bold text-slate-900 group-hover:text-primary transition-colors cursor-pointer">
                    @Class.Title
                </h3>
            </a>

            @* Dropdown trigger *@
            <div class="relative">
                <button @onclick="ToggleMenu" @onclick:stopPropagation="true"
                        class="size-8 flex items-center justify-center rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors border-0 outline-none">
                    <span class="material-symbols-outlined text-[20px]">more_horiz</span>
                </button>

                @if (isMenuOpen)
                {
                    <div class="fixed inset-0 z-10" @onclick="CloseMenu"></div>
                    <div class="absolute right-0 top-8 z-20 py-1 min-w-[180px]"
                         style="background:#f8fafc; border:2px solid #e2e8f0; border-radius:8px; box-shadow:0 1px 4px rgba(0,0,0,.08);"
                         @onclick:stopPropagation="true">
                        <button @onclick="OpenClass"
                                class="w-full px-4 py-2.5 text-left text-sm text-slate-700 hover:bg-slate-100 flex items-center gap-3 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">open_in_new</span>
                            Open Class
                        </button>
                        <button @onclick="OpenLeaveModal"
                                class="w-full px-4 py-2.5 text-left text-sm text-rose-600 hover:bg-rose-50 flex items-center gap-3 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">logout</span>
                            Leave Class
                        </button>
                    </div>
                }
            </div>
        </div>

        <p class="text-slate-500 text-sm mb-6 line-clamp-2">@Class.Description</p>

        <div class="mt-auto">
            @if (Class.NextClass is not null)
            {
                <div class="flex items-center gap-3 bg-slate-50 p-3 rounded-xl border border-slate-100">
                    <span class="material-symbols-outlined text-primary text-[20px]">calendar_month</span>
                    <div class="text-sm">
                        <span class="text-slate-500 font-medium">Next:</span>
                        <span class="text-slate-900 font-bold ml-1">@Class.NextClass</span>
                    </div>
                </div>
                <div class="mt-4 flex gap-3">
                    @if (Class.ButtonText is not null)
                    {
                        <button @onclick="OpenClass"
                                class="flex-1 py-2.5 rounded-xl font-semibold text-sm transition-colors @(Class.ButtonText == "Submit Task" ? "bg-white text-slate-700 border border-slate-200 hover:bg-slate-50" : "bg-slate-900 text-white hover:bg-slate-800")">
                            @Class.ButtonText
                        </button>
                    }
                    <button class="w-10 py-2.5 flex items-center justify-center rounded-xl text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors border-0 outline-none">
                        <span class="material-symbols-outlined">folder_open</span>
                    </button>
                </div>
            }
            else
            {
                <div class="w-full flex items-center justify-center py-4 text-slate-400 text-sm font-medium bg-slate-50 rounded-2xl border border-dashed border-slate-300">
                    Course Starts in 14 days
                </div>
            }
        </div>
    </div>
</article>

<LeaveClassModal IsOpen="isLeaveModalOpen"
                 ClassName="@Class.Title"
                 OnClose="EventCallback.Factory.Create(this, CloseLeaveModal)"
                 OnConfirm="EventCallback.Factory.Create(this, ConfirmLeaveAsync)" />

@code {
    [Parameter] public ClassItem Class { get; set; } = null!;
    [Parameter] public EventCallback<long> OnLeaved { get; set; }

    private bool isMenuOpen;
    private bool isLeaveModalOpen;
    private bool _leaving;

    private void ToggleMenu() => isMenuOpen = !isMenuOpen;
    private void CloseMenu() => isMenuOpen = false;

    private void OpenClass()
    {
        isMenuOpen = false;
        Nav.NavigateTo($"/classes/{Class.Id}");
    }

    private void OpenLeaveModal()
    {
        isMenuOpen = false;
        isLeaveModalOpen = true;
    }

    private void CloseLeaveModal() => isLeaveModalOpen = false;

    private async Task ConfirmLeaveAsync()
    {
        isLeaveModalOpen = false;
        _leaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("learnmate");
            client.BaseAddress = new Uri(Nav.BaseUri);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);

            var resp = await client.DeleteAsync($"api/classes/{Class.Id}/members/me");
            if (resp.IsSuccessStatusCode)
                await OnLeaved.InvokeAsync(Class.Id);
        }
        catch { }
        finally
        {
            _leaving = false;
        }
    }
}
