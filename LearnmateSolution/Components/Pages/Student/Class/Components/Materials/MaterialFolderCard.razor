@using LearnmateSolution.Components.Pages.Student.Class.Models

<div class="group p-5 bg-slate-50 rounded-2xl border border-slate-100 hover:border-primary/30 hover:shadow-md transition-all cursor-pointer">
    <div class="flex items-start justify-between mb-3">
        <div class="size-12 rounded-xl @Folder.IconBg @Folder.IconColor flex items-center justify-center">
            <span class="material-symbols-outlined text-[28px]">@Folder.Icon</span>
        </div>
        <button class="text-slate-400 hover:text-primary transition-colors p-1.5 hover:bg-white rounded-lg" title="Download Folder">
            <span class="material-symbols-outlined text-[20px]">cloud_download</span>
        </button>
    </div>
    <h4 class="text-lg font-bold text-slate-900 mb-1 group-hover:text-primary transition-colors">@Folder.Name</h4>
    <p class="text-sm text-slate-500">@Folder.FileCount files • @Folder.Size</p>
</div>

@code {
    [Parameter] public MaterialFolder Folder { get; set; } = null!;
}
