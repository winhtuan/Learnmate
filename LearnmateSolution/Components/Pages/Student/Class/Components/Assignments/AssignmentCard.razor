@using LearnmateSolution.Components.Pages.Student.Class.Models

<div class="bg-white p-4 rounded-2xl border @(Assignment.Highlighted ? "border-2 border-primary shadow-lg shadow-primary/5" : "border-slate-200 hover:border-slate-300") cursor-pointer flex flex-col sm:flex-row sm:items-center justify-between gap-4 relative overflow-hidden group transition-all @(Assignment.Completed ? "opacity-60 hover:opacity-100" : Assignment.Locked ? "opacity-90 hover:opacity-100" : "")">

    @if (Assignment.Highlighted)
    {
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary rounded-l-2xl"></div>
    }

    <div class="flex items-center gap-4 @(Assignment.Highlighted ? "pl-2" : "")">
        <div class="size-12 rounded-xl @Assignment.IconBg @Assignment.IconColor flex items-center justify-center shrink-0 border @IconBorderClass">
            <span class="material-symbols-outlined">@Assignment.Icon</span>
        </div>
        <div>
            <h4 class="font-bold text-slate-900 text-lg leading-tight @(Assignment.Completed ? "line-through decoration-slate-400" : "group-hover:text-primary") transition-colors">
                @Assignment.Title
            </h4>
            <p class="text-sm text-slate-500 mt-1">@Assignment.Metadata</p>
        </div>
    </div>

    <div class="flex items-center justify-between sm:justify-end gap-6 sm:pl-0 pl-2">
        <div class="text-left sm:text-right">
            <span class="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wide">@Assignment.DueLabel</span>
            <span class="font-semibold text-sm @Assignment.DueColor">@Assignment.Due</span>
        </div>
        <span class="inline-flex items-center px-2.5 py-1 rounded-lg @Assignment.StatusBg @Assignment.StatusColor text-xs font-bold border @StatusBorderClass">
            @Assignment.Status
        </span>
    </div>
</div>

@code {
    [Parameter] public AssignmentItem Assignment { get; set; } = null!;

    private string IconBorderClass => Assignment.IconBg switch
    {
        var s when s.Contains("blue")    => "border-blue-100",
        var s when s.Contains("purple")  => "border-purple-100",
        var s when s.Contains("rose")    => "border-rose-100",
        var s when s.Contains("emerald") => "border-emerald-100",
        _                                => "border-slate-100",
    };

    private string StatusBorderClass => Assignment.StatusBg switch
    {
        var s when s.Contains("amber")   => "border-amber-200",
        var s when s.Contains("rose")    => "border-rose-200",
        var s when s.Contains("emerald") => "border-emerald-200",
        _                                => "border-slate-200",
    };
}
