@page "/classes/{Id:long}/assignments"
@layout ClassLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Student.Class.Components
@using LearnmateSolution.Components.Pages.Student.Class.Models
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Class
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<div class="space-y-6 max-w-screen-xl mx-auto">
    <Breadcrumb Items="@([ new("Dashboard", "/student-dashboard"), new("My Classes", "/classes"), new(_className, $"/classes/{Id}"), new("Assignments") ])" />

    @if (!_ready)
    {
        <div class="flex items-center justify-center h-64 text-slate-400">
            <svg class="animate-spin h-8 w-8 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span class="text-sm font-medium">Loading...</span>
        </div>
    }
    else
    {
        <HeroBanner ClassCode="@_subject" ClassStatus="@_status" ClassName="@_className"
                    Description="@_description" BackgroundImage="" />

        <ClassTabNav ClassId="@Id" ActiveTab="assignments" AssignmentCount="@(_upcoming.Count + _missing.Count + _completed.Count)" />

        <div class="grid grid-cols-1 xl:grid-cols-5 gap-6">
            @* Left: Assignment list *@
            <div class="xl:col-span-3 space-y-6">
                @if (_upcoming.Count > 0)
                {
                    <div>
                        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Upcoming</h3>
                        <div class="space-y-3">
                            @foreach (var asg in _upcoming)
                            {
                                <div @onclick="() => selectedAssignment = asg" class="cursor-pointer">
                                    <AssignmentCard Assignment="@MapToCard(asg)" />
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (_missing.Count > 0)
                {
                    <div>
                        <h3 class="text-xs font-bold text-rose-400 uppercase tracking-wider mb-3">Missing</h3>
                        <div class="space-y-3">
                            @foreach (var asg in _missing)
                            {
                                <div @onclick="() => selectedAssignment = asg" class="cursor-pointer">
                                    <AssignmentCard Assignment="@MapToCard(asg)" />
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (_completed.Count > 0)
                {
                    <div>
                        <h3 class="text-xs font-bold text-emerald-500 uppercase tracking-wider mb-3">Completed</h3>
                        <div class="space-y-3">
                            @foreach (var asg in _completed)
                            {
                                <div @onclick="() => selectedAssignment = asg" class="cursor-pointer">
                                    <AssignmentCard Assignment="@MapToCard(asg)" />
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (_upcoming.Count == 0 && _missing.Count == 0 && _completed.Count == 0)
                {
                    <div class="flex flex-col items-center justify-center py-16 text-slate-400">
                        <span class="material-symbols-outlined text-5xl mb-3">assignment</span>
                        <p class="text-base font-medium">No assignments yet.</p>
                    </div>
                }
            </div>

            @* Right: Detail panel *@
            <div class="xl:col-span-2">
                @if (selectedAssignment is not null)
                {
                    <AssignmentDetailPanel Assignment="@MapToDetail(selectedAssignment)"
                                          OnSubmitted="@HandleSubmitted"
                                          OnClose="@(() => { selectedAssignment = null; })" />
                }
                else
                {
                    <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm p-10 flex flex-col items-center justify-center text-center h-full min-h-[300px]">
                        <span class="material-symbols-outlined text-slate-200 text-[64px] mb-4">assignment</span>
                        <p class="text-slate-400 font-medium">Select an assignment to view details</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public long Id { get; set; }

    private bool _ready;
    private string _className   = "Class";
    private string _subject     = "";
    private string _status      = "ACTIVE";
    private string _description = "";

    private List<ClassAssignmentDto> _upcoming  = [];
    private List<ClassAssignmentDto> _missing   = [];
    private List<ClassAssignmentDto> _completed = [];

    private ClassAssignmentDto? selectedAssignment;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Session.IsAuthenticated)
        {
            var email = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
            var role  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
            if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
                Session.SetSession(email, role, token);
        }

        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login", replace: true); return; }
        if (Session.Role != "STUDENT") { Nav.NavigateTo(Session.Role == "ADMIN" ? "/admin/dashboard" : "/", replace: true); return; }

        await LoadAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("learnmate");
            client.BaseAddress = new Uri(Nav.BaseUri);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);

            var classTask = client.GetFromJsonAsync<ApiResponse<ClassDetailDto>>($"api/classes/{Id}");
            var asgTask   = client.GetFromJsonAsync<ApiResponse<List<ClassAssignmentDto>>>($"api/classes/{Id}/assignments");
            await Task.WhenAll(classTask, asgTask);

            var cls = classTask.Result?.Data;
            if (cls is not null)
            {
                _className   = cls.Name;
                _subject     = cls.Subject;
                _status      = cls.Status;
                _description = cls.Description ?? "";
            }

            var assignments = asgTask.Result?.Data ?? [];

            _upcoming  = assignments.Where(a => a.SubmissionStatus is "not_started" or "in_progress").ToList();
            _missing   = assignments.Where(a => a.SubmissionStatus == "missing").ToList();
            _completed = assignments.Where(a => a.SubmissionStatus is "submitted" or "graded").ToList();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Session.Clear();
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_email");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_role");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_token");
            Nav.NavigateTo("/login", replace: true);
        }
        catch
        {
            // Keep defaults on error
        }
    }

    private static AssignmentItem MapToCard(ClassAssignmentDto a) =>
        ClassPageHelpers.MapAssignment(a);

    private AssignmentDetail MapToDetail(ClassAssignmentDto a)
    {
        var dueLabel = a.DueDateLocal is { } d ? d.ToString("MMMM d, yyyy 'at' h:mm tt") : "No due date";

        string? feedbackScoreDisplay = null;
        if (a.FeedbackScore is { } fs)
            feedbackScoreDisplay = a.TotalPoints is { } tp
                ? $"{fs:0.#} / {tp:0.#} pts"
                : $"{fs:0.#} pts";

        var resources = new List<AssignmentResource>();
        if (!string.IsNullOrEmpty(a.FileUrl))
        {
            resources.Add(new AssignmentResource(
                Id: a.Id,
                Title: "Đề bài - " + a.Title,
                Size: "Download",
                Icon: "description",
                IconBg: "bg-blue-50",
                IconColor: "text-blue-500",
                Href: a.FileUrl
            ));
        }

        return new AssignmentDetail(
            Id:                   a.Id,
            ClassId:              Id,
            Title:                a.Title,
            Type:                 "Assignment",
            DueDate:              dueLabel,
            Points:               a.TotalPoints is { } tpts ? $"{tpts:0.#} pts" : "",
            SubmissionStatus:     a.SubmissionStatus,
            Instructions:         new AssignmentInstructions(
                Text:  a.Description ?? "No description provided.",
                Items: []
            ),
            Resources:            resources,
            UploadText:           "Upload your submission",
            UploadSubtext:        "PDF, DOCX, or ZIP up to 50 MB",
            FeedbackComment:      a.FeedbackComment,
            FeedbackScoreDisplay: feedbackScoreDisplay
        );
    }

    private async Task HandleSubmitted()
    {
        // Move selected assignment from upcoming/missing → completed
        if (selectedAssignment is null) return;
        var updated = selectedAssignment with { SubmissionStatus = "submitted" };
        _upcoming.RemoveAll(a => a.Id == updated.Id);
        _missing.RemoveAll(a => a.Id == updated.Id);
        _completed.Add(updated);
        selectedAssignment = updated;
        StateHasChanged();
    }
}
