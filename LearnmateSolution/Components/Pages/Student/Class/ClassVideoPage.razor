@page "/classes/{Id:long}/videos"
@layout ClassLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Student.Class.Components
@using LearnmateSolution.Components.Pages.Student.Class.Models
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Class
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<div class="space-y-6 max-w-screen-xl mx-auto">
    <Breadcrumb Items="@([ new("Dashboard", "/student-dashboard"), new("My Classes", "/classes"), new(_className, $"/classes/{Id}"), new("Videos") ])" />

    @if (!_ready)
    {
        <div class="flex items-center justify-center h-64 text-slate-400">
            <svg class="animate-spin h-8 w-8 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span class="text-sm font-medium">Loading...</span>
        </div>
    }
    else
    {
        <HeroBanner ClassCode="@_subject" ClassStatus="@_status" ClassName="@_className"
                    Description="@_description" BackgroundImage="" />

        <ClassTabNav ClassId="@Id" ActiveTab="videos" />

        @* Live Session *@
        @if (_liveSession is not null)
        {
            <LiveSessionCard Session="@_liveSession" />
        }

        @* Recorded Videos *@
        @if (_recorded.Count > 0)
        {
            <div>
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Recorded Lectures</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    @foreach (var lecture in _recorded)
                    {
                        <VideoLectureCard Lecture="@lecture" />
                    }
                </div>
            </div>
        }

        @if (_liveSession is null && _recorded.Count == 0)
        {
            <div class="flex flex-col items-center justify-center py-20 bg-white rounded-[2rem] border border-slate-100 shadow-sm text-slate-400">
                <span class="material-symbols-outlined text-5xl mb-3">videocam_off</span>
                <p class="text-base font-medium">No recorded lectures available yet.</p>
            </div>
        }
    }
</div>

@code {
    [Parameter] public long Id { get; set; }

    private bool _ready;
    private string _className   = "Class";
    private string _subject     = "";
    private string _status      = "ACTIVE";
    private string _description = "";

    private LiveSession? _liveSession;
    private List<VideoLecture> _recorded = [];

    private static readonly string[][] _gradients =
    [
        ["from-blue-900",    "to-blue-700",    "from-blue-400"],
        ["from-purple-900",  "to-purple-700",  "from-purple-400"],
        ["from-emerald-900", "to-emerald-700", "from-emerald-400"],
        ["from-rose-900",    "to-rose-700",    "from-rose-400"],
        ["from-amber-900",   "to-amber-700",   "from-amber-400"],
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Session.IsAuthenticated)
        {
            var email = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
            var role  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
            if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
                Session.SetSession(email, role, token);
        }

        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login", replace: true); return; }
        if (Session.Role != "STUDENT") { Nav.NavigateTo(Session.Role == "ADMIN" ? "/admin/dashboard" : "/", replace: true); return; }

        await LoadAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("learnmate");
            client.BaseAddress = new Uri(Nav.BaseUri);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);

            var classTask = client.GetFromJsonAsync<ApiResponse<ClassDetailDto>>($"api/classes/{Id}");
            var vidTask   = client.GetFromJsonAsync<ApiResponse<ClassVideosDto>>($"api/classes/{Id}/videos");
            await Task.WhenAll(classTask, vidTask);

            var cls = classTask.Result?.Data;
            if (cls is not null)
            {
                _className   = cls.Name;
                _subject     = cls.Subject;
                _status      = cls.Status;
                _description = cls.Description ?? "";
            }

            var videos = vidTask.Result?.Data;
            if (videos is not null)
            {
                if (videos.LiveSession is { } live)
                {
                    _liveSession = new LiveSession(
                        Status:         "LIVE",
                        Date:           live.StartTimeLocal.ToString("ddd, MMM d · h:mm tt"),
                        Title:          live.Title,
                        Description:    $"Join via {live.Provider}",
                        Host:           new LiveSessionHost("", ""),
                        StudentsWaiting: 0,
                        MeetingUrl:     live.MeetingUrl
                    );
                }

                _recorded = videos.RecordedSessions
                    .Select((v, i) =>
                    {
                        var g = _gradients[i % _gradients.Length];
                        var dur = v.EndTimeLocal is { } end
                            ? $"{(end - v.StartTimeLocal).TotalMinutes:F0} min"
                            : "—";
                        return new VideoLecture(
                            Id:            v.Id,
                            Title:         v.Title,
                            Duration:      dur,
                            Date:          v.StartTimeLocal.ToString("MMM d, yyyy"),
                            Unit:          v.Provider,
                            MeetingUrl:    v.MeetingUrl,
                            GradientFrom:  g[0],
                            GradientTo:    g[1],
                            AccentGradient: g[2]
                        );
                    })
                    .ToList();
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Session.Clear();
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_email");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_role");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_token");
            Nav.NavigateTo("/login", replace: true);
        }
        catch { }
    }
}
