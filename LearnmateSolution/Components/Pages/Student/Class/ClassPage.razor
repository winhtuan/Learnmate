@page "/classes"
@layout ClassLayout
@rendermode InteractiveServer
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Student.Class.Components
@using LearnmateSolution.Components.Pages.Student.Class.Models
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Class
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<PageTitle>My Classes - LearnMate</PageTitle>

<div class="space-y-8 max-w-screen-xl mx-auto">
    <h1 class="sr-only" tabindex="-1">My Classes</h1>
    <Breadcrumb Items="@([ new("Dashboard", "/student-dashboard"), new("My Classes") ])" />

    <ClassFilterTabs ActiveTab="@activeTab" OnTabChange="@(tab => { activeTab = tab; RebuildFiltered(); })"
                     SearchQuery="@searchQuery" OnSearchChange="@(q => { searchQuery = q; RebuildFiltered(); })" />

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 items-start min-h-[400px]">
        @if (!_ready)
        {
            <div class="col-span-full flex items-center justify-center py-20 text-slate-400">
                <svg class="animate-spin h-8 w-8 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <span class="text-sm font-medium">Loading classes...</span>
            </div>
        }
        else
        {
            @foreach (var cls in _filtered)
            {
                <ClassCard Class="cls" OnLeaved="@HandleLeaved" />
            }
            @if (_filtered.Count == 0)
            {
                <div class="col-span-full flex flex-col items-center justify-center py-20 text-slate-400">
                    <span class="material-symbols-outlined text-5xl mb-3">search_off</span>
                    <p class="text-base font-medium">No classes found</p>
                </div>
            }
        }
    </div>
</div>

@code {
    private bool _ready;
    private string activeTab = "all";
    private string searchQuery = "";
    private List<ClassItem> _classes = [];
    private List<ClassItem> _filtered = [];

    private void RebuildFiltered() =>
        _filtered = _classes
            .Where(c => activeTab == "all"
                || (activeTab == "active"   && !c.IsUpcoming)
                || (activeTab == "upcoming" &&  c.IsUpcoming))
            .Where(c => string.IsNullOrEmpty(searchQuery)
                || c.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
                || c.Code.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
            .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Session.IsAuthenticated)
        {
            var email = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
            var role  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
            if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
                Session.SetSession(email, role, token);
        }

        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login", replace: true); return; }
        if (Session.Role != "STUDENT") { Nav.NavigateTo(Session.Role == "ADMIN" ? "/admin/dashboard" : "/", replace: true); return; }

        await LoadClassesAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task LoadClassesAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("learnmate");
            client.BaseAddress = new Uri(Nav.BaseUri);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);

            var resp = await client.GetFromJsonAsync<ApiResponse<List<ClassListItemDto>>>("api/classes");
            var data = resp?.Data;
            if (data is null) return;

            _classes = data.Select(MapToClassItem).ToList();
            RebuildFiltered();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Session.Clear();
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_email");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_role");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "lm_token");
            Nav.NavigateTo("/login", replace: true);
        }
        catch
        {
            // Keep empty list on error
        }
    }

    private static ClassItem MapToClassItem(ClassListItemDto dto)
    {
        var isUpcoming = dto.Status != "ACTIVE";
        var nextClass  = dto.NextSessionLocal is { } t ? FormatNextSession(t) : null;

        return new ClassItem(
            Id:          dto.Id,
            Code:        dto.Subject,
            Title:       dto.Name,
            Professor:   dto.TeacherName,
            Description: dto.Description ?? "",
            NextClass:   nextClass,
            Image:       null,
            ButtonText:  isUpcoming ? null : "Open Class",
            IsUpcoming:  isUpcoming
        );
    }

    private void HandleLeaved(long classId)
    {
        _classes.RemoveAll(c => c.Id == classId);
        RebuildFiltered();
    }

    private static string FormatNextSession(DateTime local)
    {
        var today = DateTime.Today;
        var diff  = (local.Date - today).Days;
        var time  = local.ToString("h:mm tt");
        return diff switch
        {
            0  => $"Today, {time}",
            1  => $"Tomorrow, {time}",
            _  => $"{local:ddd, MMM d}, {time}"
        };
    }
}
