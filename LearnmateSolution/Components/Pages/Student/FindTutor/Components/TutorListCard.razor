@using LearnmateSolution.Components.Pages.Student.FindTutor.Models

<div class="group flex gap-5 bg-white rounded-2xl border @(IsSelected ? "border-indigo-500 shadow-md shadow-indigo-100" : "border-slate-200 hover:border-indigo-200 hover:shadow-sm") transition-all duration-150 p-5 cursor-pointer"
     @onclick="() => OnSelected.InvokeAsync(Tutor)">

    <!-- Left: Avatar + Rating -->
    <div class="flex flex-col items-center gap-1.5 shrink-0 w-16">
        <div class="relative">
            <div class="size-16 rounded-full bg-indigo-100 bg-cover bg-center ring-2 @(IsSelected ? "ring-indigo-400" : "ring-slate-100") @(Tutor.Availability == AvailabilityStatus.FullyBooked ? "grayscale opacity-60" : "")"
                 style="background-image: url('@Tutor.AvatarUrl')">
            </div>
            @if (Tutor.IsVerified)
            {
                <div class="absolute -bottom-0.5 -right-0.5 bg-white rounded-full p-0.5" title="Verified Tutor">
                    <span class="material-symbols-outlined text-indigo-500 text-[14px]" style="font-variation-settings:'FILL' 1">verified</span>
                </div>
            }
        </div>
        <div class="flex items-center gap-0.5">
            <span class="material-symbols-outlined text-amber-400 text-[14px]" style="font-variation-settings:'FILL' 1">star</span>
            <span class="text-xs font-bold text-slate-800">@Tutor.Rating.ToString("0.0")</span>
        </div>
        <span class="text-[11px] text-slate-400 leading-none">(@Tutor.ReviewCount)</span>
    </div>

    <!-- Center: Info -->
    <div class="flex flex-col flex-1 gap-2 min-w-0">
        <div>
            <h3 class="text-base font-semibold text-slate-900 leading-snug">@Tutor.Name</h3>
            <p class="text-xs text-slate-400 mt-0.5 flex items-center gap-1">
                <span class="material-symbols-outlined text-[12px]">location_on</span>
                @Tutor.Location
            </p>
        </div>

        <div class="flex flex-wrap gap-1.5">
            @foreach (var subject in Tutor.Subjects)
            {
                <span class="px-2 py-0.5 text-xs bg-indigo-50 text-indigo-700 rounded-md font-medium border border-indigo-100">@subject</span>
            }
        </div>

        <p class="text-sm text-slate-500 line-clamp-2 leading-relaxed">@Tutor.Bio</p>

        @{ var (badgeText, badgeCss) = AvailabilityBadge(Tutor.Availability, Tutor.AvailabilityLabel); }
        <span class="self-start text-xs px-2 py-0.5 rounded-md font-medium @badgeCss">@badgeText</span>
    </div>

    <!-- Right: Price + Actions -->
    <div class="flex flex-col items-end justify-between shrink-0 pl-4 border-l border-slate-100 min-w-[120px]">
        <div class="flex flex-col items-end gap-1.5">
            @if (Tutor.IsSuperTutor)
            {
                <div class="bg-amber-50 text-amber-700 text-[11px] font-bold px-2.5 py-1 rounded-md flex items-center gap-1 border border-amber-200">
                    <span class="material-symbols-outlined text-[13px]" style="font-variation-settings:'FILL' 1">bolt</span>
                    Super Tutor
                </div>
            }
            <p class="text-2xl font-bold text-indigo-600 leading-none">
                $@Tutor.HourlyRate.ToString("0")<span class="text-xs font-normal text-slate-400">/hr</span>
            </p>
        </div>
        <div class="flex flex-col gap-2 w-full mt-4">
            <button class="w-full bg-indigo-600 text-white text-sm font-semibold px-3 py-2 rounded-xl hover:bg-indigo-700 transition-colors shadow-sm shadow-indigo-200"
                    @onclick:stopPropagation
                    @onclick="() => OnSelected.InvokeAsync(Tutor)">
                Book
            </button>
            <button class="w-full border border-slate-200 text-slate-700 text-sm font-medium px-3 py-2 rounded-xl hover:bg-indigo-50 hover:border-indigo-200 hover:text-indigo-700 transition-colors"
                    @onclick:stopPropagation
                    @onclick="() => OnSelected.InvokeAsync(Tutor)">
                View Profile
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public TutorListItem Tutor { get; set; } = null!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback<TutorListItem> OnSelected { get; set; }

    private static (string text, string css) AvailabilityBadge(AvailabilityStatus status, string? label) => status switch
    {
        AvailabilityStatus.AvailableToday => ("Available Today", "bg-emerald-50 text-emerald-700 border border-emerald-200"),
        AvailabilityStatus.FullyBooked    => ("Fully Booked",    "bg-slate-100 text-slate-500"),
        _                                 => (label ?? "Has Slots", "bg-violet-50 text-violet-700 border border-violet-200"),
    };
}
