@using LearnmateSolution.Components.Pages.Student.FindTutor.Models

@if (Tutor is null)
{
    <div class="flex flex-col items-center justify-center h-64 gap-3">
        <span class="material-symbols-outlined text-5xl text-[#D6D6D4]">person_search</span>
        <p class="text-sm font-medium text-[#787774]">Select a tutor to see details</p>
    </div>
}
else
{
    <!-- Header -->
    <div class="flex flex-col items-center text-center gap-2">
        <div class="relative">
            <div class="size-24 rounded-full bg-[#F1F1EF] bg-cover bg-center border-4 border-white"
                 style="background-image: url('@Tutor.AvatarUrl')">
            </div>
            @if (Tutor.IsVerified)
            {
                <div class="absolute bottom-1 right-1 bg-white rounded-full p-0.5" title="Verified Tutor">
                    <span class="material-symbols-outlined text-[#37352F] text-[16px]" style="font-variation-settings:'FILL' 1">verified</span>
                </div>
            }
        </div>
        <div>
            <h2 class="text-lg font-bold text-[#37352F]">@Tutor.Name</h2>
            <p class="text-xs text-[#787774] mt-0.5">
                @(Tutor.IsSuperTutor ? "Super Tutor" : "Tutor")
                <span class="mx-1">·</span>
                @Tutor.Location
            </p>
        </div>
        <!-- Rating row -->
        <div class="flex items-center gap-1 text-sm">
            <span class="material-symbols-outlined text-[#F59E0B] text-[15px]" style="font-variation-settings:'FILL' 1">star</span>
            <span class="font-semibold text-[#37352F]">@Tutor.Rating.ToString("0.0")</span>
            <span class="text-[#787774]">(@Tutor.ReviewCount reviews)</span>
        </div>
        <!-- Subjects -->
        <div class="flex flex-wrap justify-center gap-1.5 mt-0.5">
            @foreach (var subject in Tutor.Subjects)
            {
                <span class="px-2 py-0.5 text-xs bg-[#F1F1EF] text-[#37352F] rounded-md font-medium">@subject</span>
            }
        </div>
    </div>

    <!-- Price + Availability -->
    <div class="flex items-center justify-between bg-[#F7F7F5] rounded-xl px-4 py-3 border border-[#E9E9E7]">
        <div>
            <p class="text-xs text-[#787774] font-medium uppercase tracking-wide">Rate</p>
            <p class="text-xl font-bold text-[#37352F] leading-none mt-0.5">
                $@Tutor.HourlyRate.ToString("0")<span class="text-sm font-normal text-[#787774]">/hr</span>
            </p>
        </div>
        @{ var (badgeText, badgeCss) = AvailBadge(Tutor.Availability); }
        <span class="text-xs px-2.5 py-1 rounded-md font-semibold @badgeCss">@badgeText</span>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 gap-3">
        <div class="flex flex-col items-center justify-center p-3 rounded-xl bg-[#F7F7F5] border border-[#E9E9E7]">
            <span class="text-xs text-[#787774] uppercase font-semibold tracking-wider">Response</span>
            <span class="font-bold text-[#37352F] mt-1">@Tutor.ResponseTime</span>
        </div>
        <div class="flex flex-col items-center justify-center p-3 rounded-xl bg-[#F7F7F5] border border-[#E9E9E7]">
            <span class="text-xs text-[#787774] uppercase font-semibold tracking-wider">Lessons</span>
            <span class="font-bold text-[#37352F] mt-1">@Tutor.TotalLessons.ToString("N0")</span>
        </div>
    </div>

    <!-- Bio -->
    <div class="space-y-1.5">
        <h4 class="text-xs font-semibold uppercase tracking-wide text-[#787774]">About</h4>
        <p class="text-sm text-[#37352F] leading-relaxed">@Tutor.FullBio</p>
    </div>

    <!-- Mini Calendar -->
    <div class="space-y-3">
        <div class="flex items-center justify-between">
            <h4 class="text-sm font-semibold text-[#37352F]">@_monthLabel</h4>
            <div class="flex gap-1">
                <button class="p-1 rounded hover:bg-[#F1F1EF] transition-colors" @onclick="PrevMonth">
                    <span class="material-symbols-outlined text-[#787774] text-[18px]">chevron_left</span>
                </button>
                <button class="p-1 rounded hover:bg-[#F1F1EF] transition-colors" @onclick="NextMonth">
                    <span class="material-symbols-outlined text-[#787774] text-[18px]">chevron_right</span>
                </button>
            </div>
        </div>

        <div class="grid grid-cols-7 gap-1 text-center text-xs">
            @foreach (var day in new[] { "Mo", "Tu", "We", "Th", "Fr", "Sa", "Su" })
            {
                <div class="text-[#787774] py-1 font-medium">@day</div>
            }
            @foreach (var cell in _calendarCells)
            {
                @if (cell == 0)
                {
                    <div class="py-2"></div>
                }
                else if (cell == _today.Day && _viewYear == _today.Year && _viewMonth == _today.Month)
                {
                    <div class="bg-[#37352F] text-white font-bold py-2 rounded-md cursor-pointer">@cell</div>
                }
                else if (_availableDays.Contains(cell))
                {
                    <div class="bg-[#ECECEC] text-[#37352F] font-bold py-2 rounded-md cursor-pointer">@cell</div>
                }
                else
                {
                    <div class="text-[#37352F] py-2 hover:bg-[#F1F1EF] rounded-md cursor-pointer transition-colors">@cell</div>
                }
            }
        </div>

        @if (Tutor.AvailableSlots.Length > 0)
        {
            <div class="flex flex-wrap gap-2 mt-1">
                @foreach (var slot in Tutor.AvailableSlots)
                {
                    <span class="text-xs px-2.5 py-1 rounded-md bg-[#D1FAE5] text-[#065F46] font-medium hover:bg-[#A7F3D0] transition-colors cursor-pointer">@slot</span>
                }
            </div>
        }
    </div>

    <!-- Actions -->
    <div class="mt-2">
        <button class="w-full bg-white border border-[#E9E9E7] hover:bg-[#F7F7F5] text-[#37352F] font-medium py-2.5 rounded-md transition-colors flex items-center justify-center gap-2"
                @onclick="() => _chatDrawer.OpenAsync()">
            <span class="material-symbols-outlined text-[18px]">chat_bubble</span>
            Message @Tutor!.Name.Split(' ')[0]
        </button>
    </div>

    <ChatDrawer @ref="_chatDrawer" Tutor="Tutor" />
}

@code {
    [Parameter] public TutorListItem? Tutor { get; set; }

    private ChatDrawer _chatDrawer = null!;
    private DateTime _today = DateTime.Today;
    private int _viewYear;
    private int _viewMonth;
    private string _monthLabel = "";
    private List<int> _calendarCells = [];
    private HashSet<int> _availableDays = [];

    protected override void OnInitialized()
    {
        _viewYear = _today.Year;
        _viewMonth = _today.Month;
        RebuildCalendar();
    }

    protected override void OnParametersSet() => RebuildCalendar();

    private void PrevMonth()
    {
        var d = new DateTime(_viewYear, _viewMonth, 1).AddMonths(-1);
        _viewYear = d.Year; _viewMonth = d.Month;
        RebuildCalendar();
    }

    private void NextMonth()
    {
        var d = new DateTime(_viewYear, _viewMonth, 1).AddMonths(1);
        _viewYear = d.Year; _viewMonth = d.Month;
        RebuildCalendar();
    }

    private void RebuildCalendar()
    {
        _monthLabel = new DateTime(_viewYear, _viewMonth, 1).ToString("MMMM yyyy");
        var firstDay = new DateTime(_viewYear, _viewMonth, 1);
        var startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
        var daysInMonth = DateTime.DaysInMonth(_viewYear, _viewMonth);

        _calendarCells = [.. Enumerable.Repeat(0, startOffset),
                          .. Enumerable.Range(1, daysInMonth)];

        while (_calendarCells.Count % 7 != 0) _calendarCells.Add(0);

        _availableDays = [.. Enumerable.Range(1, daysInMonth)
            .Where(d =>
            {
                var dow = new DateTime(_viewYear, _viewMonth, d).DayOfWeek;
                return dow is DayOfWeek.Monday or DayOfWeek.Wednesday or DayOfWeek.Friday;
            })];
    }

    private static (string text, string css) AvailBadge(AvailabilityStatus status) => status switch
    {
        AvailabilityStatus.AvailableToday => ("Available Today", "bg-[#D1FAE5] text-[#065F46]"),
        AvailabilityStatus.FullyBooked    => ("Fully Booked",    "bg-[#F3F4F6] text-[#787774]"),
        _                                 => ("Has Slots",        "bg-[#FEF3C7] text-[#92400E]"),
    };
}
