@using LearnmateSolution.Components.Pages.Student.FindTutor.Models

<div class="group flex flex-col gap-4 bg-white rounded-2xl border @(IsSelected ? "border-indigo-500 shadow-md shadow-indigo-100" : "border-slate-200 hover:border-indigo-200 hover:shadow-sm") transition-all duration-150 p-5 cursor-pointer"
     @onclick="() => OnSelected.InvokeAsync(Class)">

    <!-- Top row: subject badge + price -->
    <div class="flex items-start justify-between gap-3">
        <div class="flex flex-col gap-1.5 min-w-0">
            <span class="self-start text-xs font-semibold px-2.5 py-0.5 rounded-md bg-indigo-50 text-indigo-700 border border-indigo-100">
                @Class.Subject
            </span>
            <h3 class="text-base font-bold text-slate-900 leading-snug">@Class.ClassName</h3>
        </div>
        <div class="shrink-0 flex flex-col items-end gap-1">
            <p class="text-xl font-bold text-indigo-600 leading-none">
                $@Class.HourlyRate.ToString("0")<span class="text-xs font-normal text-slate-400">/hr</span>
            </p>
            @{ int remaining = Class.MaxStudents - Class.EnrolledCount; }
            <span class="text-xs font-semibold px-2 py-0.5 rounded-md @(remaining <= 3 ? "bg-rose-50 text-rose-600 border border-rose-200" : remaining <= 10 ? "bg-amber-50 text-amber-700 border border-amber-200" : "bg-emerald-50 text-emerald-700 border border-emerald-200")">
                @(remaining <= 0 ? "Full" : $"{remaining} slots left")
            </span>
        </div>
    </div>

    <!-- Description -->
    @if (!string.IsNullOrEmpty(Class.Description))
    {
        <p class="text-sm text-slate-500 line-clamp-2 leading-relaxed -mt-1">@Class.Description</p>
    }

    <!-- Schedule row -->
    @if (!string.IsNullOrEmpty(Class.ScheduleSummary))
    {
        <div class="flex items-center gap-1.5 text-sm text-slate-600">
            <span class="material-symbols-outlined text-[16px] text-slate-400">schedule</span>
            <span class="font-medium">@Class.ScheduleSummary</span>
        </div>
    }
    
    @if (Class.StartDate.HasValue && Class.EndDate.HasValue && Class.TotalSessions.HasValue)
    {
        <div class="flex items-center gap-1.5 text-sm text-slate-600 -mt-2">
            <span class="material-symbols-outlined text-[16px] text-slate-400">calendar_month</span>
            <span class="font-medium">@Class.StartDate.Value.ToString("dd/MM/yyyy") – @Class.EndDate.Value.ToString("dd/MM/yyyy") (@Class.TotalSessions buổi)</span>
        </div>
    }

    <!-- Divider -->
    <div class="border-t border-slate-100"></div>

    <!-- Bottom row: teacher info + actions -->
    <div class="flex items-center justify-between gap-3">

        <!-- Teacher -->
        <div class="flex items-center gap-2.5 min-w-0">
            <div class="size-9 rounded-full bg-indigo-100 bg-cover bg-center shrink-0 ring-2 ring-slate-100"
                 style="background-image: url('@Class.TeacherAvatarUrl')"></div>
            <div class="min-w-0">
                <p class="text-sm font-semibold text-slate-800 truncate">@Class.TeacherName</p>
                <div class="flex items-center gap-0.5">
                    <span class="material-symbols-outlined text-amber-400 text-[13px]" style="font-variation-settings:'FILL' 1">star</span>
                    <span class="text-xs font-bold text-slate-700">@Class.Rating.ToString("0.0")</span>
                    <span class="text-xs text-slate-400 ml-0.5">(@Class.ReviewCount)</span>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-2 shrink-0">
            <button class="border border-slate-200 text-slate-700 text-sm font-medium px-3 py-1.5 rounded-xl hover:bg-indigo-50 hover:border-indigo-200 hover:text-indigo-700 transition-colors"
                    @onclick:stopPropagation
                    @onclick="() => OnSelected.InvokeAsync(Class)">
                View
            </button>
            <button class="bg-indigo-600 text-white text-sm font-semibold px-3 py-1.5 rounded-xl hover:bg-indigo-700 transition-colors shadow-sm shadow-indigo-200"
                    @onclick:stopPropagation
                    @onclick="() => OnSelected.InvokeAsync(Class)">
                Enroll
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ClassListItem Class { get; set; } = null!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback<ClassListItem> OnSelected { get; set; }
}
