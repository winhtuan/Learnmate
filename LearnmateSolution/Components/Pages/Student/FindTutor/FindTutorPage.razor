@page "/student/find-tutor"
@layout ClassLayout
@rendermode InteractiveServer
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Tutor
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Student.Class.Components.Shared
@using LearnmateSolution.Components.Pages.Student.FindTutor.Components
@using LearnmateSolution.Components.Pages.Student.FindTutor.Models
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Find a Tutor - LearnMate</PageTitle>

<div class="space-y-6 max-w-screen-xl mx-auto">
    <Breadcrumb Items="@([new("Dashboard", "/student-dashboard"), new("Find a Tutor")])" />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- Left Column -->
        <div class="lg:col-span-8 flex flex-col gap-5">

            <!-- Title row -->
            <div class="flex items-center justify-between">
                <h1 class="text-2xl font-bold text-slate-900">Find a class</h1>
                @if (!_loading)
                {
                    <span class="text-sm text-slate-400 font-medium bg-indigo-50 px-3 py-1 rounded-full">@_filtered.Count classes</span>
                }
            </div>

            <!-- Search bar -->
            <div class="flex w-full items-center rounded-xl h-11 bg-white border border-slate-200 focus-within:border-indigo-400 focus-within:shadow-sm focus-within:shadow-indigo-100 transition-all">
                <span class="material-symbols-outlined text-slate-400 text-[18px] pl-4 shrink-0">search</span>
                <input class="flex-1 bg-transparent text-slate-800 focus:outline-none border-none text-sm px-3 placeholder:text-slate-400"
                       placeholder="Search by class name or tutor..."
                       @bind="_searchQuery" @bind:event="oninput" @bind:after="ApplyFilter" />
                @if (!string.IsNullOrEmpty(_searchQuery))
                {
                    <button class="pr-3 text-slate-400 hover:text-slate-700 transition-colors" @onclick="ClearSearch">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </button>
                }
            </div>

            <!-- Subject chips + filter toggle -->
            <div class="flex items-center gap-3">
                <div class="flex gap-2 overflow-x-auto pb-1 flex-1 min-w-0">
                    @foreach (var chip in _subjectChips)
                    {
                        <button class="flex h-8 shrink-0 items-center rounded-xl px-3.5 text-sm font-medium transition-all @(chip == _activeSubject ? "bg-indigo-600 text-white shadow-sm shadow-indigo-200" : "bg-white border border-slate-200 text-slate-600 hover:bg-indigo-50 hover:border-indigo-200 hover:text-indigo-700")"
                                @onclick="() => SetSubject(chip)">
                            @chip
                        </button>
                    }
                </div>
                <button class="flex items-center gap-1.5 h-8 shrink-0 px-3.5 rounded-xl border text-sm font-medium transition-all @(_showFilters ? "bg-indigo-600 text-white border-indigo-600 shadow-sm" : "bg-white border-slate-200 text-slate-600 hover:bg-indigo-50 hover:border-indigo-200")"
                        @onclick="() => _showFilters = !_showFilters">
                    <span class="material-symbols-outlined text-[16px]">tune</span>
                    Filters
                    @if (ActiveFilterCount > 0)
                    {
                        <span class="size-4 rounded-full bg-white/30 text-white text-[10px] font-bold flex items-center justify-center leading-none">@ActiveFilterCount</span>
                    }
                </button>
            </div>

            <!-- Advanced filter panel -->
            @if (_showFilters)
            {
                <div class="bg-white border border-indigo-100 rounded-2xl p-5 flex flex-col gap-5 shadow-sm shadow-indigo-50">

                    <!-- Price -->
                    <div class="flex flex-col gap-2">
                        <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Price per hour</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var opt in _priceOptions)
                            {
                                <button class="h-8 px-3.5 rounded-xl text-sm font-medium border transition-all @(opt == _priceFilter ? "bg-indigo-600 border-indigo-600 text-white shadow-sm" : "bg-white border-slate-200 text-slate-500 hover:bg-indigo-50 hover:border-indigo-200 hover:text-indigo-700")"
                                        @onclick="() => { _priceFilter = opt; ApplyFilter(); }">
                                    @opt
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Verified only -->
                    <label class="flex items-center gap-2 cursor-pointer w-fit">
                        <input type="checkbox" class="size-4 rounded cursor-pointer accent-indigo-600"
                               @bind="_verifiedOnly" @bind:after="ApplyFilter" />
                        <span class="text-sm font-medium text-slate-700">Active tutors only</span>
                    </label>

                    <!-- Reset -->
                    @if (ActiveFilterCount > 0)
                    {
                        <button class="self-start text-sm font-medium text-indigo-500 hover:text-indigo-700 transition-colors underline underline-offset-2"
                                @onclick="ResetFilters">
                            Reset all filters
                        </button>
                    }
                </div>
            }

            <!-- Error message -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="flex items-center gap-2 p-4 bg-rose-50 border border-rose-200 rounded-2xl text-sm text-rose-700">
                    <span class="material-symbols-outlined text-[18px]">error</span>
                    @_errorMessage
                </div>
            }

            <!-- Class Cards -->
            <div class="flex flex-col gap-4">
                @if (_loading)
                {
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="animate-pulse flex flex-col gap-4 bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
                            <div class="flex items-start justify-between">
                                <div class="flex flex-col gap-2 flex-1">
                                    <div class="h-5 w-16 bg-slate-200 rounded-md"></div>
                                    <div class="h-5 w-52 bg-slate-200 rounded"></div>
                                </div>
                                <div class="flex flex-col items-end gap-2">
                                    <div class="h-6 w-16 bg-slate-200 rounded"></div>
                                    <div class="h-5 w-20 bg-slate-200 rounded-md"></div>
                                </div>
                            </div>
                            <div class="h-3 w-full bg-slate-200 rounded"></div>
                            <div class="h-3 w-3/4 bg-slate-200 rounded"></div>
                            <div class="border-t border-slate-100"></div>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <div class="size-9 rounded-full bg-slate-200"></div>
                                    <div class="flex flex-col gap-1">
                                        <div class="h-3 w-24 bg-slate-200 rounded"></div>
                                        <div class="h-3 w-16 bg-slate-200 rounded"></div>
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    <div class="h-8 w-16 bg-slate-200 rounded-xl"></div>
                                    <div class="h-8 w-16 bg-slate-200 rounded-xl"></div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else if (_filtered.Count == 0)
                {
                    <div class="flex flex-col items-center justify-center py-20 text-slate-400">
                        <span class="material-symbols-outlined text-5xl mb-3 text-indigo-200">search_off</span>
                        <p class="text-base font-medium text-slate-500">No classes match your filters</p>
                        <button class="mt-3 text-sm text-indigo-500 hover:text-indigo-700 underline underline-offset-2 transition-colors" @onclick="ResetAll">Clear all</button>
                    </div>
                }
                else
                {
                    @foreach (var cls in _filtered)
                    {
                        <ClassListCard Class="cls"
                                       IsSelected="@(_selected?.ClassId == cls.ClassId)"
                                       OnSelected="SelectClass" />
                    }
                }
            </div>
        </div>

        <!-- Right Column: Quick View -->
        <div class="hidden lg:block lg:col-span-4">
            <div class="sticky top-8 flex flex-col gap-6 rounded-xl bg-white border border-[#E9E9E7] p-6 max-h-[calc(100vh-6rem)] overflow-y-auto">
                <TutorQuickView Tutor="_selectedTutor" OnBookClicked="OpenBookingModal" />
            </div>
        </div>

    </div>
</div>

@if (_showBookingModal && _selectedTutor is not null)
{
    <BookingModal TeacherId="_selectedTutor.Id"
                  TeacherName="_selectedTutor.Name"
                  OnClose="CloseBookingModal"
                  OnBooked="HandleBooked" />
}

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="fixed bottom-6 right-6 z-50 flex items-center gap-3 bg-emerald-600 text-white px-5 py-3 rounded-2xl shadow-lg animate-in fade-in slide-in-from-bottom-4">
        <span class="material-symbols-outlined text-[20px]">check_circle</span>
        <span class="text-sm font-medium">@_successMessage</span>
    </div>
}

@code {
    private static readonly string[] _subjectChips =
        ["All Subjects", "Mathematics", "Science", "English", "Coding", "Languages"];
    private static readonly string[] _priceOptions =
        ["Any Price", "Under $30", "$30 – $50", "Over $50"];

    private string _activeSubject = "All Subjects";
    private string _priceFilter   = "Any Price";
    private bool   _verifiedOnly;
    private bool   _showFilters;
    private string _searchQuery   = "";
    private bool   _loading       = true;
    private string _errorMessage  = "";
    private string _successMessage = "";

    private bool _showBookingModal;

    private ClassListItem?  _selected;
    private TutorListItem?  _selectedTutor;

    private int ActiveFilterCount =>
        (_priceFilter != "Any Price" ? 1 : 0) +
        (_verifiedOnly               ? 1 : 0);

    private List<ClassListItem> _classes  = [];
    private List<ClassListItem> _filtered = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadSessionAsync();
        if (!Session.IsAuthenticated || Session.Role != "STUDENT")
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await FetchTutorsAsync();
        ApplyFilter();
        SelectClass(_filtered.FirstOrDefault());
        _loading = false;
        StateHasChanged();
    }

    private async Task LoadSessionAsync()
    {
        if (Session.IsAuthenticated) return;
        var email  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
        var role   = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
        var token  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
        var avatar = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_avatar");
        var uidStr = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_userid");
        if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
        {
            var uid = long.TryParse(uidStr, out var id) ? id : 0;
            Session.SetSession(email, role, token, avatar, uid);
        }
    }

    private async Task FetchTutorsAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("learnmate");
            client.BaseAddress = new Uri(Nav.BaseUri);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);

            var subject  = _activeSubject == "All Subjects" ? null : _activeSubject;
            decimal? max = _priceFilter switch
            {
                "Under $30" => 29.99m,
                "$30 – $50" => 50m,
                _           => null
            };

            var url = "api/tutors";
            var query = new List<string>();
            if (subject is not null) query.Add($"subject={Uri.EscapeDataString(subject)}");
            if (max.HasValue) query.Add($"maxRate={max.Value}");
            if (query.Count > 0) url += "?" + string.Join("&", query);

            var resp = await client.GetFromJsonAsync<ApiResponse<IReadOnlyList<TutorSummaryDto>>>(url);
            _classes = resp?.Data?.Select(MapToClassItem).ToList() ?? [];
        }
        catch
        {
            _errorMessage = "Failed to load classes. Please try again.";
            _classes = [];
        }
    }

    private static ClassListItem MapToClassItem(TutorSummaryDto dto)
    {
        var initials = dto.FullName.Length >= 2
            ? dto.FullName[..2].ToUpper()
            : dto.FullName.ToUpper();

        var subjects = dto.Subjects.Split(',').Select(s => s.Trim()).Where(s => s.Length > 0).ToArray();
        var primarySubject = subjects.FirstOrDefault() ?? "General";

        return new ClassListItem(
            ClassId:          dto.TeacherUserId,   // tạm dùng TeacherUserId, sẽ thay bằng ClassId thật sau
            ClassName:        $"{primarySubject} — {dto.FullName}",
            Description:      dto.Bio,
            Subject:          primarySubject,
            ScheduleSummary:  "",                  // sẽ có khi API trả về class thật
            EnrolledCount:    0,
            MaxStudents:      30,
            TeacherId:        dto.TeacherUserId,
            TeacherName:      dto.FullName,
            TeacherAvatarUrl: dto.AvatarUrl ?? $"https://placehold.co/200/e0e7ff/4f46e5?text={Uri.EscapeDataString(initials)}",
            Rating:           dto.RatingAvg,
            ReviewCount:      dto.TotalRatingCount,
            Subjects:         subjects,
            HourlyRate:       dto.HourlyRate,
            Bio:              dto.Bio ?? ""
        );
    }

    private static TutorListItem ToTutorListItem(ClassListItem cls) => new(
        Id:               cls.TeacherId,
        Name:             cls.TeacherName,
        AvatarUrl:        cls.TeacherAvatarUrl,
        IsVerified:       false,
        IsSuperTutor:     false,
        Rating:           cls.Rating,
        ReviewCount:      cls.ReviewCount,
        StudentCount:     0,
        Bio:              cls.Bio,
        Subjects:         cls.Subjects,
        HourlyRate:       cls.HourlyRate,
        Availability:     AvailabilityStatus.NextSlot,
        AvailabilityLabel: null,
        Location:         "Online",
        ResponseTime:     "",
        TotalLessons:     0,
        FullBio:          cls.Bio,
        AvailableSlots:   []
    );

    private void SetSubject(string chip) { _activeSubject = chip; ApplyFilter(); }
    private void ClearSearch() { _searchQuery = ""; ApplyFilter(); }

    private void ResetFilters()
    {
        _priceFilter  = "Any Price";
        _verifiedOnly = false;
        ApplyFilter();
    }

    private void ResetAll()
    {
        _searchQuery   = "";
        _activeSubject = "All Subjects";
        ResetFilters();
    }

    private void ApplyFilter()
    {
        var q = _searchQuery.Trim().ToLowerInvariant();
        _filtered = _classes
            .Where(c =>
            {
                if (!string.IsNullOrEmpty(q) &&
                    !c.ClassName.Contains(q, StringComparison.OrdinalIgnoreCase) &&
                    !c.TeacherName.Contains(q, StringComparison.OrdinalIgnoreCase))
                    return false;

                if (_activeSubject != "All Subjects" &&
                    !c.Subjects.Any(s => s.Contains(_activeSubject, StringComparison.OrdinalIgnoreCase)))
                    return false;

                var pass = _priceFilter switch
                {
                    "Under $30" => c.HourlyRate < 30,
                    "$30 – $50" => c.HourlyRate is >= 30 and <= 50,
                    "Over $50"  => c.HourlyRate > 50,
                    _           => true
                };
                if (!pass) return false;

                return true;
            })
            .ToList();
    }

    private void SelectClass(ClassListItem? cls)
    {
        _selected      = cls;
        _selectedTutor = cls is null ? null : ToTutorListItem(cls);
    }

    private void OpenBookingModal(long teacherId) => _showBookingModal = true;
    private void CloseBookingModal() => _showBookingModal = false;

    private async Task HandleBooked(string message)
    {
        _showBookingModal = false;
        _successMessage = message;
        StateHasChanged();
        await Task.Delay(3000);
        _successMessage = "";
        StateHasChanged();
    }
}
