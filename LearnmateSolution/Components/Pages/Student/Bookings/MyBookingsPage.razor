@page "/student/bookings"
@layout LearnmateSolution.Components.Layout.DashboardLayout
@rendermode InteractiveServer
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Payment
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Lịch đặt học | LearnMate</PageTitle>

<div class="max-w-screen-lg mx-auto space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Lịch đặt học</h1>
            <p class="text-slate-500 text-sm mt-1">Quản lý các yêu cầu đặt lịch học và thanh toán khoá học.</p>
        </div>
        <div class="size-10 rounded-full bg-amber-50 border border-amber-200 flex items-center justify-center">
            <span class="material-symbols-outlined text-amber-600 text-[20px]">calendar_month</span>
        </div>
    </div>

    @if (!_ready)
    {
        <div class="flex items-center justify-center h-60 text-slate-400">
            <span class="material-symbols-outlined animate-spin text-3xl mr-3">progress_activity</span>
            <span class="text-sm font-medium">Đang tải...</span>
        </div>
    }
    else if (_bookings.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-20 bg-white rounded-2xl border border-slate-100 shadow-sm text-slate-400">
            <span class="material-symbols-outlined text-5xl mb-3 text-slate-300">event_available</span>
            <p class="text-base font-semibold">Chưa có lịch đặt học nào</p>
            <p class="text-sm mt-1">Tìm giáo viên và đặt lịch học ngay hôm nay!</p>
            <a href="/student/find-tutor" class="mt-5 px-5 py-2.5 rounded-xl bg-primary text-white text-sm font-bold hover:bg-blue-600 transition-colors shadow-sm shadow-primary/20">
                Tìm giáo viên
            </a>
        </div>
    }
    else
    {
        <!-- Booking list -->
        <div class="space-y-4">
            @foreach (var b in _bookings)
            {
                var (statusColor, statusBg, statusLabel, statusIcon) = GetStatusStyle(b.Status);
                var isAwaitingPayment = b.Status == "AWAITING_PAYMENT" && b.CanPay;
                var deadlineExpired   = b.PaymentDeadlineLocal.HasValue && b.PaymentDeadlineLocal < DateTime.Now;

                <div class="bg-white rounded-2xl border @(isAwaitingPayment ? "border-amber-300 ring-2 ring-amber-100" : "border-slate-100") shadow-sm overflow-hidden transition-all hover:shadow-md">
                    <!-- Card top: status bar -->
                    <div class="h-1 @statusBg"></div>

                    <div class="p-5 flex flex-col sm:flex-row items-start gap-5">
                        <!-- Teacher avatar -->
                        <div class="size-14 rounded-2xl bg-slate-100 flex items-center justify-center shrink-0 border border-slate-200 overflow-hidden shadow-sm">
                            @if (!string.IsNullOrEmpty(b.TeacherAvatar))
                            {
                                <img src="@b.TeacherAvatar" alt="Avatar" class="size-14 object-cover rounded-2xl" />
                            }
                            else
                            {
                                <span class="text-slate-600 font-black text-xl">@Initials(b.TeacherName)</span>
                            }
                        </div>

                        <!-- Info -->
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2 flex-wrap">
                                <div>
                                    <p class="text-base font-bold text-slate-900">@b.TeacherName</p>
                                    @if (!string.IsNullOrEmpty(b.ClassName))
                                    {
                                        <p class="text-sm text-slate-500 flex items-center gap-1 mt-0.5">
                                            <span class="material-symbols-outlined text-[15px]">class</span>
                                            @b.ClassName
                                        </p>
                                    }
                                </div>
                                <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold @statusBg @statusColor border border-current/20">
                                    <span class="material-symbols-outlined text-[14px]">@statusIcon</span>
                                    @statusLabel
                                </span>
                            </div>

                            <!-- Time info -->
                            <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-slate-600">
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[16px] text-slate-400">schedule</span>
                                    @b.RequestedStartTimeLocal.ToString("dd/MM/yyyy HH:mm") — @b.RequestedEndTimeLocal.ToString("HH:mm")
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[16px] text-slate-400">today</span>
                                    Đặt lúc: @b.CreatedAtLocal.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>

                            <!-- Payment deadline -->
                            @if (b.Status == "AWAITING_PAYMENT" && b.PaymentDeadlineLocal.HasValue)
                            {
                                <div class="mt-3 flex items-center gap-2 @(deadlineExpired ? "text-red-500" : "text-amber-600") text-sm font-semibold bg-amber-50 rounded-xl px-3 py-2 border border-amber-200">
                                    <span class="material-symbols-outlined text-[18px]">@(deadlineExpired ? "timer_off" : "timer")</span>
                                    @if (deadlineExpired)
                                    {
                                        <span>Đã hết thời hạn thanh toán</span>
                                    }
                                    else
                                    {
                                        <span>Hạn thanh toán: <strong>@b.PaymentDeadlineLocal.Value.ToString("dd/MM/yyyy HH:mm")</strong></span>
                                        <CountdownTimer Deadline="b.PaymentDeadlineLocal.Value" />
                                    }
                                </div>
                            }

                            <!-- Cancel reason -->
                            @if (!string.IsNullOrEmpty(b.CancelReason))
                            {
                                <div class="mt-3 flex items-start gap-2 text-sm text-red-600 bg-red-50 rounded-xl px-3 py-2 border border-red-100">
                                    <span class="material-symbols-outlined text-[18px] shrink-0 mt-0.5">info</span>
                                    <span>@b.CancelReason</span>
                                </div>
                            }
                        </div>

                        <!-- Action section -->
                        <div class="flex flex-col items-end gap-3 shrink-0">
                            @if (b.Amount.HasValue)
                            {
                                <div class="text-right">
                                    <p class="text-xs text-slate-400 font-medium">Học phí</p>
                                    <p class="text-xl font-black text-slate-900">@b.Amount.Value.ToString("N0")<span class="text-sm font-semibold">đ</span></p>
                                </div>
                            }

                            @if (isAwaitingPayment)
                            {
                                <button class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-600 text-white text-sm font-bold transition-all shadow-sm shadow-amber-300 disabled:opacity-50"
                                        disabled="@(_payingBookingId == b.BookingId)"
                                        @onclick="() => PayAsync(b)">
                                    @if (_payingBookingId == b.BookingId)
                                    {
                                        <span class="material-symbols-outlined animate-spin text-[18px]">progress_activity</span>
                                        <span>Đang xử lý...</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-[18px]">payment</span>
                                        <span>Thanh toán ngay</span>
                                    }
                                </button>
                            }
                            else if (b.Status == "BOOKING_SUCCESS" && b.ClassId.HasValue)
                            {
                                <a href="/classes/@b.ClassId" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-bold transition-all shadow-sm">
                                    <span class="material-symbols-outlined text-[18px]">school</span>
                                    Vào lớp học
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Error toast -->
    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="fixed bottom-6 right-6 flex items-center gap-3 bg-red-600 text-white px-5 py-4 rounded-2xl shadow-xl z-50 animate-fade-in">
            <span class="material-symbols-outlined text-[20px]">error</span>
            <span class="text-sm font-medium">@_errorMsg</span>
            <button @onclick="() => _errorMsg = null" class="ml-2 hover:opacity-70 transition-opacity">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        </div>
    }
</div>

@code {
    private bool _ready;
    private List<BookingPaymentSummaryDto> _bookings = [];
    private long? _payingBookingId;
    private string? _errorMsg;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Session.IsAuthenticated)
        {
            var email    = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
            var role     = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
            var token    = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
            var uidStr   = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_userid");
            var avatar   = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_avatar");
            var fullName = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_fullname");
            if (!string.IsNullOrEmpty(token))
            {
                var uid = long.TryParse(uidStr, out var id) ? id : 0;
                Session.SetSession(email!, role!, token, avatar, uid, fullName);
            }
        }

        if (!Session.IsAuthenticated) { Nav.NavigateTo("/login", replace: true); return; }
        if (Session.Role != "STUDENT") { Nav.NavigateTo("/", replace: true); return; }

        await LoadBookingsAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task LoadBookingsAsync()
    {
        try
        {
            var client = CreateClient();
            var resp   = await client.GetFromJsonAsync<ApiResponse<IReadOnlyList<BookingPaymentSummaryDto>>>("api/bookings/my/payment");
            _bookings  = resp?.Data?.ToList() ?? [];
        }
        catch { _bookings = []; }
    }

    private async Task PayAsync(BookingPaymentSummaryDto booking)
    {
        _payingBookingId = booking.BookingId;
        _errorMsg        = null;
        StateHasChanged();

        try
        {
            var client = CreateClient();
            var body   = new { BookingId = booking.BookingId };
            var resp   = await client.PostAsJsonAsync("api/payment/initiate", body);
            var result = await resp.Content.ReadFromJsonAsync<ApiResponse<string>>();

            if (result?.Success == true && !string.IsNullOrEmpty(result.Data))
            {
                // Redirect sang cổng thanh toán VNPay
                await JS.InvokeVoidAsync("open", result.Data, "_self");
            }
            else
            {
                _errorMsg = result?.Message ?? "Không thể khởi tạo thanh toán.";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = $"Lỗi kết nối: {ex.Message}";
        }
        finally
        {
            _payingBookingId = null;
            StateHasChanged();
        }
    }

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient("learnmate");
        client.BaseAddress = new Uri(Nav.BaseUri);
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);
        return client;
    }

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "G";
        return string.Concat(name.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(p => char.ToUpper(p[0])));
    }

    private static (string color, string bg, string label, string icon) GetStatusStyle(string status) => status switch
    {
        "PENDING"           => ("text-slate-600",  "bg-slate-100",   "Chờ giáo viên duyệt", "hourglass_empty"),
        "AWAITING_PAYMENT"  => ("text-amber-700",  "bg-amber-500",   "Chờ thanh toán",       "payment"),
        "PAYMENT_SUCCESS"   => ("text-blue-700",   "bg-blue-500",    "Đã thanh toán",         "verified"),
        "BOOKING_SUCCESS"   => ("text-emerald-700","bg-emerald-500", "Đặt lịch thành công",   "check_circle"),
        "DECLINED"          => ("text-red-700",    "bg-red-400",     "Bị từ chối",            "cancel"),
        "CANCELLED"         => ("text-slate-600",  "bg-slate-300",   "Đã huỷ",               "block"),
        "EXPIRED"           => ("text-orange-700", "bg-orange-400",  "Hết hạn thanh toán",    "timer_off"),
        _                   => ("text-slate-600",  "bg-slate-100",   status,                  "info"),
    };
}
