@using LearnmateSolution.Components.Pages.Student.Dashboard.Models
@implements IDisposable

<div class="bg-white rounded-xl border border-slate-200 shadow-sm mb-8">
    @* Header row *@
    <div class="p-6 md:p-8 border-b border-slate-100 flex flex-col md:flex-row justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-slate-900 mb-1">@Greeting, @UserName!</h1>
            <p class="text-slate-500">Here's your overview for @CurrentDay, @CurrentDate.</p>
        </div>
        <div class="hidden sm:flex items-center gap-2 px-4 py-2 bg-slate-50 rounded-lg border border-slate-100 self-start">
            <span class="material-symbols-outlined text-slate-400 text-[20px]">event_upcoming</span>
            <span class="text-sm font-semibold text-slate-700">Term: @CurrentTerm</span>
        </div>
    </div>

    @* Stat cards *@
    <div class="flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-slate-100">
        @* My Classes *@
        <div class="flex-1 p-6 flex flex-col items-center text-center hover:bg-blue-50 transition-colors">
            <span class="material-symbols-outlined text-3xl text-blue-600 mb-3">school</span>
            <span class="text-xs font-bold uppercase tracking-widest mb-1 text-blue-600/70">My Classes</span>
            <span class="text-2xl font-bold text-slate-900">@Stats.ActiveClasses</span>
        </div>

        <div class="w-px bg-slate-100 hidden md:block"></div>

        @* Pending Tasks *@
        <div class="flex-1 p-6 flex flex-col items-center text-center hover:bg-orange-50 transition-colors">
            <span class="material-symbols-outlined text-3xl text-orange-600 mb-3">checklist</span>
            <span class="text-xs font-bold uppercase tracking-widest mb-1 text-orange-600/70">Pending Tasks</span>
            <span class="text-2xl font-bold text-slate-900">@Stats.PendingTasks</span>
        </div>

        <div class="w-px bg-slate-100 hidden md:block"></div>

        @* Study Streak *@
        <div class="flex-1 p-6 flex flex-col items-center text-center hover:bg-amber-50 transition-colors">
            <span class="material-symbols-outlined text-3xl text-amber-500 mb-3">local_fire_department</span>
            <span class="text-xs font-bold uppercase tracking-widest mb-1 text-amber-500/70">Study Streak</span>
            <span class="text-2xl font-bold text-slate-900">@Stats.StudyStreak</span>
        </div>

        <div class="w-px bg-slate-100 hidden md:block"></div>

        @* Next Session *@
        <div class="flex-[1.2] p-6 flex flex-col items-center text-center hover:bg-slate-100 bg-slate-50 transition-colors">
            <span class="material-symbols-outlined text-3xl text-primary mb-3">timer</span>
            <span class="text-xs font-bold text-primary/70 uppercase tracking-widest mb-1">Next Session</span>
            <span class="text-2xl font-bold text-slate-900 tabular-nums font-mono">@_countdown</span>
            <span class="text-xs text-slate-500 mt-1">
                @Stats.NextSession.ClassName
                @if (!string.IsNullOrEmpty(Stats.NextSession.Room))
                {
                    <span> • @Stats.NextSession.Room</span>
                }
            </span>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Greeting { get; set; } = "Good Morning";
    [Parameter] public string UserName { get; set; } = "Student";
    [Parameter] public string CurrentDay { get; set; } = "";
    [Parameter] public string CurrentDate { get; set; } = "";
    [Parameter] public string CurrentTerm { get; set; } = "Fall 2024";
    [Parameter] public WelcomeBannerStats Stats { get; set; } = new("5 Active", "12 Items", "15 days", new(null, "No upcoming class", ""));

    private string _countdown = "—";
    private Timer? _timer;

    protected override void OnParametersSet()
    {
        _timer?.Dispose();
        _timer = null;

        if (Stats.NextSession.StartTimeLocal is null)
        {
            _countdown = "—";
            return;
        }

        UpdateCountdown();
        _timer = new Timer(_ => InvokeAsync(() => { UpdateCountdown(); StateHasChanged(); }),
                           null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateCountdown()
    {
        if (Stats.NextSession.StartTimeLocal is not { } target)
        {
            _countdown = "—";
            return;
        }

        var remaining = target - DateTime.Now;
        if (remaining <= TimeSpan.Zero)
        {
            _countdown = "Now";
            return;
        }

        _countdown = remaining.TotalHours >= 24
            ? $"{(int)remaining.TotalDays}d {remaining.Hours:D2}h {remaining.Minutes:D2}m"
            : $"{(int)remaining.TotalHours:D2}:{remaining.Minutes:D2}:{remaining.Seconds:D2}";
    }

    public void Dispose() => _timer?.Dispose();
}
