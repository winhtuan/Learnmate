@page "/student/messages"
@layout ClassLayout
@rendermode InteractiveServer
@using BusinessLogicLayer.DTOs
@using BusinessLogicLayer.DTOs.Messaging
@using LearnmateSolution.Components.Layout
@using LearnmateSolution.Components.Pages.Student.Class.Components.Shared
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@inject UserSessionService Session
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@implements IAsyncDisposable

<PageTitle>Messages - LearnMate</PageTitle>

<div class="max-w-screen-xl mx-auto space-y-4">
    <Breadcrumb Items="@([new("Dashboard", "/student-dashboard"), new("Messages")])" />

    <div class="flex h-[calc(100vh-10rem)] bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">

        <!-- Left sidebar: conversation list -->
        <div class="w-80 shrink-0 flex flex-col border-r border-slate-100">
            <div class="px-4 py-3 border-b border-slate-100">
                <h2 class="text-base font-bold text-slate-900">Messages</h2>
            </div>

            @if (!_ready)
            {
                <div class="flex items-center justify-center flex-1 text-slate-400 text-sm">Loading...</div>
            }
            else if (_conversations.Count == 0)
            {
                <div class="flex flex-col items-center justify-center flex-1 gap-2 text-slate-400 px-4 text-center">
                    <span class="material-symbols-outlined text-4xl">chat_bubble_outline</span>
                    <p class="text-sm">No conversations yet.<br />Message a tutor from the Find Tutor page.</p>
                </div>
            }
            else
            {
                <div class="flex-1 overflow-y-auto divide-y divide-slate-50">
                    @foreach (var conv in _conversations)
                    {
                        var isSelected = _selectedConvId == conv.Id;
                        <button class="w-full flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition-colors text-left @(isSelected ? "bg-slate-50" : "")"
                                @onclick="() => SelectConversationAsync(conv)">
                            <!-- Avatar -->
                            <div class="size-10 rounded-full bg-indigo-100 flex items-center justify-center shrink-0 overflow-hidden mt-0.5">
                                @if (!string.IsNullOrEmpty(conv.OtherUserAvatar))
                                {
                                    <img src="@conv.OtherUserAvatar" class="size-10 object-cover rounded-full" alt="" />
                                }
                                else
                                {
                                    <span class="text-indigo-600 font-bold text-sm">@Initials(conv.OtherUserName)</span>
                                }
                            </div>
                            <!-- Info -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-1">
                                    <p class="text-sm font-semibold text-slate-900 truncate">@conv.OtherUserName</p>
                                    @if (conv.LastMessageAtLocal.HasValue)
                                    {
                                        <span class="text-[11px] text-slate-400 shrink-0">@FormatTime(conv.LastMessageAtLocal.Value)</span>
                                    }
                                </div>
                                <div class="flex items-center gap-1 mt-0.5">
                                    <p class="text-xs text-slate-500 truncate flex-1">@(conv.LastMessagePreview ?? "No messages yet")</p>
                                    @if (conv.UnreadCount > 0)
                                    {
                                        <span class="size-4 rounded-full bg-indigo-600 text-white text-[10px] font-bold flex items-center justify-center shrink-0 leading-none">@conv.UnreadCount</span>
                                    }
                                </div>
                            </div>
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Right: chat pane -->
        <div class="flex-1 flex flex-col min-w-0">
            @if (_selectedConv is null)
            {
                <div class="flex flex-col items-center justify-center flex-1 text-slate-400 gap-2">
                    <span class="material-symbols-outlined text-5xl">chat</span>
                    <p class="text-sm">Select a conversation to start chatting</p>
                </div>
            }
            else
            {
                <!-- Chat header -->
                <div class="flex items-center gap-3 px-5 py-3.5 border-b border-slate-100 shrink-0">
                    <div class="size-9 rounded-full bg-indigo-100 flex items-center justify-center shrink-0 overflow-hidden">
                        @if (!string.IsNullOrEmpty(_selectedConv.OtherUserAvatar))
                        {
                            <img src="@_selectedConv.OtherUserAvatar" class="size-9 object-cover rounded-full" alt="" />
                        }
                        else
                        {
                            <span class="text-indigo-600 font-bold text-sm">@Initials(_selectedConv.OtherUserName)</span>
                        }
                    </div>
                    <div>
                        <p class="text-sm font-bold text-slate-900">@_selectedConv.OtherUserName</p>
                        @if (_otherUserTyping)
                        {
                            <p class="text-xs text-slate-400 italic">typing…</p>
                        }
                    </div>
                </div>

                <!-- Messages -->
                <div @ref="_messagesContainer" class="flex-1 overflow-y-auto px-5 py-4 flex flex-col gap-3">
                    @if (_loadingMessages)
                    {
                        <div class="flex items-center justify-center h-16 text-slate-400 text-sm">Loading...</div>
                    }
                    else
                    {
                        <!-- Load more button -->
                        @if (_hasMore)
                        {
                            <div class="flex justify-center">
                                <button class="text-xs text-slate-500 hover:text-slate-700 py-1.5 px-3 rounded-full hover:bg-slate-100 transition-colors disabled:opacity-40"
                                        disabled="@_loadingMore"
                                        @onclick="LoadMoreAsync">
                                    @(_loadingMore ? "Loading…" : "Load older messages")
                                </button>
                            </div>
                        }

                        @foreach (var msg in _messages)
                        {
                            if (msg.IsMine)
                            {
                                <div class="flex justify-end">
                                    <div class="bg-[#37352F] rounded-xl rounded-tr-sm px-3.5 py-2.5 max-w-[70%]">
                                        <p class="text-sm text-white whitespace-pre-wrap">@msg.Content</p>
                                        <p class="text-[11px] text-white/60 mt-1 text-right">@msg.SentAtLocal.ToString("h:mm tt")</p>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="flex gap-2.5">
                                    <div class="size-7 rounded-full bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5 overflow-hidden">
                                        @if (!string.IsNullOrEmpty(_selectedConv.OtherUserAvatar))
                                        {
                                            <img src="@_selectedConv.OtherUserAvatar" class="size-7 object-cover rounded-full" alt="" />
                                        }
                                        else
                                        {
                                            <span class="text-indigo-600 font-bold text-[10px]">@Initials(_selectedConv.OtherUserName)</span>
                                        }
                                    </div>
                                    <div class="bg-slate-100 rounded-xl rounded-tl-sm px-3.5 py-2.5 max-w-[70%]">
                                        <p class="text-sm text-slate-800 whitespace-pre-wrap">@msg.Content</p>
                                        <p class="text-[11px] text-slate-400 mt-1">@msg.SentAtLocal.ToString("h:mm tt")</p>
                                    </div>
                                </div>
                            }
                        }

                        <!-- Typing indicator -->
                        @if (_otherUserTyping)
                        {
                            <div class="flex gap-2.5">
                                <div class="size-7 rounded-full bg-indigo-100 flex items-center justify-center shrink-0 mt-0.5 overflow-hidden">
                                    @if (!string.IsNullOrEmpty(_selectedConv.OtherUserAvatar))
                                    {
                                        <img src="@_selectedConv.OtherUserAvatar" class="size-7 object-cover rounded-full" alt="" />
                                    }
                                    else
                                    {
                                        <span class="text-indigo-600 font-bold text-[10px]">@Initials(_selectedConv.OtherUserName)</span>
                                    }
                                </div>
                                <div class="bg-slate-100 rounded-xl rounded-tl-sm px-3.5 py-3 flex items-center gap-1">
                                    <span class="size-1.5 rounded-full bg-slate-400 animate-bounce" style="animation-delay:0ms"></span>
                                    <span class="size-1.5 rounded-full bg-slate-400 animate-bounce" style="animation-delay:150ms"></span>
                                    <span class="size-1.5 rounded-full bg-slate-400 animate-bounce" style="animation-delay:300ms"></span>
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Input -->
                <div class="px-4 py-3 border-t border-slate-100 flex items-end gap-2 shrink-0">
                    <textarea @ref="_inputRef"
                              class="flex-1 resize-none overflow-y-auto rounded-xl border border-slate-200 bg-slate-50
                                     px-3.5 py-2.5 text-sm text-slate-900 placeholder:text-slate-400
                                     focus:outline-none focus:border-slate-400 transition-colors
                                     min-h-[42px] max-h-32 leading-relaxed"
                              placeholder="Type a message…"
                              rows="1"
                              value="@_draft"
                              @oninput="OnDraftInput"
                              @onkeydown="OnKeyDown">
                    </textarea>
                    <button class="shrink-0 size-[42px] rounded-xl bg-[#37352F] hover:bg-[#2F2E2B] transition-colors
                                   flex items-center justify-center disabled:opacity-40"
                            disabled="@(string.IsNullOrWhiteSpace(_draft) || _sending)"
                            @onclick="SendMessageAsync">
                        <span class="material-symbols-outlined text-white text-[18px]">send</span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool _ready;
    private bool _loadingMessages;
    private bool _loadingMore;
    private bool _hasMore;
    private bool _sending;
    private bool _otherUserTyping;
    private bool _isTypingNotified;
    private bool _needsScrollAdjust;
    private double _prevScrollHeight;
    private int _skip;
    private const int Take = 50;
    private long _selectedConvId;
    private string _draft = "";
    private ElementReference _messagesContainer;
    private ElementReference _inputRef;
    private HubConnection? _hub;
    private CancellationTokenSource? _typingCts;

    private List<ConversationSummaryDto> _conversations = [];
    private ConversationSummaryDto? _selectedConv;
    private List<MessageDto> _messages = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!Session.IsAuthenticated)
            {
                var email  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_email");
                var role   = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_role");
                var token  = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_token");
                var uidStr = await JS.InvokeAsync<string?>("sessionStorage.getItem", "lm_userid");
                if (!string.IsNullOrEmpty(email) && !string.IsNullOrEmpty(role) && !string.IsNullOrEmpty(token))
                {
                    var uid = long.TryParse(uidStr, out var id) ? id : 0;
                    Session.SetSession(email, role, token, null, uid);
                }
            }

            if (!Session.IsAuthenticated) { Nav.NavigateTo("/login", replace: true); return; }
            if (Session.Role != "STUDENT") { Nav.NavigateTo("/", replace: true); return; }

            await LoadConversationsAsync();
            _ready = true;
            StateHasChanged();
        }

        if (_needsScrollAdjust)
        {
            _needsScrollAdjust = false;
            try { await JS.InvokeVoidAsync("adjustScrollAfterPrepend", _messagesContainer, _prevScrollHeight); }
            catch { }
        }
    }

    private async Task LoadConversationsAsync()
    {
        try
        {
            var resp = await CreateClient()
                .GetFromJsonAsync<ApiResponse<IReadOnlyList<ConversationSummaryDto>>>("api/conversations");
            _conversations = resp?.Data?.ToList() ?? [];
        }
        catch
        {
            _conversations = [];
        }
    }

    private async Task SelectConversationAsync(ConversationSummaryDto conv)
    {
        if (_selectedConvId == conv.Id) return;

        if (_hub is not null && _selectedConvId != 0)
        {
            try { await _hub.InvokeAsync("LeaveConversation", _selectedConvId); } catch { }
        }

        _selectedConv   = conv;
        _selectedConvId = conv.Id;
        _messages.Clear();
        _loadingMessages = true;
        _hasMore = false;
        _skip = 0;
        _otherUserTyping = false;
        StateHasChanged();

        try
        {
            var msgResp = await CreateClient()
                .GetFromJsonAsync<ApiResponse<IReadOnlyList<MessageDto>>>(
                    $"api/conversations/{conv.Id}/messages?skip=0&take={Take}");
            var loaded = msgResp?.Data?.ToList() ?? [];
            _messages = loaded;
            _skip = loaded.Count;
            _hasMore = loaded.Count == Take;

            await EnsureHubAsync();
            await _hub!.InvokeAsync("JoinConversation", conv.Id);

            _ = CreateClient().PostAsync($"api/conversations/{conv.Id}/read", null);

            var idx = _conversations.FindIndex(c => c.Id == conv.Id);
            if (idx >= 0 && _conversations[idx].UnreadCount > 0)
                _conversations[idx] = _conversations[idx] with { UnreadCount = 0 };
        }
        catch { }

        _loadingMessages = false;
        StateHasChanged();
        await ScrollBottomAsync();
    }

    private async Task LoadMoreAsync()
    {
        if (_loadingMore || !_hasMore || _selectedConvId == 0) return;

        _loadingMore = true;
        StateHasChanged();

        try
        {
            var msgResp = await CreateClient()
                .GetFromJsonAsync<ApiResponse<IReadOnlyList<MessageDto>>>(
                    $"api/conversations/{_selectedConvId}/messages?skip={_skip}&take={Take}");
            var loaded = msgResp?.Data?.ToList() ?? [];

            if (loaded.Count > 0)
            {
                _prevScrollHeight = await JS.InvokeAsync<double>("getScrollHeight", _messagesContainer);
                _messages.InsertRange(0, loaded);
                _skip += loaded.Count;
                _hasMore = loaded.Count == Take;
                _needsScrollAdjust = true;
            }
            else
            {
                _hasMore = false;
            }
        }
        catch { }

        _loadingMore = false;
        StateHasChanged();
    }

    private async Task EnsureHubAsync()
    {
        if (_hub?.State == HubConnectionState.Connected) return;

        if (_hub is not null)
        {
            try { await _hub.StopAsync(); } catch { }
            await _hub.DisposeAsync();
        }

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/chat"), opts =>
            {
                opts.AccessTokenProvider = () => Task.FromResult<string?>(Session.AccessToken);
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<MessageDto>("ReceiveMessage", async msg =>
        {
            var corrected = msg with { IsMine = msg.SenderId == Session.UserId };
            if (_messages.All(m => m.Id != msg.Id))
                _messages.Add(corrected);
            await InvokeAsync(StateHasChanged);
            await ScrollBottomAsync();
        });

        _hub.On<bool>("UserTyping", async isTyping =>
        {
            _otherUserTyping = isTyping;
            await InvokeAsync(StateHasChanged);
            if (isTyping) await ScrollBottomAsync();
        });

        await _hub.StartAsync();
    }

    private void OnDraftInput(ChangeEventArgs e)
    {
        _draft = e.Value?.ToString() ?? "";
        _ = NotifyTypingAsync();
    }

    private async Task NotifyTypingAsync()
    {
        if (_hub?.State != HubConnectionState.Connected || _selectedConvId == 0) return;

        _typingCts?.Cancel();
        _typingCts = new CancellationTokenSource();

        if (!_isTypingNotified)
        {
            _isTypingNotified = true;
            try { await _hub.InvokeAsync("StartTyping", _selectedConvId); } catch { }
        }

        var cts = _typingCts;
        try
        {
            await Task.Delay(2000, cts.Token);
            _isTypingNotified = false;
            try { await _hub.InvokeAsync("StopTyping", _selectedConvId); } catch { }
        }
        catch (OperationCanceledException) { }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessageAsync();
    }

    private async Task SendMessageAsync()
    {
        var text = _draft.Trim();
        if (string.IsNullOrEmpty(text) || _sending || _selectedConvId == 0) return;

        _sending = true;
        _draft = "";
        StateHasChanged();

        _typingCts?.Cancel();
        _isTypingNotified = false;
        try { await _hub!.InvokeAsync("StopTyping", _selectedConvId); } catch { }

        try
        {
            await CreateClient().PostAsJsonAsync(
                $"api/conversations/{_selectedConvId}/messages",
                new SendMessageDto { Content = text });
        }
        catch { }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }

    private async Task ScrollBottomAsync()
    {
        try { await JS.InvokeVoidAsync("scrollToBottom", _messagesContainer); } catch { }
    }

    private HttpClient CreateClient()
    {
        var client = HttpClientFactory.CreateClient("learnmate");
        client.BaseAddress = new Uri(Nav.BaseUri);
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.AccessToken);
        return client;
    }

    private static string Initials(string name) =>
        string.Concat(name.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                          .Take(2)
                          .Select(w => char.ToUpper(w[0])));

    private static string FormatTime(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        return diff.TotalDays < 1 ? dt.ToString("h:mm tt")
             : diff.TotalDays < 7 ? dt.ToString("ddd")
             : dt.ToString("MMM d");
    }

    public async ValueTask DisposeAsync()
    {
        _typingCts?.Cancel();
        _typingCts?.Dispose();
        if (_hub is not null)
        {
            try { await _hub.StopAsync(); } catch { }
            await _hub.DisposeAsync();
        }
    }
}
